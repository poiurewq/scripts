# Section 9: Help text
# ══════════════════════════════════════════════════════════════════════════════

cmd_synopsis() {
    cat <<'EOF'
qlaude - Claude session utilities

Usage: qlaude [<account>] <command> [args...]

Commands:
  conv      Conversation viewer (token stats, time ranges, live mode)
  skills    List skills
  agents    List agents
  plugins   List plugins
  touch     Send keepalive
  launch    Start a Claude session (requires account)
  config    Manage accounts and display settings
  help      Show detailed help

Accounts: defined in 'qlaude config' (default: only ~/.claude)
  Omit account to operate across all accounts.

Run 'qlaude help' or 'qlaude conv' (no args) for detailed usage.
EOF
}

cmd_help() {
    cat <<'EOF'
qlaude - Claude session utilities

USAGE
  qlaude [<account>] <command> [args...]
  qlaude <account> launch [claude-args...]
  qlaude help

  Omit account to operate across ALL accounts.
  Specific account scopes the command to that account only.

ACCOUNTS  (managed via 'qlaude config'; only 'default → ~/.claude' is hardcoded)
  Run 'qlaude config list' to see current accounts.
  Run 'qlaude config add-dir <name> <basedir>' to add an account.

COMMANDS
  conv [conv-args...]
      Conversation viewer. Shows token usage bar charts for recent sessions.
      No args → detailed usage. Key subcommands:
        qlaude conv 10                       10 most recent (all accounts)
        qlaude sbq conv 10                   10 most recent (sbq only)
        qlaude conv -2 weeks through today   time range
        qlaude conv live                     live watcher

  skills / agents / plugins
      List resources under each account's skills/, agents/, or plugins/ directory.

  touch
      Send a minimal keepalive message to Claude for the account.
      No account → touches all accounts.

  launch [claude-args...]
      Launch claude with CLAUDE_CONFIG_DIR set for the account.
      Requires an explicit account. Examples:
        qlaude sbq launch
        qlaude sbq launch --resume

  config [subcommand...]
      Manage account dirs and display settings. Config file: ~/.config/qlaude/config.zsh
        qlaude config list                         show all settings
        qlaude config add-dir <name> <basedir>     add an account
        qlaude config add-alias <alias> <name>     add a secondary alias
        qlaude config remove-dir <name>            remove an account
        qlaude config set <key> <val>              set a display value
        qlaude config get <key>                    get a value
        qlaude config path                         print config file path
        qlaude config reset [--yes]                restore defaults
      Keys and valid values:
        max_tokens        positive integer (e.g. 20000000)   — bar ceiling (actual mode, norm=fixed)
        max_scaled_tokens positive integer (e.g. 200000000)  — bar ceiling (scaled mode, norm=fixed)
        scale             log | linear                       — bar length scaling
        tokens            actual | scaled                    — displayed count: raw vs cost-weighted
        norm        fixed | dynamic                    — fixed ceiling (max_tokens) or longest-in-view
        w_input     positive integer (×10, e.g. 100 = 10×)
        w_output    positive integer (×10, e.g. 500 = 50×)
        w_cc        positive integer (×10, e.g. 125 = 12.5×)
        w_cr        positive integer (×10, e.g. 10 = 1×)
        live_mode   override | scroll  — live bar: overwrite line vs append new line

  help
      Show this help page.
EOF
}

# ══════════════════════════════════════════════════════════════════════════════
# Section 10: Top-level dispatch
# ══════════════════════════════════════════════════════════════════════════════

# Detect invocation as 'conv' (thin wrapper)
if [[ "$(basename "$0")" == "conv" ]]; then
    _qlaude_account="_all_"
    cmd_conv "$@"
    exit $?
fi

# No args → synopsis
if [[ $# -eq 0 ]]; then
    cmd_synopsis
    exit 0
fi

# Help shortcuts (before account parsing)
case "$1" in
    h|help) cmd_help; exit 0 ;;
esac

# Parse optional account prefix
_qlaude_account="_all_"
if [[ -n "${_QLAUDE_DIRS[$1]:-}" ]]; then
    if [[ $# -ge 2 ]]; then
        case "$2" in
            conv|skills|agents|plugins|touch|launch|h|help)
                _qlaude_account="$1"
                shift
                ;;
            *)
                echo "qlaude: unknown command '$2'" >&2
                echo "Run 'qlaude help' for available commands." >&2
                exit 1
                ;;
        esac
    else
        echo "qlaude: missing command after account '$1'" >&2
        echo "Run 'qlaude help' for available commands." >&2
        exit 1
    fi
fi

# Route to subcommand
case "$1" in
    conv)    shift; cmd_conv "$@" ;;
    skills)  cmd_skills "$_qlaude_account" ;;
    agents)  cmd_agents "$_qlaude_account" ;;
    plugins) cmd_plugins "$_qlaude_account" ;;
    touch)   cmd_touch "$_qlaude_account" ;;
    launch)  shift; cmd_launch "$_qlaude_account" "$@" ;;
    config)  shift; cmd_config "$@" ;;
    h|help)  cmd_help ;;
    *)
        echo "qlaude: unknown command '$1'" >&2
        echo "Run 'qlaude help' for available commands." >&2
        exit 1
        ;;
esac
