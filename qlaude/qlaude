# Section 6: Resource listing commands
# ══════════════════════════════════════════════════════════════════════════════

_qlaude_list_resource() {
    local account="$1" subdir="$2" label="$3"
    local acct base dir entries printed_any

    if [[ "$account" == "_all_" ]]; then
        printed_any=0
        for acct in "${_QLAUDE_ALL[@]}"; do
            base="${_QLAUDE_DIRS[$acct]}"
            [[ -n "$base" ]] || continue
            dir="$base/$subdir"
            [[ -d "$dir" ]] || continue
            entries=()
            while IFS= read -r -d '' child; do
                entries+=("$(basename "$child")")
            done < <(find -L "$dir" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
            (( ${#entries[@]} == 0 )) && continue
            printf '%s:\n' "$acct"
            printf '  %s\n' "${entries[@]}"
            printed_any=1
        done
        (( printed_any )) || echo "No $label found across all accounts."
    else
        base="${_QLAUDE_DIRS[$account]}"
        if [[ -z "$base" ]]; then
            echo "Unknown account: '$account'" >&2; return 1
        fi
        dir="$base/$subdir"
        if [[ ! -d "$base" ]]; then
            echo "Directory not found: $base" >&2; return 1
        elif [[ ! -d "$dir" ]]; then
            echo "No ${subdir}/ directory found under $base" >&2; return 1
        fi
        entries=()
        while IFS= read -r -d '' child; do
            entries+=("$(basename "$child")")
        done < <(find -L "$dir" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
        if (( ${#entries[@]} == 0 )); then
            echo "No ${label} found for $(account_label "$account")."
            return
        fi
        printf '%s\n' "${entries[@]}"
    fi
}

cmd_skills() { _qlaude_list_resource "$1" "skills" "skills"; }
cmd_agents() { _qlaude_list_resource "$1" "agents" "agents"; }

_qlaude_list_plugins() {
    local account="$1"
    local acct base file plugins printed_any

    if [[ "$account" == "_all_" ]]; then
        printed_any=0
        for acct in "${_QLAUDE_ALL[@]}"; do
            base="${_QLAUDE_DIRS[$acct]}"
            [[ -n "$base" ]] || continue
            file="$base/plugins/installed_plugins.json"
            [[ -f "$file" ]] || continue
            plugins=$(jq -r '.plugins | keys[] | split("@")[0]' "$file" 2>/dev/null | sort)
            [[ -z "$plugins" ]] && continue
            printf '%s:\n' "$acct"
            printf '  %s\n' "${(f)plugins}"
            printed_any=1
        done
        (( printed_any )) || echo "No installed plugins found across all accounts."
    else
        base="${_QLAUDE_DIRS[$account]}"
        if [[ -z "$base" ]]; then
            echo "Unknown account: '$account'" >&2; return 1
        fi
        file="$base/plugins/installed_plugins.json"
        if [[ ! -d "$base" ]]; then
            echo "Directory not found: $base" >&2; return 1
        elif [[ ! -f "$file" ]]; then
            echo "No installed_plugins.json found under $base/plugins/" >&2; return 1
        fi
        plugins=$(jq -r '.plugins | keys[] | split("@")[0]' "$file" 2>/dev/null | sort)
        if [[ -z "$plugins" ]]; then
            echo "No installed plugins found for $(account_label "$account")."
            return
        fi
        echo "$plugins"
    fi
}

cmd_plugins() { _qlaude_list_plugins "$1"; }

# ══════════════════════════════════════════════════════════════════════════════
# Section 7: Touch command
# ══════════════════════════════════════════════════════════════════════════════

_qlaude_touch_one() {
    local base="${_QLAUDE_DIRS[$1]}"
    CLAUDE_CONFIG_DIR="$base" \claude --no-session-persistence --tools "" --effort low --model haiku -p <<< 'just say the word hi back' > /dev/null
}

cmd_touch() {
    local account="$1"
    local acct
    if [[ "$account" == "_all_" ]]; then
        for acct in "${_QLAUDE_ALL[@]}"; do
            echo "→ Touching $(account_label "$acct")..."
            _qlaude_touch_one "$acct"
        done
    else
        _qlaude_touch_one "$account"
    fi
}

# ══════════════════════════════════════════════════════════════════════════════
# Section 8: Launch command
# ══════════════════════════════════════════════════════════════════════════════

cmd_launch() {
    local account="$1"; shift
    if [[ "$account" == "_all_" ]]; then
        echo "qlaude: launch requires a specific account, e.g. qlaude sbq launch" >&2
        exit 1
    fi
    local base="${_QLAUDE_DIRS[$account]}"
    if [[ -z "$base" ]]; then
        echo "qlaude: unknown account '$account'" >&2; exit 1
    fi
    CLAUDE_CONFIG_DIR="$base" \claude "$@"
}

