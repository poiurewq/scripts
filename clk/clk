# Initialize log
clk__ensure_log

#####################################################################
# Argument parsing and subcommand dispatch
#####################################################################

# Shared option-parsing helpers used by subcommand parsers.
# These consume arguments from the caller's positional params via
# variable names rather than shift (since we parse in a while loop).

clk_subcmd=""
clk_tag=""
clk_at_timestamp=""
clk_minus_minutes=""
clk_description=""
clk_for_minutes=""
clk_from_tag=""
clk_last_n=""

case "$1" in

in)
    clk_subcmd="in"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing <tag> in 'clk in <tag>'. Run 'clk' for usage."
    fi
    clk_tag="$1"; shift

    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <minutes> after 'minus'."
                clk__validate_positive_int "$2" "<minutes> after 'minus'"
                clk_minus_minutes="$2"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__validate_timestamp "$2"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift 2
                ;;
            on)
                [ $# -ge 2 ] || clk__die 1 "Missing <description> after 'on'."
                shift  # consume 'on'
                clk_description="$*"
                break  # 'on' consumes all remaining args
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk in ${clk_tag}'."
                ;;
        esac
    done

    clk_do_in "$clk_tag" "$clk_at_timestamp" "$clk_minus_minutes" "$clk_description"
    ;;

out)
    clk_subcmd="out"
    shift

    # Tag is optional — peek at first arg to see if it's a tag or an option
    if [ $# -gt 0 ] && [ "$1" != "minus" ] && [ "$1" != "at" ] && [ "$1" != "on" ]; then
        clk_tag="$1"; shift
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <minutes> after 'minus'."
                clk__validate_positive_int "$2" "<minutes> after 'minus'"
                clk_minus_minutes="$2"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__validate_timestamp "$2"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift 2
                ;;
            on)
                [ $# -ge 2 ] || clk__die 1 "Missing <description> after 'on'."
                shift
                clk_description="$*"
                break
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk out'."
                ;;
        esac
    done

    clk_do_out "$clk_tag" "$clk_at_timestamp" "$clk_minus_minutes" "$clk_description"
    ;;

status|s)
    clk_subcmd="status"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk status'"
    clk_do_status
    ;;

last|l)
    clk_subcmd="last"
    shift
    if [ $# -gt 0 ]; then
        if printf '%s' "$1" | grep -Eq '^-[1-9][0-9]*$' || printf '%s' "$1" | grep -Eq '^[1-9][0-9]*$'; then
            clk_last_n="$1"
        else
            clk__die 1 "Expected a nonzero integer (e.g., -1 or 2) for 'clk last', got '$1'."
        fi
    fi
    clk_do_last "${clk_last_n:--1}"
    ;;

pause|p)
    clk_subcmd="pause"
    shift

    # Tag is optional — peek at first arg
    if [ $# -gt 0 ] && [ "$1" != "minus" ] && [ "$1" != "at" ]; then
        clk_tag="$1"; shift
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <minutes> after 'minus'."
                clk__validate_positive_int "$2" "<minutes> after 'minus'"
                clk_minus_minutes="$2"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__validate_timestamp "$2"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift 2
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk pause'."
                ;;
        esac
    done

    clk_do_pause "$clk_tag" "$clk_minus_minutes" "$clk_at_timestamp"
    ;;

resume|r)
    clk_subcmd="resume"
    shift

    # Tag is optional — peek at first arg
    if [ $# -gt 0 ] && [ "$1" != "minus" ] && [ "$1" != "at" ]; then
        clk_tag="$1"; shift
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <minutes> after 'minus'."
                clk__validate_positive_int "$2" "<minutes> after 'minus'"
                clk_minus_minutes="$2"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__validate_timestamp "$2"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift 2
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk resume'."
                ;;
        esac
    done

    clk_do_resume "$clk_tag" "$clk_minus_minutes" "$clk_at_timestamp"
    ;;

unpause)
    clk_subcmd="unpause"
    shift

    # Tag is optional
    if [ $# -gt 0 ]; then
        clk_tag="$1"; shift
    fi
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk unpause [<tag>]'"

    clk_do_unpause "$clk_tag"
    ;;

switch)
    clk_subcmd="switch"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing <new-tag> in 'clk switch <new-tag>'. Run 'clk' for usage."
    fi
    clk_tag="$1"; shift

    while [ $# -gt 0 ]; do
        case "$1" in
            from)
                [ $# -ge 2 ] || clk__die 1 "Missing <old-tag> after 'from'."
                clk_from_tag="$2"; shift 2
                ;;
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <minutes> after 'minus'."
                clk__validate_positive_int "$2" "<minutes> after 'minus'"
                clk_minus_minutes="$2"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__validate_timestamp "$2"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift 2
                ;;
            on)
                [ $# -ge 2 ] || clk__die 1 "Missing <description> after 'on'."
                shift
                clk_description="$*"
                break
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk switch ${clk_tag}'."
                ;;
        esac
    done

    clk_do_switch "$clk_tag" "$clk_from_tag" "$clk_at_timestamp" "$clk_minus_minutes" "$clk_description"
    ;;

add|a)
    clk_subcmd="add"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing arguments. Usage: 'clk add <tag> for <minutes>' or 'clk add <minutes> [to <tag>]'."
    fi

    # Disambiguate: if $1 is a positive integer, it's "add <minutes> [to <tag>]"
    if printf '%s' "$1" | grep -Eq '^[0-9]+$'; then
        # Form: add <minutes> [to <tag>]
        clk_for_minutes="$1"; shift
        if [ $# -gt 0 ] && [ "$1" = "to" ]; then
            [ $# -ge 2 ] || clk__die 1 "Missing <tag> after 'to'."
            clk_tag="$2"; shift 2
        fi
        [ $# -eq 0 ] || clk__die 1 "Unexpected argument '$1' after 'clk add $clk_for_minutes'."
        clk_do_add_time "$clk_for_minutes" "$clk_tag"
    else
        # Form: add <tag> for <minutes> [minus <minutes> | at <timestamp>] [on <description>]
        clk_tag="$1"; shift
        if [ $# -eq 0 ] || [ "$1" != "for" ]; then
            clk__die 1 "Expected 'for <minutes>' after 'clk add ${clk_tag}'. Run 'clk' for usage."
        fi
        shift  # consume 'for'
        [ $# -ge 1 ] || clk__die 1 "Missing <minutes> after 'for'."
        clk__validate_positive_int "$1" "<minutes> after 'for'"
        clk_for_minutes="$1"; shift

        while [ $# -gt 0 ]; do
            case "$1" in
                minus)
                    [ $# -ge 2 ] || clk__die 1 "Missing <minutes> after 'minus'."
                    clk__validate_positive_int "$2" "<minutes> after 'minus'"
                    clk_minus_minutes="$2"; shift 2
                    ;;
                at)
                    [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                    clk__validate_timestamp "$2"
                    clk_at_timestamp="$CLK_VALIDATED_TS"; shift 2
                    ;;
                on)
                    [ $# -ge 2 ] || clk__die 1 "Missing <description> after 'on'."
                    shift
                    clk_description="$*"
                    break
                    ;;
                *)
                    clk__die 1 "Unknown option '$1' after 'clk add ${clk_tag} for ${clk_for_minutes}'."
                    ;;
            esac
        done

        clk_do_add_session "$clk_tag" "$clk_for_minutes" "$clk_at_timestamp" "$clk_minus_minutes" "$clk_description"
    fi
    ;;

add-break|ab)
    clk_subcmd="add-break"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing <minutes> in 'clk add-break <minutes>'. Run 'clk' for usage."
    fi
    clk__validate_positive_int "$1" "<minutes> in 'clk add-break <minutes>'"
    clk_for_minutes="$1"; shift

    if [ $# -gt 0 ] && [ "$1" = "to" ]; then
        [ $# -ge 2 ] || clk__die 1 "Missing <tag> after 'to'."
        clk_tag="$2"; shift 2
    fi
    [ $# -eq 0 ] || clk__die 1 "Unexpected argument '$1'. Usage: 'clk add-break <minutes> [to <tag>]'."

    clk_do_add_break "$clk_for_minutes" "$clk_tag"
    ;;

extend)
    clk_subcmd="extend"
    shift

    # Tag is optional — peek at first arg
    if [ $# -gt 0 ] && [ "$1" != "minus" ] && [ "$1" != "at" ] && [ "$1" != "by" ]; then
        clk_tag="$1"; shift
    fi

    clk_by_minutes=""
    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <minutes> after 'minus'."
                clk__validate_positive_int "$2" "<minutes> after 'minus'"
                clk_minus_minutes="$2"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__validate_timestamp "$2"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift 2
                ;;
            by)
                [ $# -ge 2 ] || clk__die 1 "Missing <minutes> after 'by'."
                clk__validate_positive_int "$2" "<minutes> after 'by'"
                clk_by_minutes="$2"; shift 2
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk extend'."
                ;;
        esac
    done

    clk_do_extend "$clk_tag" "$clk_at_timestamp" "$clk_minus_minutes" "$clk_by_minutes"
    ;;

remove|pop)
    clk_subcmd="remove"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk remove'"
    clk_do_remove
    ;;

undo)
    clk_subcmd="undo"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk undo'"
    clk_do_undo
    ;;

redo)
    clk_subcmd="redo"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk redo'"
    clk_do_redo
    ;;

view|v)
    clk_subcmd="view"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing arguments. Usage: 'clk view today', 'clk view past <n> <unit>', or 'clk view from <ts> until <ts>'."
    fi

    view_start_epoch=""
    view_end_epoch=""
    view_range_desc=""

    case "$1" in
        all)
            shift
            view_start_epoch=0
            view_end_epoch="$(clk__now_epoch)"
            view_range_desc="All time"
            ;;
        past)
            shift
            # past [<n>] <unit> [before <timestamp> | before minus <minutes>]
            view_n=1
            view_unit=""

            if [ $# -eq 0 ]; then
                clk__die 1 "Missing time unit after 'past'. Usage: 'clk view past [<n>] <hour(s)|day(s)|week(s)|month(s)|year(s)>'."
            fi

            # If first arg is a number, it's the count
            if printf '%s' "$1" | grep -Eq '^[0-9]+$'; then
                view_n="$1"; shift
            fi

            if [ $# -eq 0 ]; then
                clk__die 1 "Missing time unit. Expected 'hour(s)', 'day(s)', 'week(s)', 'month(s)', or 'year(s)'."
            fi

            # --- RATIONALE: Plurality leniency in view ---
            # hour/hours, day/days, week/weeks are all accepted. Natural language is
            # lenient; the CLI should be too when intent is unambiguous.
            case "$1" in
                hour|hours)   view_unit="hours"; shift ;;
                day|days)     view_unit="days"; shift ;;
                week|weeks)   view_unit="weeks"; shift ;;
                month|months) view_unit="months"; shift ;;
                year|years)   view_unit="years"; shift ;;
                *) clk__die 1 "Unknown time unit '$1'. Expected 'hour(s)', 'day(s)', 'week(s)', 'month(s)', or 'year(s)'." ;;
            esac

            # Default anchor is now
            view_anchor_epoch="$(clk__now_epoch)"

            # Optional: before <timestamp> | before minus <minutes>
            if [ $# -gt 0 ]; then
                if [ "$1" = "before" ]; then
                    shift
                    if [ $# -eq 0 ]; then
                        clk__die 1 "Missing value after 'before'. Expected a timestamp or 'minus <minutes>'."
                    fi
                    if [ "$1" = "minus" ]; then
                        shift
                        [ $# -ge 1 ] || clk__die 1 "Missing <minutes> after 'before minus'."
                        clk__validate_positive_int "$1" "<minutes> after 'before minus'"
                        before_minus_val="$1"; shift
                        now_ep="$(clk__now_epoch)"
                        view_anchor_epoch=$(( now_ep - before_minus_val * 60 ))
                    else
                        clk__validate_timestamp "$1"
                        view_anchor_epoch="$(clk__to_epoch "$CLK_VALIDATED_TS")"; shift
                    fi
                elif [ "$1" != "for" ]; then
                    clk__die 1 "Unexpected argument '$1'. Expected 'before', 'for', or end of command."
                fi
            fi

            duration_secs=0
            case "$view_unit" in
                hours)  duration_secs=$(( view_n * 3600 )) ;;
                days)   duration_secs=$(( view_n * 86400 )) ;;
                weeks)  duration_secs=$(( view_n * 604800 )) ;;
                months) duration_secs=$(( view_n * 2592000 )) ;;
                years)  duration_secs=$(( view_n * 31536000 )) ;;
            esac

            view_end_epoch="$view_anchor_epoch"
            view_start_epoch=$(( view_anchor_epoch - duration_secs ))
            # Singularize unit when count is 1
            view_unit_display="$view_unit"
            if [ "$view_n" -eq 1 ]; then
                view_unit_display="${view_unit%s}"
            fi
            view_range_desc="Past ${view_n} ${view_unit_display}"
            ;;
        from)
            shift
            [ $# -ge 1 ] || clk__die 1 "Missing <timestamp> after 'from'."
            clk__validate_timestamp "$1"
            view_start_epoch="$(clk__to_epoch "$CLK_VALIDATED_TS")"; shift

            if [ $# -eq 0 ] || { [ "$1" != "until" ] && [ "$1" != "to" ]; }; then
                clk__die 1 "Expected 'until|to <timestamp>' after 'from <timestamp>'."
            fi
            shift  # consume 'until' or 'to'
            [ $# -ge 1 ] || clk__die 1 "Missing <timestamp> after 'until/to'."
            clk__validate_timestamp "$1"
            view_end_epoch="$(clk__to_epoch "$CLK_VALIDATED_TS")"; shift

            from_ts="$(clk__from_epoch "$view_start_epoch")"
            until_ts="$(clk__from_epoch "$view_end_epoch")"
            view_range_desc="$(clk__fmt_ts_display "$from_ts") → $(clk__fmt_ts_display "$until_ts")"
            ;;
        -[0-9]*|current|this|today|yesterday)
            view_offset_unit=""
            case "$1" in
                today)     view_offset=0; view_offset_unit="day" ;;
                yesterday) view_offset=1; view_offset_unit="day" ;;
                current|this) view_offset=0 ;;
                *)
                    view_offset="${1#-}"
                    if ! printf '%s' "$view_offset" | grep -Eq '^[0-9]+$'; then
                        clk__die 1 "Invalid offset '$1'. Expected '-<n>' (e.g., '-0', '-3')."
                    fi
                    ;;
            esac
            shift

            # today/yesterday imply day; others require explicit unit
            if [ -z "$view_offset_unit" ]; then
                [ $# -ge 1 ] || clk__die 1 "Missing time unit after offset. Expected 'day(s)', 'week(s)', or 'month(s)'."
                view_offset_unit="$1"; shift
            fi

            case "$view_offset_unit" in
                day|days)
                    view_start_epoch="$(clk__midnight_epoch "-$view_offset")"
                    if [ "$view_offset" -eq 0 ]; then
                        view_end_epoch="$(clk__now_epoch)"
                        view_range_desc="Today"
                    else
                        view_end_epoch="$(clk__midnight_epoch "-$(( view_offset - 1 ))")"
                        if [ "$view_offset" -eq 1 ]; then
                            view_range_desc="Yesterday"
                        else
                            view_range_desc="${view_offset} days ago"
                        fi
                    fi
                    ;;
                week|weeks)
                    view_start_epoch="$(clk__week_start_epoch "-$view_offset")"
                    if [ "$view_offset" -eq 0 ]; then
                        view_end_epoch="$(clk__now_epoch)"
                        view_range_desc="This week"
                    else
                        view_end_epoch="$(clk__week_start_epoch "-$(( view_offset - 1 ))")"
                        if [ "$view_offset" -eq 1 ]; then
                            view_range_desc="Last week"
                        else
                            view_range_desc="${view_offset} weeks ago"
                        fi
                    fi
                    ;;
                month|months)
                    view_start_epoch="$(clk__month_start_epoch "-$view_offset")"
                    if [ "$view_offset" -eq 0 ]; then
                        view_end_epoch="$(clk__now_epoch)"
                        view_range_desc="This month"
                    else
                        view_end_epoch="$(clk__month_start_epoch "-$(( view_offset - 1 ))")"
                        if [ "$view_offset" -eq 1 ]; then
                            view_range_desc="Last month"
                        else
                            view_range_desc="${view_offset} months ago"
                        fi
                    fi
                    ;;
                *) clk__die 1 "Unknown time unit '$view_offset_unit'. Expected 'day(s)', 'week(s)', or 'month(s)'." ;;
            esac

            # Optional: through {-<m> | current | this | today | yesterday} [<unit>]
            if [ $# -gt 0 ] && [ "$1" = "through" ]; then
                shift
                [ $# -ge 1 ] || clk__die 1 "Missing offset after 'through'. Expected '-<n>', 'current', 'today', or 'yesterday'."
                view_thru_unit=""
                case "$1" in
                    today)          view_thru_offset=0; view_thru_unit="day" ;;
                    yesterday)      view_thru_offset=1; view_thru_unit="day" ;;
                    current|this)   view_thru_offset=0 ;;
                    *)
                        view_thru_offset="${1#-}"
                        if ! printf '%s' "$view_thru_offset" | grep -Eq '^[0-9]+$'; then
                            clk__die 1 "Invalid offset '$1' after 'through'. Expected '-<n>', 'current', 'today', or 'yesterday'."
                        fi
                        ;;
                esac
                shift

                if [ -z "$view_thru_unit" ]; then
                    [ $# -ge 1 ] || clk__die 1 "Missing time unit after 'through' offset. Expected 'day(s)', 'week(s)', or 'month(s)'."
                    view_thru_unit="$1"; shift
                fi

                view_thru_label=""
                case "$view_thru_unit" in
                    day|days)
                        if [ "$view_thru_offset" -eq 0 ]; then
                            view_end_epoch="$(clk__now_epoch)"
                            view_thru_label="today"
                        else
                            view_end_epoch="$(clk__midnight_epoch "-$(( view_thru_offset - 1 ))")"
                            if [ "$view_thru_offset" -eq 1 ]; then
                                view_thru_label="yesterday"
                            else
                                view_thru_label="${view_thru_offset} days ago"
                            fi
                        fi
                        ;;
                    week|weeks)
                        if [ "$view_thru_offset" -eq 0 ]; then
                            view_end_epoch="$(clk__now_epoch)"
                            view_thru_label="this week"
                        else
                            view_end_epoch="$(clk__week_start_epoch "-$(( view_thru_offset - 1 ))")"
                            if [ "$view_thru_offset" -eq 1 ]; then
                                view_thru_label="last week"
                            else
                                view_thru_label="${view_thru_offset} weeks ago"
                            fi
                        fi
                        ;;
                    month|months)
                        if [ "$view_thru_offset" -eq 0 ]; then
                            view_end_epoch="$(clk__now_epoch)"
                            view_thru_label="this month"
                        else
                            view_end_epoch="$(clk__month_start_epoch "-$(( view_thru_offset - 1 ))")"
                            if [ "$view_thru_offset" -eq 1 ]; then
                                view_thru_label="last month"
                            else
                                view_thru_label="${view_thru_offset} months ago"
                            fi
                        fi
                        ;;
                    *) clk__die 1 "Unknown time unit '$view_thru_unit' after 'through'. Expected 'day(s)', 'week(s)', or 'month(s)'." ;;
                esac

                if [ "$view_end_epoch" -le "$view_start_epoch" ]; then
                    clk__die 1 "'through' end must be after start. The 'through' period must be more recent than the starting period."
                fi

                view_range_desc="${view_range_desc} through ${view_thru_label}"
            fi
            ;;
        *)
            clk__die 1 "Unknown view mode '$1'. Expected 'all', 'today', 'yesterday', 'past', 'from', '-<n>', 'current', or 'this'."
            ;;
    esac

    # Optional: for <tag> — filter by tag
    view_filter_tag=""
    if [ $# -gt 0 ] && [ "$1" = "for" ]; then
        shift
        [ $# -ge 1 ] || clk__die 1 "Missing <tag> after 'for'."
        view_filter_tag="$1"; shift
    fi

    # Optional: by <day|week|month|session> — group by time bucket
    view_group_by=""
    if [ $# -gt 0 ] && [ "$1" = "by" ]; then
        shift
        [ $# -ge 1 ] || clk__die 1 "Missing <day|week|month|session> after 'by'."
        case "$1" in
            day)     view_group_by="day"; shift ;;
            week)    view_group_by="week"; shift ;;
            month)   view_group_by="month"; shift ;;
            session) view_group_by="session"; shift ;;
            *) clk__die 1 "Unknown grouping '$1'. Expected 'day', 'week', 'month', or 'session'." ;;
        esac
    fi

    [ $# -eq 0 ] || clk__die 1 "Unexpected argument '$1' after 'clk view'."

    clk_do_view "$view_start_epoch" "$view_end_epoch" "$view_range_desc" "$view_filter_tag" "$view_group_by"
    ;;

edit|e)
    clk_subcmd="edit"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing index. Usage: 'clk edit (-<n> | <n>) <field> <value>'."
    fi

    # Parse signed index: -<n> targets done sessions, <n> targets active sessions
    clk_edit_n=""
    if printf '%s' "$1" | grep -Eq '^-[1-9][0-9]*$'; then
        clk_edit_n="$1"; shift
    elif printf '%s' "$1" | grep -Eq '^[1-9][0-9]*$'; then
        clk_edit_n="$1"; shift
    else
        clk__die 1 "Expected -<n> (done) or <n> (active) index, got '$1'. Usage: 'clk edit (-<n> | <n>) <field> <value>'."
    fi

    if [ $# -eq 0 ]; then
        clk__die 1 "Missing field. Usage: 'clk edit ${clk_edit_n} <field> <value>'."
    fi

    clk_edit_field="$1"; shift

    # For 'on', collect all remaining args as the description
    # For 'delete', no value needed
    # For others, take next arg as value
    clk_edit_value=""
    case "$clk_edit_field" in
        on)
            [ $# -ge 1 ] || clk__die 1 "Missing <description> after 'on'."
            clk_edit_value="$*"
            ;;
        delete)
            [ $# -eq 0 ] || clk__die 1 "Unexpected argument '$1' after 'delete'."
            ;;
        tag|start|end|break|pause)
            [ $# -ge 1 ] || clk__die 1 "Missing value for 'edit ${clk_edit_n} ${clk_edit_field}'."
            clk_edit_value="$1"; shift
            [ $# -eq 0 ] || clk__die 1 "Unexpected argument '$1' after 'clk edit ${clk_edit_n} ${clk_edit_field} ${clk_edit_value}'."
            ;;
        *)
            clk__die 1 "Unknown field '${clk_edit_field}'. Expected: tag, start, end, break, pause, on, delete."
            ;;
    esac

    clk_do_edit "$clk_edit_n" "$clk_edit_field" "$clk_edit_value"
    ;;

log)
    clk_subcmd="log"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk log'"
    clk_do_log
    ;;

alias)
    clk_subcmd="alias"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk alias'"
    clk_do_alias
    ;;

-[0-9]*)
    # Syntactic sugar: clk -<n> → clk last -<n>
    clk_subcmd="last"
    clk_last_n="$1"
    clk__validate_positive_int "${clk_last_n#-}" "<n> in 'clk -<n>'"
    clk_do_last "$clk_last_n"
    ;;

*)
    clk__die 1 "Unknown command '$1'. Run 'clk' with no arguments for usage."
    ;;

esac
