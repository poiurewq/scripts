#!/usr/bin/env bash
# clk — time-tracking CLI
#
# v3 rewrite: functions-not-copy-paste architecture, unified record schema,
# seconds-precision durations, multiple active sessions.

# --- RATIONALE: No set -e ---
# set -e interacts poorly with conditionals and command substitutions in bash.
# Errors are handled explicitly via || clk__die throughout. set -u is used
# to catch unset variable bugs.
set -u

#####################################################################
# Constants & format definitions
#####################################################################

CLK_FMT='%Y-%m-%dT%H:%M:%S'
CLK_USER_FMT='yyyy-mm-ddTHH:MM:SS (or HH:MM, HH:MM:SS, yyyy-mm-ddTHH:MM, yyyy-mm-dd HH:MM, yyyy-mm-dd)'
CLK_FMT_RAW=0
CLK_FMT_DONE_TAG_WIDTH=0
CLK_TAB='	'
CLK_LOG_VERSION_MARKER='#clk-v3'
CLK_VERSION="0.4.4"

# Detect OS once; all platform differences are isolated in helper functions.
CLK_OS="$(uname)"
case "$CLK_OS" in
    Linux|Darwin) : ;;
    *) printf "clk: unsupported operating system '%s'\n" "$CLK_OS" >&2; exit 3 ;;
esac

# Temp file for capturing stderr from subprocesses (date, etc.)
CLK_TMP_ERR=""

# Log file paths (set by clk__ensure_log)
CLK_DIR=""
CLK_LOG=""
CLK_LOG_TMP=""

# Synopsis for --help / no-args display
read -r -d '' CLK_SYNOPSIS << 'EOF' || true
clk [help]

Core workflow:
    in <tag> [minus <duration> | at <timestamp>] [on <description>]
    in-focus | I <tag> [minus <duration> | at <timestamp>] [on <description>]
    out [<tag>] [minus <duration> | at <timestamp>] [on <description>]
    switch <new-tag> [from <old-tag>] [minus <duration> | at <timestamp>] [on <description>]
    pause | p [<tag>] [minus <duration> | at <timestamp>]
    resume | r [<tag>] [minus <duration> | at <timestamp>]
    resume-focus | R <tag> [minus <duration> | at <timestamp>]
    unpause | up [<tag>]

Record management:
    add | a <tag> for <duration> [minus <duration> | at <timestamp>] [on <description>]
    add | a <duration> [to <tag>]
    add-break | ab <duration> [to <tag>]
    extend [<tag>] [minus <duration> | at <timestamp> | by <duration>]
    pop [-<n> | <n>]
    reactivate | ra -<n>

Editing:
    edit | e                                              (interactive)
    edit | e (-<n> | <n>) {tag|start|pause|on} <value>
    edit | e (-<n> | <n>) {end} <timestamp> [--adjust active|break]
    edit | e (-<n> | <n>) {active|break} <duration> [--adjust ...]
    edit | e (-<n> | <n>) delete

Viewing:
    status | s
    last | l [<n>]
    -<n> | <n>
    log
    view | v <range> [<filter>]
    <range> [<filter>]

Utilities:
    undo | redo
    alias

<range>:
    all | today | yesterday
    {-<n> | this} <unit> [through ...]
    past [<n>] <unit> [before <timestamp> | before minus <duration>]
    from <timestamp> to <timestamp>

<filter>:
    [for <tag,tag.,...>] [by {day|week|month|session}]

<unit>       = hour(s) | day(s) | week(s) | month(s) | year(s)
<timestamp>  = HH:MM | HH:MM:SS | yyyy-mm-dd | yyyy-mm-ddTHH:MM | yyyy-mm-dd HH:MM | yyyy-mm-ddTHH:MM:SS
<duration>   = <minutes> | Xh | Ym | XhYm    (e.g., 90, 2h, 45m, 1h30m)
EOF

#####################################################################
# Helper functions
#####################################################################

# --- clk__die(exit_code, message, [upstream_detail]) ---
# Prints message to stderr. If upstream_detail is provided, appends it
# indented below the main message. Exits with exit_code.
clk__die() {
    local code="$1" msg="$2"
    printf 'clk: %s\n' "$msg" >&2
    if [ -n "${3:-}" ]; then
        printf '  %s\n' "$3" >&2
    fi
    exit "$code"
}

# --- OS shim layer ---
# All date(1) differences between Linux and Darwin are isolated here.
# No case "$CLK_OS" appears in business logic.

# clk__to_epoch(timestamp) → epoch
# Input:  timestamp in CLK_FMT (e.g., "2026-03-19T18:45:00")
# Output: Unix epoch seconds on stdout
# Exit 4 on failure, with captured date(1) stderr in the message.
clk__to_epoch() {
    local ts="$1" result exit_code=0
    case "$CLK_OS" in
        Linux)  result="$(date -d "$ts" +'%s' 2>"$CLK_TMP_ERR")" || exit_code=$? ;;
        Darwin) result="$(date -j -f "$CLK_FMT" "$ts" +'%s' 2>"$CLK_TMP_ERR")" || exit_code=$? ;;
    esac
    if [ "$exit_code" -ne 0 ]; then
        clk__die 4 "Failed to parse timestamp '$ts'" "$(cat "$CLK_TMP_ERR")"
    fi
    printf '%s' "$result"
}

# clk__from_epoch(epoch) → timestamp
# Input:  Unix epoch seconds
# Output: timestamp in CLK_FMT on stdout
clk__from_epoch() {
    local epoch="$1" result exit_code=0
    case "$CLK_OS" in
        Linux)  result="$(date -d "@$epoch" +"$CLK_FMT" 2>"$CLK_TMP_ERR")" || exit_code=$? ;;
        Darwin) result="$(date -r "$epoch" +"$CLK_FMT" 2>"$CLK_TMP_ERR")" || exit_code=$? ;;
    esac
    if [ "$exit_code" -ne 0 ]; then
        clk__die 4 "Failed to format epoch '$epoch'" "$(cat "$CLK_TMP_ERR")"
    fi
    printf '%s' "$result"
}

# clk__now_epoch() → epoch
# Current time as Unix epoch seconds.
clk__now_epoch() {
    date +'%s'
}

# clk__now_fmt() → timestamp
# Current time in CLK_FMT.
clk__now_fmt() {
    date +"$CLK_FMT"
}

# clk__resolve_time(at_val, minus_secs) → timestamp
# Resolves the at/minus/now tri-state that recurs in nearly every subcommand.
# If at_val is set, return it. Elif minus_secs is set, return now - N seconds.
# Else return now.
#
# --- RATIONALE: Extracted tri-state ---
# This tri-state recurs in in, out, switch, add, extend, pause, resume.
# Extracting it eliminates ~80 lines of duplicated logic from v1.
clk__resolve_time() {
    local at_val="$1" minus_secs="$2"
    if [ -n "$at_val" ]; then
        printf '%s' "$at_val"
    elif [ -n "$minus_secs" ]; then
        local now_epoch
        now_epoch="$(clk__now_epoch)"
        clk__from_epoch "$(( now_epoch - minus_secs ))"
    else
        clk__now_fmt
    fi
}

# clk__midnight_epoch(offset_days) → epoch
# Returns the epoch for midnight (00:00:00) of today + offset_days.
# offset_days=0 → midnight today, offset_days=-1 → midnight yesterday, etc.
clk__midnight_epoch() {
    local offset_days="${1:-0}"
    local today_midnight result
    case "$CLK_OS" in
        Linux)
            today_midnight="$(date -d "today 00:00:00" +'%s' 2>"$CLK_TMP_ERR")" \
                || clk__die 4 "Failed to compute midnight" "$(cat "$CLK_TMP_ERR")"
            ;;
        Darwin)
            today_midnight="$(date -j -v0H -v0M -v0S +'%s' 2>"$CLK_TMP_ERR")" \
                || clk__die 4 "Failed to compute midnight" "$(cat "$CLK_TMP_ERR")"
            ;;
    esac
    result=$(( today_midnight + offset_days * 86400 ))
    printf '%s' "$result"
}

# clk__week_start_epoch(offset_weeks) → epoch
# Returns the epoch for Monday 00:00:00 of the current week + offset_weeks.
# offset_weeks=0 → this Monday, offset_weeks=-1 → last Monday, etc.
clk__week_start_epoch() {
    local offset_weeks="${1:-0}"
    local today_midnight dow
    today_midnight="$(clk__midnight_epoch 0)"
    # %u: ISO day of week, 1=Monday … 7=Sunday
    case "$CLK_OS" in
        Linux)  dow="$(date -d "@$today_midnight" +'%u' 2>"$CLK_TMP_ERR")" ;;
        Darwin) dow="$(date -r "$today_midnight" +'%u' 2>"$CLK_TMP_ERR")" ;;
    esac
    local monday_midnight=$(( today_midnight - (dow - 1) * 86400 ))
    printf '%s' $(( monday_midnight + offset_weeks * 604800 ))
}

# clk__month_start_epoch(offset_months) → epoch
# Returns the epoch for the 1st day 00:00:00 of the current month + offset_months.
# offset_months=0 → 1st of this month, offset_months=-1 → 1st of last month, etc.
clk__month_start_epoch() {
    local offset_months="${1:-0}"
    # BSD date -v treats unsigned values as absolute setters (e.g., -v0m = "set
    # month to 0", which is invalid).  A +/- prefix makes it relative instead.
    case "$offset_months" in
        -*) ;;
        *)  offset_months="+${offset_months}" ;;
    esac
    local result
    case "$CLK_OS" in
        Linux)
            result="$(date -d "$(date +%Y-%m-01) ${offset_months} month" +'%s' 2>"$CLK_TMP_ERR")" \
                || clk__die 4 "Failed to compute month start" "$(cat "$CLK_TMP_ERR")"
            ;;
        Darwin)
            result="$(date -j -v1d -v0H -v0M -v0S -v"${offset_months}m" +'%s' 2>"$CLK_TMP_ERR")" \
                || clk__die 4 "Failed to compute month start" "$(cat "$CLK_TMP_ERR")"
            ;;
    esac
    printf '%s' "$result"
}

# clk__hour_start_epoch(offset_hours) → epoch
# Returns the epoch for the top of the current hour + offset_hours.
# offset_hours=0 → :00 of this hour, offset_hours=-1 → :00 of last hour, etc.
clk__hour_start_epoch() {
    local offset_hours="${1:-0}"
    local now_epoch hour_start
    now_epoch="$(clk__now_epoch)"
    hour_start=$(( now_epoch - now_epoch % 3600 ))
    printf '%s' $(( hour_start + offset_hours * 3600 ))
}

# clk__year_start_epoch(offset_years) → epoch
# Returns the epoch for Jan 1 00:00:00 of the current year + offset_years.
# offset_years=0 → Jan 1 this year, offset_years=-1 → Jan 1 last year, etc.
clk__year_start_epoch() {
    local offset_years="${1:-0}"
    # Ensure offset has explicit sign for Darwin -v flag.
    case "$offset_years" in
        -*) ;;
        *)  offset_years="+${offset_years}" ;;
    esac
    local result
    case "$CLK_OS" in
        Linux)
            result="$(date -d "$(date +%Y)-01-01 ${offset_years} year" +'%s' 2>"$CLK_TMP_ERR")" \
                || clk__die 4 "Failed to compute year start" "$(cat "$CLK_TMP_ERR")"
            ;;
        Darwin)
            result="$(date -j -v1m -v1d -v0H -v0M -v0S -v"${offset_years}y" +'%s' 2>"$CLK_TMP_ERR")" \
                || clk__die 4 "Failed to compute year start" "$(cat "$CLK_TMP_ERR")"
            ;;
    esac
    printf '%s' "$result"
}

# clk__fmt_duration(seconds) → "Xh Ym" or "Ym"
# Human-readable duration formatter.
# 0     → "0m"
# 45    → "0m"    (sub-minute rounds down for display; stored value is exact)
# 300   → "5m"
# 3660  → "1h 1m"
# 7200  → "2h 0m"
#
# --- RATIONALE: Seconds not minutes ---
# v1 stored duration in integer minutes, losing up to 59 seconds per session.
# Over hundreds of sessions this drift compounds. Seconds preserve full
# precision; display helpers convert for humans.
clk__fmt_duration() {
    local secs="$1"
    local mins=$(( secs / 60 ))
    local hours=$(( mins / 60 ))
    local rem_mins=$(( mins % 60 ))
    if [ "$hours" -gt 0 ]; then
        printf '%dh %dm' "$hours" "$rem_mins"
    else
        printf '%dm' "$mins"
    fi
}

# clk__fmt_ts_display(ts)
# Formats a stored timestamp for user-facing display:
#   - Drops seconds and replaces the T with a space
#   - If the date is today, shows only HH:MM
#   - Otherwise shows yyyy-mm-dd HH:MM
# When CLK_FMT_RAW=1, returns the timestamp unchanged (used by clk last).
clk__fmt_ts_display() {
    local ts="$1"
    if [ "$CLK_FMT_RAW" = "1" ]; then
        printf '%s' "$ts"
        return
    fi
    # ts format: yyyy-mm-ddTHH:MM:SS
    local date_part="${ts%%T*}"
    local time_full="${ts#*T}"
    local time_hm="${time_full%:*}"    # drop :SS
    local today
    today="$(date +%Y-%m-%d)"
    if [ "$date_part" = "$today" ]; then
        printf '%s' "$time_hm"
    else
        printf '%s %s' "$date_part" "$time_hm"
    fi
}

# clk__fmt_ts_full(ts)
# Always formats as "yyyy-mm-dd HH:MM" (no today-abbreviation).
# Used for view range headers where both endpoints must be unambiguous.
clk__fmt_ts_full() {
    local ts="$1"
    # ts format: yyyy-mm-ddTHH:MM:SS
    local date_part="${ts%%T*}"
    local time_full="${ts#*T}"
    local time_hm="${time_full%:*}"    # drop :SS
    printf '%s %s' "$date_part" "$time_hm"
}

# --- RATIONALE: Unified record schema ---
# v1 used different field positions for active vs completed records (e.g.,
# field 2 was "start time" in active but "tag" in completed). v2 uses a
# single 8-field schema where field N always means the same thing regardless
# of status, eliminating the need to branch on record type for field access.

# clk__read_line(line_content) → sets CLK_F1..CLK_F8
# Parses a record line into global field variables.
# Fields: STATUS START_TIME END_TIME TAG LENGTH_SECS BREAK_SECS PAUSED_AT DESCRIPTION
clk__read_line() {
    local line="$1"
    # Note: bash's IFS-read collapses consecutive delimiters, losing empty
    # fields. Use cut -d<tab> -fN instead, which preserves empty fields.
    CLK_F1="$(printf '%s' "$line" | cut -d"$CLK_TAB" -f1)"
    CLK_F2="$(printf '%s' "$line" | cut -d"$CLK_TAB" -f2)"
    CLK_F3="$(printf '%s' "$line" | cut -d"$CLK_TAB" -f3)"
    CLK_F4="$(printf '%s' "$line" | cut -d"$CLK_TAB" -f4)"
    CLK_F5="$(printf '%s' "$line" | cut -d"$CLK_TAB" -f5)"
    CLK_F6="$(printf '%s' "$line" | cut -d"$CLK_TAB" -f6)"
    CLK_F7="$(printf '%s' "$line" | cut -d"$CLK_TAB" -f7)"
    CLK_F8="$(printf '%s' "$line" | cut -d"$CLK_TAB" -f8)"
}

# clk__fmt_record(line_content) → human-readable string
# Formats a single record for user display.
# For completed records:
#   <tag>  <start_time> → <end_time>  <duration>  (break: Xm)  <description>
# For active records:
#   <tag>  started at <start_time>  (active, <elapsed> so far)  <description>
# Break shown only if > 0. Description shown only if non-empty.
# Pause state shown for active records if paused.
clk__fmt_record() {
    local line="$1"
    clk__read_line "$line"

    local status="$CLK_F1"
    local start_time="$CLK_F2"
    local end_time="$CLK_F3"
    local tag="$CLK_F4"
    local length_secs="$CLK_F5"
    local break_secs="$CLK_F6"
    local paused_at="$CLK_F7"
    local description="$CLK_F8"

    local out=""

    if [ "$status" = "done" ]; then
        local dur_str
        dur_str="$(clk__fmt_duration "$length_secs")"
        local disp_start disp_end
        disp_start="$(clk__fmt_ts_display "$start_time")"
        disp_end="$(clk__fmt_ts_display "$end_time")"
        # Elide end-date when it matches start-date (non-raw mode only):
        # "2026-04-04 14:58 → 2026-04-04 15:43" becomes
        # "2026-04-04 14:58 → 15:43".
        if [ "$CLK_FMT_RAW" != "1" ]; then
            local start_date="${start_time%%T*}"
            local end_date="${end_time%%T*}"
            if [ "$start_date" = "$end_date" ] && [ "${disp_end#* }" != "$disp_end" ]; then
                disp_end="${disp_end#* }"
            fi
        fi
        local tag_display="$tag"
        if [ "${CLK_FMT_DONE_TAG_WIDTH:-0}" -gt "${#tag}" ]; then
            tag_display="$(printf "%-${CLK_FMT_DONE_TAG_WIDTH}s" "$tag")"
        fi
        out="${tag_display}  ${disp_start} → ${disp_end}  ${dur_str}"
        if [ -n "$break_secs" ] && [ "$break_secs" -gt 0 ] 2>/dev/null; then
            local break_str
            break_str="$(clk__fmt_duration "$break_secs")"
            out="${out}  (break: ${break_str})"
        fi
        if [ -n "$description" ]; then
            out="${out}  ${description}"
        fi
    elif [ "$status" = "active" ]; then
        local disp_start
        disp_start="$(clk__fmt_ts_display "$start_time")"
        local tag_display
        if [ "${CLK_FMT_ACTIVE_TAG_WIDTH:-0}" -gt "${#tag}" ]; then
            tag_display="$(printf "%-${CLK_FMT_ACTIVE_TAG_WIDTH}s" "$tag")"
        else
            tag_display="$tag"
        fi
        out="${tag_display}  started at ${disp_start}  (active"
        # Calculate elapsed if possible
        local now_epoch start_epoch elapsed_secs elapsed_str
        now_epoch="$(clk__now_epoch)"
        start_epoch="$(clk__to_epoch "$start_time" 2>/dev/null)" || start_epoch=""
        if [ -n "$start_epoch" ]; then
            elapsed_secs=$(( now_epoch - start_epoch ))
            # Subtract finalized break time
            if [ -n "$break_secs" ] && [ "$break_secs" -gt 0 ] 2>/dev/null; then
                elapsed_secs=$(( elapsed_secs - break_secs ))
            fi
            # If currently paused, subtract ongoing pause too
            if [ -n "$paused_at" ]; then
                elapsed_secs=$(( elapsed_secs - (now_epoch - paused_at) ))
            fi
            if [ "$elapsed_secs" -lt 0 ]; then
                elapsed_secs=0
            fi
            elapsed_str="$(clk__fmt_duration "$elapsed_secs")"
            out="${out}, ${elapsed_str} so far"
        fi
        if [ -n "$paused_at" ]; then
            local paused_ts
            paused_ts="$(clk__from_epoch "$paused_at" 2>/dev/null)" || paused_ts="$paused_at"
            local disp_paused
            disp_paused="$(clk__fmt_ts_display "$paused_ts")"
            out="${out}, paused since ${disp_paused}"
        fi
        out="${out})"
        if [ -n "$description" ]; then
            out="${out}  ${description}"
        fi
    else
        # Unknown status, just dump it
        out="$line"
    fi

    printf '%s' "$out"
}

# --- Validators ---

# clk__validate_tag(tag)
# Exits with error if tag is empty, numeric-only, or contains whitespace/tabs.
clk__validate_tag() {
    local tag="$1"
    if [ -z "$tag" ]; then
        clk__die 1 "Tag cannot be empty."
    fi
    if printf '%s' "$tag" | grep -Eq '^[0-9]+$'; then
        # --- RATIONALE: No numeric tags ---
        # The add subcommand is overloaded: add <tag> for <duration> vs
        # add <duration> [to <tag>]. The parser disambiguates by checking if $2
        # looks like a duration. If tags could be numbers, this would be ambiguous.
        clk__die 1 "Tag '$tag' cannot be purely numeric. Use a descriptive name."
    fi
    if printf '%s' "$tag" | grep -Eq '[[:space:]]'; then
        clk__die 1 "Tag '$tag' cannot contain whitespace. Use dots for hierarchy (e.g., 'pm.bills')."
    fi
}

# clk__normalize_timestamp(ts)
# Accepts simplified timestamp formats and expands them to CLK_FMT:
#   HH:MM              → <today>THH:MM:00
#   HH:MM:SS           → <today>THH:MM:SS
#   yyyy-mm-ddTHH:MM   → yyyy-mm-ddTHH:MM:00
#   yyyy-mm-dd HH:MM   → yyyy-mm-ddTHH:MM:00
#   yyyy-mm-dd         → yyyy-mm-ddT00:00:00
#   Full format        → unchanged
# Outputs normalized timestamp on stdout.
clk__normalize_timestamp() {
    local ts="$1"
    # HH:MM:SS (time only with seconds)
    if printf '%s' "$ts" | grep -Eq '^[0-9]{2}:[0-9]{2}:[0-9]{2}$'; then
        printf '%s' "$(date +%Y-%m-%d)T${ts}"
    # HH:MM (time only, no seconds)
    elif printf '%s' "$ts" | grep -Eq '^[0-9]{2}:[0-9]{2}$'; then
        printf '%s' "$(date +%Y-%m-%d)T${ts}:00"
    # yyyy-mm-ddTHH:MM (date+time with T, no seconds)
    elif printf '%s' "$ts" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}$'; then
        printf '%s' "${ts}:00"
    # yyyy-mm-dd HH:MM (date+time with space, no seconds)
    elif printf '%s' "$ts" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2} [0-9]{2}:[0-9]{2}$'; then
        local d="${ts%% *}"
        local t="${ts##* }"
        printf '%s' "${d}T${t}:00"
    # yyyy-mm-dd (date only → midnight)
    elif printf '%s' "$ts" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
        printf '%s' "${ts}T00:00:00"
    else
        printf '%s' "$ts"
    fi
}

# clk__validate_timestamp(ts)
# Normalizes ts via clk__normalize_timestamp, then validates it matches
# CLK_FMT regex. Sets CLK_VALIDATED_TS to the normalized value.
# Exits with error if the normalized form doesn't match CLK_FMT.
CLK_VALIDATED_TS=""
clk__validate_timestamp() {
    CLK_VALIDATED_TS="$(clk__normalize_timestamp "$1")"
    if ! printf '%s' "$CLK_VALIDATED_TS" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}$'; then
        clk__die 1 "Invalid timestamp '$1'. Expected format: ${CLK_USER_FMT}"
    fi
}

# clk__consume_timestamp(arg1 [arg2])
# Like clk__validate_timestamp, but also handles a date and time supplied as two
# separate shell words (e.g. "2026-03-24" "16:00"). Sets CLK_VALIDATED_TS and
# CLK_TIMESTAMP_ARGC (1 or 2) to indicate how many args were consumed.
CLK_TIMESTAMP_ARGC=0
clk__consume_timestamp() {
    local _ts="$1"
    local _next="${2:-}"
    if printf '%s' "$_ts" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}$' && \
       printf '%s' "$_next" | grep -Eq '^[0-9]{2}:[0-9]{2}(:[0-9]{2})?$'; then
        clk__validate_timestamp "$_ts $_next"
        CLK_TIMESTAMP_ARGC=2
    else
        clk__validate_timestamp "$_ts"
        CLK_TIMESTAMP_ARGC=1
    fi
}

# clk__validate_positive_int(val, label)
# Exits with error if val is not a positive integer.
clk__validate_positive_int() {
    local val="$1" label="$2"
    if ! printf '%s' "$val" | grep -Eq '^[0-9]+$'; then
        clk__die 1 "Expected a positive integer for ${label}, got '$val'."
    fi
}

# clk__parse_duration(str) → sets CLK_PARSED_DURATION_SECS
# Accepts: plain integer (minutes), "Xh", "Ym", "XhYm" (case-insensitive).
# Dies on invalid input.
CLK_PARSED_DURATION_SECS=0
clk__parse_duration() {
    local input="$1"
    # Plain integer → minutes
    if printf '%s' "$input" | grep -Eq '^[0-9]+$'; then
        CLK_PARSED_DURATION_SECS=$(( input * 60 ))
        return 0
    fi
    # Duration string: Xh, Ym, XhYm (case-insensitive)
    local lower
    lower="$(printf '%s' "$input" | tr 'HM' 'hm')"
    local hours=0 mins=0
    if printf '%s' "$lower" | grep -Eq '^[0-9]+h[0-9]+m$'; then
        hours="$(printf '%s' "$lower" | grep -o '^[0-9]*')"
        mins="$(printf '%s' "$lower" | grep -o '[0-9]*m$' | tr -d 'm')"
    elif printf '%s' "$lower" | grep -Eq '^[0-9]+h$'; then
        hours="$(printf '%s' "$lower" | tr -d 'h')"
    elif printf '%s' "$lower" | grep -Eq '^[0-9]+m$'; then
        mins="$(printf '%s' "$lower" | tr -d 'm')"
    else
        clk__die 1 "Invalid duration '$input'. Expected: minutes (e.g. 90), Xh, Ym, or XhYm (e.g. 1h30m)."
    fi
    CLK_PARSED_DURATION_SECS=$(( hours * 3600 + mins * 60 ))
}

# --- File I/O helpers ---

# clk__save_undo()
# Snapshots the current log for single-level undo. Clears redo state.
#
# --- RATIONALE: Single-level undo ---
# Multi-level undo would require a snapshot stack (disk) or reversible op log
# (complexity). Single-level covers the common "oops" case. clk edit handles
# surgical fixes to older records.
clk__save_undo() {
    cp "$CLK_LOG" "${CLK_LOG}.undo" || clk__die 2 "Failed to save undo snapshot."
    \rm -f "${CLK_LOG}.redo"
}

# clk__append_line(content)
# Appends a record line to the end of the log.
clk__append_line() {
    local content="$1"
    printf '%s\n' "$content" >> "$CLK_LOG" || clk__die 2 "Failed to append to log."
}

# clk__replace_line(line_number, new_content)
# Replaces a specific line in the log (1-indexed).
clk__replace_line() {
    local lineno="$1" new_content="$2"
    awk -v n="$lineno" -v rep="$new_content" 'NR==n{print rep;next}{print}' \
        "$CLK_LOG" > "$CLK_LOG_TMP" || clk__die 2 "Failed to replace line $lineno."
    mv "$CLK_LOG_TMP" "$CLK_LOG" || clk__die 2 "Failed to update log file."
}

# clk__delete_line(line_number)
# Deletes a specific line from the log (1-indexed).
clk__delete_line() {
    local lineno="$1"
    awk -v n="$lineno" 'NR!=n' \
        "$CLK_LOG" > "$CLK_LOG_TMP" || clk__die 2 "Failed to delete line $lineno."
    mv "$CLK_LOG_TMP" "$CLK_LOG" || clk__die 2 "Failed to update log file."
}

# clk__insert_before_active(content)
# Inserts a completed record just above the first active line
# (or appends if no active lines exist). Maintains sort order.
#
# --- RATIONALE: Active records at end of file ---
# Completed records are sorted by end-time for efficient range queries in
# 'view'. Keeping active records below all completed records preserves this
# sort order. When a session completes, its done-line is inserted just above
# the first remaining active line.
clk__insert_before_active() {
    local content="$1"
    local first_active_lineno
    first_active_lineno="$(clk__find_active | head -1)" || true
    if [ -n "$first_active_lineno" ]; then
        # Insert before the first active line
        awk -v n="$first_active_lineno" -v ins="$content" \
            'NR==n{print ins}{print}' \
            "$CLK_LOG" > "$CLK_LOG_TMP" || clk__die 2 "Failed to insert before active line."
        mv "$CLK_LOG_TMP" "$CLK_LOG" || clk__die 2 "Failed to update log file."
    else
        # No active lines; just append
        clk__append_line "$content"
    fi
}

# clk__tag_matches(tag, filter) → 0 if tag matches filter, 1 otherwise
# filter can be a single tag or comma-separated list (e.g., "dev,pm,admin").
clk__tag_matches() {
    local tag="$1" filter="$2"
    # Fast path: no comma means single-tag comparison
    if ! printf '%s' "$filter" | grep -qF ','; then
        [ "$tag" = "$filter" ]
        return $?
    fi
    # Multi-tag: check if tag is in the comma-separated list
    printf '%s' "$filter" | tr ',' '\n' | grep -qxF "$tag"
}

# clk__find_active([tag]) → line_number(s)
# With no args: finds all active lines, prints line numbers (one per line).
# With tag arg: finds the active line for that specific tag.
# Prints line numbers to stdout. Returns 0 if found, 1 if not found.
#
# Implementation: awk scan for lines where field 1 == "active".
# Since active records cluster at the end, this is fast even for large logs.
clk__find_active() {
    local tag="${1:-}"
    local result
    if [ -n "$tag" ]; then
        result="$(awk -F'\t' -v t="$tag" '$1=="active" && $4==t {print NR}' "$CLK_LOG")"
    else
        result="$(awk -F'\t' '$1=="active" {print NR}' "$CLK_LOG")"
    fi
    if [ -z "$result" ]; then
        return 1
    fi
    printf '%s\n' "$result"
    return 0
}

# clk__require_active_tag(tag) → sets CLK_ACTIVE_LINE and CLK_ACTIVE_TAG
# If tag is provided and has an active session, set globals and return.
# If tag is empty and exactly one active session, infer tag and set globals.
# If tag is empty and zero active sessions, error + exit 5.
# If tag is empty and multiple active sessions, error listing them + exit 1.
#
# --- RATIONALE: Tag resolution (implicit when unambiguous) ---
# Commands like out/pause/resume accept an optional tag. When exactly one
# session is active, the tag is inferred. When multiple are active, the user
# must specify. This means single-session users see zero UX change from v1.
CLK_ACTIVE_LINE=""
CLK_ACTIVE_TAG=""

clk__require_active_tag() {
    local tag="${1:-}"
    CLK_ACTIVE_LINE=""
    CLK_ACTIVE_TAG=""

    if [ -n "$tag" ]; then
        # Tag provided: find its active session
        local lineno
        lineno="$(clk__find_active "$tag")" || \
            clk__die 5 "No active session for tag '$tag'."
        CLK_ACTIVE_LINE="$lineno"
        CLK_ACTIVE_TAG="$tag"
        return 0
    fi

    # No tag: check how many active sessions exist
    local lines
    lines="$(clk__find_active)" || \
        clk__die 5 "No active sessions. Clock in first with 'clk in <tag>'."

    local count
    count="$(printf '%s\n' "$lines" | wc -l | tr -d ' ')"

    if [ "$count" -eq 1 ]; then
        CLK_ACTIVE_LINE="$lines"
        # Read the line to get the tag
        local line_content
        line_content="$(awk -v n="$lines" 'NR==n' "$CLK_LOG")"
        clk__read_line "$line_content"
        CLK_ACTIVE_TAG="$CLK_F4"
        return 0
    fi

    # Multiple active sessions — list them and error
    local msg="Multiple active sessions. Specify a tag:"
    local lineno
    while IFS= read -r lineno; do
        local line_content
        line_content="$(awk -v n="$lineno" 'NR==n' "$CLK_LOG")"
        clk__read_line "$line_content"
        msg="${msg}
  ${CLK_F4}  (started at $(clk__fmt_ts_display "$CLK_F2"))"
    done <<< "$lines"
    clk__die 1 "$msg"
}

# clk__get_line(line_number) → line content
# Reads a specific line from the log by line number.
clk__get_line() {
    local lineno="$1"
    awk -v n="$lineno" 'NR==n' "$CLK_LOG"
}

# clk__record_count() → number of data lines (excluding comments)
# Returns the count of non-comment, non-empty lines in the log.
clk__record_count() {
    awk -F'\t' '/^[^#]/ && NF>0' "$CLK_LOG" | wc -l | tr -d ' '
}

# --- Log management ---

# clk__ensure_log()
# Creates log dir/file if missing. Runs migration if needed (not yet implemented).
# Strips trailing blank lines. Sets CLK_DIR, CLK_LOG, CLK_LOG_TMP, CLK_TMP_ERR.
clk__ensure_log() {
    CLK_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/clk"
    CLK_LOG="${CLK_DIR}/clk.tsv"
    CLK_LOG_TMP="${CLK_LOG}.tmp"
    CLK_TMP_ERR="${CLK_DIR}/.clk_stderr"

    if [ ! -d "$CLK_DIR" ]; then
        mkdir -p "$CLK_DIR" || clk__die 2 "Failed to create directory '$CLK_DIR'."
    fi

    if [ ! -f "$CLK_LOG" ]; then
        printf '%s\n' "$CLK_LOG_VERSION_MARKER" > "$CLK_LOG" || clk__die 2 "Failed to create log file '$CLK_LOG'."
    fi

    # Initialize temp error file
    : > "$CLK_TMP_ERR" || clk__die 2 "Failed to create temp error file '$CLK_TMP_ERR'."

    # Migration (step 9) was performed manually. Auto-migration is not
    # implemented — the only user has already migrated their data.

    # Strip trailing blank lines
    if [ -s "$CLK_LOG" ]; then
        local last_line
        while
            last_line="$(tail -1 "$CLK_LOG")" &&
            { [ -z "$last_line" ] || printf '%s' "$last_line" | grep -Eq '^[[:space:]]*$'; }
        do
            local line_count
            line_count=$(wc -l < "$CLK_LOG")
            if [ "$line_count" -le 1 ]; then
                # Only the version marker remains (or file is nearly empty)
                break
            fi
            sed -e '$d' "$CLK_LOG" > "$CLK_LOG_TMP" || clk__die 2 "Failed to strip trailing blank line."
            mv "$CLK_LOG_TMP" "$CLK_LOG" || clk__die 2 "Failed to update log file."
        done
    fi
}

#####################################################################
# Upgrade check
#####################################################################

# Returns 0 (true) if $1 > $2 in semver (X.Y.Z).
clk__version_gt() {
    local a1 a2 a3 b1 b2 b3 old_ifs
    old_ifs="$IFS"
    IFS='.'; set -- $1 $2; IFS="$old_ifs"
    a1=$1 a2=$2 a3=$3 b1=$4 b2=$5 b3=$6
    [ "$a1" -gt "$b1" ] 2>/dev/null && return 0
    [ "$a1" -lt "$b1" ] 2>/dev/null && return 1
    [ "$a2" -gt "$b2" ] 2>/dev/null && return 0
    [ "$a2" -lt "$b2" ] 2>/dev/null && return 1
    [ "$a3" -gt "$b3" ] 2>/dev/null && return 0
    return 1
}

# Background: fetch latest clk tag from GitHub and write to cache.
clk__upgrade_bg_fetch() {
    local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/clk"
    local cache_file="$cache_dir/latest-version"
    local latest
    mkdir -p "$cache_dir" 2>/dev/null || return 1
    latest=$(git ls-remote --tags https://github.com/poiurewq/scripts.git 'refs/tags/clk-v*' 2>/dev/null \
        | sed -n 's|.*refs/tags/clk-v\([^{]*\)$|\1|p' \
        | sort -t. -k1,1n -k2,2n -k3,3n \
        | tail -1)
    [ -n "$latest" ] && printf '%s\n' "$latest" > "$cache_file"
}

# Check cache for a newer version; print reminder if found.
# Spawn background fetch if cache is stale (>24h) or missing.
clk__upgrade_check() {
    [ -z "${CLK_NO_UPDATE_CHECK:-}" ] || return 0
    [ -t 2 ] || return 0

    local cache_dir="${XDG_CACHE_HOME:-$HOME/.cache}/clk"
    local cache_file="$cache_dir/latest-version"
    local latest mtime now age

    # Read cached version and show reminder if newer
    if [ -f "$cache_file" ]; then
        latest=$(head -1 "$cache_file" 2>/dev/null) || latest=""
        if [ -n "$latest" ] && clk__version_gt "$latest" "$CLK_VERSION"; then
            printf '\nA newer release of clk is available: %s \xe2\x86\x92 %s\n' "$CLK_VERSION" "$latest" >&2
            printf 'To upgrade: brew upgrade poiurewq/tap/clk\n\n' >&2
        fi
    fi

    # Spawn background fetch if cache is stale or missing
    local stale=0
    if [ ! -f "$cache_file" ]; then
        stale=1
    else
        now=$(date +%s)
        case "$CLK_OS" in
            Darwin) mtime=$(stat -f %m "$cache_file" 2>/dev/null) ;;
            Linux)  mtime=$(stat -c %Y "$cache_file" 2>/dev/null) ;;
        esac
        mtime=${mtime:-0}
        age=$(( now - mtime ))
        [ "$age" -ge 86400 ] && stale=1
    fi

    if [ "$stale" = 1 ]; then
        ( clk__upgrade_bg_fetch ) &>/dev/null &
        disown 2>/dev/null
    fi
}

#####################################################################
# Subcommand functions
#####################################################################

# --- clk_do_in ---
# clk in <tag> [minus <duration> | at <timestamp>] [on <description>]
#
# --- RATIONALE: Description at clock-in ---
# Users often know what they're about to work on when they clock in, but may
# forget to annotate at clock-out. Allowing `on` at clock-in captures intent
# early. The clock-out description wins if provided.
clk_do_in() {
    local tag="$1" at_ts="$2" minus_val="$3" description="$4"

    clk__validate_tag "$tag"

    # Validate that no active session for this tag already exists
    if clk__find_active "$tag" >/dev/null 2>&1; then
        clk__die 5 "Tag '$tag' already has an active session. Clock out first with 'clk out $tag'."
    fi

    local start_ts
    start_ts="$(clk__resolve_time "$at_ts" "$minus_val")"

    clk__save_undo

    # active \t START \t (empty) \t TAG \t (empty) \t 0 \t (empty) \t DESCRIPTION
    local record="active${CLK_TAB}${start_ts}${CLK_TAB}${CLK_TAB}${tag}${CLK_TAB}${CLK_TAB}0${CLK_TAB}${CLK_TAB}${description}"
    clk__append_line "$record"

    printf '\nStarted session in\n  %s\n  at %s\n' "$tag" "$(clk__fmt_ts_display "$start_ts")"
    if [ -n "$description" ]; then
        printf '  on %s\n' "$description"
    fi
    printf '\n'
}

# --- clk_do_out ---
# clk out [<tag>] [minus <duration> | at <timestamp>] [on <description>]
#
# --- RATIONALE: Description override at clock-out ---
# Users often set a description at clock-in for intent, then refine it at
# clock-out to reflect what actually happened. Clock-out description wins.
clk_do_out() {
    local tag="$1" at_ts="$2" minus_val="$3" description="$4"
    # skip_undo: when called from switch, undo is already saved
    local skip_undo="${5:-}"

    clk__require_active_tag "$tag"
    local active_line="$CLK_ACTIVE_LINE"
    local active_tag="$CLK_ACTIVE_TAG"

    local end_ts
    end_ts="$(clk__resolve_time "$at_ts" "$minus_val")"

    # Read the active record
    local line_content
    line_content="$(clk__get_line "$active_line")"
    clk__read_line "$line_content"

    local start_ts="$CLK_F2"
    local break_secs="${CLK_F6:-0}"
    local paused_at="$CLK_F7"
    local existing_desc="$CLK_F8"

    # If session is currently paused, end at the pause timestamp.
    # Time elapsed since the pause is discarded — the session effectively
    # ended when the user paused, so the pause timestamp becomes end_ts.
    local end_epoch
    end_epoch="$(clk__to_epoch "$end_ts")"
    if [ -n "$paused_at" ]; then
        end_epoch="$paused_at"
        end_ts="$(clk__from_epoch "$paused_at")"
    fi

    # Calculate length
    local start_epoch
    start_epoch="$(clk__to_epoch "$start_ts")"
    local length_secs=$(( end_epoch - start_epoch - break_secs ))

    if [ "$length_secs" -lt 0 ]; then
        local total_dur
        total_dur="$(clk__fmt_duration $(( end_epoch - start_epoch )))"
        local break_dur
        break_dur="$(clk__fmt_duration "$break_secs")"
        clk__die 1 "Active time would be negative. Session span is ${total_dur} but break time is ${break_dur}."
    fi

    # Resolve description: clock-out overrides clock-in
    local final_desc="$description"
    if [ -z "$final_desc" ]; then
        final_desc="$existing_desc"
    fi

    if [ "$skip_undo" != "skip_undo" ]; then
        clk__save_undo
    fi

    # Delete the active line
    clk__delete_line "$active_line"

    # Build completed record
    local done_record="done${CLK_TAB}${start_ts}${CLK_TAB}${end_ts}${CLK_TAB}${active_tag}${CLK_TAB}${length_secs}${CLK_TAB}${break_secs}${CLK_TAB}${CLK_TAB}${final_desc}"

    # Insert before remaining active lines (maintains sort order)
    clk__insert_before_active "$done_record"

    # Print confirmation
    local dur_str
    dur_str="$(clk__fmt_duration "$length_secs")"
    printf '\nRecorded session in\n  %s\n  %s → %s  (%s)\n' "$active_tag" "$(clk__fmt_ts_display "$start_ts")" "$(clk__fmt_ts_display "$end_ts")" "$dur_str"
    if [ "$break_secs" -gt 0 ]; then
        local break_str
        break_str="$(clk__fmt_duration "$break_secs")"
        printf '  break: %s\n' "$break_str"
    fi
    if [ -n "$final_desc" ]; then
        printf '  on %s\n' "$final_desc"
    fi
    printf '\n'
}

# --- clk_do_status ---
# clk status | s
clk_do_status() {
    local lines
    lines="$(clk__find_active)" || {
        printf 'No active sessions.\n'
        return 0
    }

    # Pad tags to a minimum width so "started" stays column-aligned across rows
    CLK_FMT_ACTIVE_TAG_WIDTH=7
    local lineno idx=1
    while IFS= read -r lineno; do
        local line_content
        line_content="$(clk__get_line "$lineno")"
        local formatted
        formatted="$(clk__fmt_record "$line_content")"
        # Show the positive index (+N) so users can target a session by
        # index with `clk <n>`, `clk edit <n> ...`, or `clk pop <n>`.
        # Active lines come out of clk__find_active in log order (oldest
        # first), which matches the +1..+N convention.
        printf '  +%d  %s\n' "$idx" "$formatted"
        idx=$(( idx + 1 ))
    done <<< "$lines"

    CLK_FMT_ACTIVE_TAG_WIDTH=0
}

# --- RATIONALE: signed index convention ---
# Negative integers count back from the most recent done session; positive
# integers count forward from the oldest active session. The sign tells you
# which pool you are indexing into: negative = done, positive = active.
# edit mirrors this exact convention so last, edit, and the bare-number
# shortcuts (`clk -n`, `clk n`) stay aligned.

# --- clk__show_done_at(abs_n) ---
# Print the abs_n-th most recent completed session (i.e., index -abs_n).
# abs_n is a positive integer. Prints "No completed records" and returns 0
# when the log has none. Exits 1 if abs_n exceeds the count.
clk__show_done_at() {
    local abs_n="$1"
    local done_lines
    done_lines="$(awk -F'\t' '$1=="done" {print NR}' "$CLK_LOG")"

    if [ -z "$done_lines" ]; then
        printf 'No completed records in log.\n'
        return 0
    fi

    local total_done
    total_done="$(printf '%s\n' "$done_lines" | wc -l | tr -d ' ')"

    if [ "$abs_n" -gt "$total_done" ]; then
        clk__die 1 "Index -${abs_n} out of range. Only ${total_done} completed record(s) in log."
    fi

    # tail -n abs_n gives the last abs_n lines; head -n 1 picks the oldest of those
    local lineno
    lineno="$(printf '%s\n' "$done_lines" | tail -n "${abs_n}" | head -n 1)"

    local line_content
    line_content="$(clk__get_line "$lineno")"
    local formatted
    formatted="$(clk__fmt_record "$line_content")"

    local this_tag="${formatted%%  *}"
    local this_rest="${formatted#*  }"
    printf -- "-%d  %s  %s\n" "$abs_n" "$this_tag" "$this_rest"
}

# --- clk__show_active_at(abs_n) ---
# Print the abs_n-th oldest active session (i.e., index +abs_n).
# abs_n is a positive integer. Prints "No active sessions" and returns 0
# when none exist. Exits 1 if abs_n exceeds the count.
clk__show_active_at() {
    local abs_n="$1"
    local active_lines
    active_lines="$(awk -F'\t' '$1=="active" {print NR}' "$CLK_LOG")"

    if [ -z "$active_lines" ]; then
        printf 'No active sessions.\n'
        return 0
    fi

    local total_active
    total_active="$(printf '%s\n' "$active_lines" | wc -l | tr -d ' ')"

    if [ "$abs_n" -gt "$total_active" ]; then
        clk__die 1 "Index ${abs_n} out of range. Only ${total_active} active session(s)."
    fi

    # head -n abs_n gives the first abs_n lines; tail -n 1 picks the newest of those
    local lineno
    lineno="$(printf '%s\n' "$active_lines" | head -n "${abs_n}" | tail -n 1)"

    local line_content
    line_content="$(clk__get_line "$lineno")"
    local formatted
    formatted="$(clk__fmt_record "$line_content")"

    local this_tag="${formatted%%  *}"
    local this_rest="${formatted#*  }"
    printf "+%d  %s  %s\n" "$abs_n" "$this_tag" "$this_rest"
}

# --- clk_do_last(n) ---
# clk last [<n>]
#
# Show all completed sessions from -n up to -1, one per line. n must be a
# positive integer (default 1). If n exceeds the number of done records,
# only the available ones are shown (no error).
clk_do_last() {
    local n="${1:-1}"

    local done_lines
    done_lines="$(awk -F'\t' '$1=="done" {print NR}' "$CLK_LOG")"

    if [ -z "$done_lines" ]; then
        printf 'No completed records in log.\n'
        return 0
    fi

    local total_done
    total_done="$(printf '%s\n' "$done_lines" | wc -l | tr -d ' ')"

    # Cap n at the number of done records — asking for more than exists
    # is a reasonable request ("show me the last 100") and should not error.
    if [ "$n" -gt "$total_done" ]; then
        n="$total_done"
    fi

    # Pad tags to a 7-char floor so the start/end times stay column-aligned
    # across rows (mirrors the pattern used by clk_do_status).
    CLK_FMT_DONE_TAG_WIDTH=7

    local i="$n"
    while [ "$i" -ge 1 ]; do
        clk__show_done_at "$i"
        i=$(( i - 1 ))
    done

    CLK_FMT_DONE_TAG_WIDTH=0
}

# --- clk_do_pause ---
# clk pause [<tag>] [minus <duration> | at <timestamp>]
clk_do_pause() {
    local tag="$1" minus_val="$2" at_ts="$3"

    if [ -n "$tag" ]; then
        # Tag explicitly provided — use the standard resolver
        clk__require_active_tag "$tag"
    else
        # No tag: filter to only non-paused active sessions
        local all_lines
        all_lines="$(clk__find_active)" || \
            clk__die 5 "No active sessions. Clock in first with 'clk in <tag>'."

        local unpaused_lines=""
        local lineno line_content
        while IFS= read -r lineno; do
            line_content="$(clk__get_line "$lineno")"
            clk__read_line "$line_content"
            if [ -z "$CLK_F7" ]; then
                if [ -n "$unpaused_lines" ]; then
                    unpaused_lines="${unpaused_lines}
${lineno}"
                else
                    unpaused_lines="$lineno"
                fi
            fi
        done <<< "$all_lines"

        if [ -z "$unpaused_lines" ]; then
            clk__die 5 "All active sessions are already paused. Use 'clk resume' first."
        fi

        local unpaused_count
        unpaused_count="$(printf '%s\n' "$unpaused_lines" | wc -l | tr -d ' ')"

        if [ "$unpaused_count" -eq 1 ]; then
            CLK_ACTIVE_LINE="$unpaused_lines"
            line_content="$(clk__get_line "$unpaused_lines")"
            clk__read_line "$line_content"
            CLK_ACTIVE_TAG="$CLK_F4"
        else
            # Multiple non-paused sessions — list only those
            local msg="Multiple active (non-paused) sessions. Specify a tag:"
            while IFS= read -r lineno; do
                line_content="$(clk__get_line "$lineno")"
                clk__read_line "$line_content"
                msg="${msg}
  ${CLK_F4}  (started at $(clk__fmt_ts_display "$CLK_F2"))"
            done <<< "$unpaused_lines"
            clk__die 1 "$msg"
        fi
    fi

    local active_line="$CLK_ACTIVE_LINE"
    local active_tag="$CLK_ACTIVE_TAG"

    # Read the active record
    local line_content
    line_content="$(clk__get_line "$active_line")"
    clk__read_line "$line_content"

    local start_ts="$CLK_F2"
    local break_secs="${CLK_F6:-0}"
    local paused_at="$CLK_F7"
    local description="$CLK_F8"

    # Guard: must not already be paused
    if [ -n "$paused_at" ]; then
        local paused_ts
        paused_ts="$(clk__from_epoch "$paused_at" 2>/dev/null)" || paused_ts="$paused_at"
        clk__die 5 "Session '$active_tag' is already paused (since $(clk__fmt_ts_display "$paused_ts")). Use 'clk resume' first."
    fi

    # Calculate pause epoch
    local pause_epoch
    if [ -n "$at_ts" ]; then
        pause_epoch="$(clk__to_epoch "$at_ts")"
    elif [ -n "$minus_val" ]; then
        local now_epoch
        now_epoch="$(clk__now_epoch)"
        pause_epoch=$(( now_epoch - minus_val ))
    else
        pause_epoch="$(clk__now_epoch)"
    fi

    clk__save_undo

    # Replace record with PAUSED_AT set
    local new_record="active${CLK_TAB}${start_ts}${CLK_TAB}${CLK_TAB}${active_tag}${CLK_TAB}${CLK_TAB}${break_secs}${CLK_TAB}${pause_epoch}${CLK_TAB}${description}"
    clk__replace_line "$active_line" "$new_record"

    local pause_ts
    pause_ts="$(clk__from_epoch "$pause_epoch")"

    # Calculate active work so far
    local start_epoch elapsed_secs
    start_epoch="$(clk__to_epoch "$start_ts")"
    elapsed_secs=$(( pause_epoch - start_epoch - break_secs ))
    if [ "$elapsed_secs" -lt 0 ]; then elapsed_secs=0; fi
    local elapsed_str
    elapsed_str="$(clk__fmt_duration "$elapsed_secs")"

    printf '\nSession in\n  %s\n  paused at %s\n  Active work so far: %s\n\n' \
        "$active_tag" "$(clk__fmt_ts_display "$pause_ts")" "$elapsed_str"
}

# --- clk_do_resume ---
# clk resume [<tag>] [minus <duration>]
clk_do_resume() {
    local tag="$1" minus_val="$2" at_ts="$3"

    clk__require_active_tag "$tag"
    local active_line="$CLK_ACTIVE_LINE"
    local active_tag="$CLK_ACTIVE_TAG"

    # Read the active record
    local line_content
    line_content="$(clk__get_line "$active_line")"
    clk__read_line "$line_content"

    local start_ts="$CLK_F2"
    local break_secs="${CLK_F6:-0}"
    local paused_at="$CLK_F7"
    local description="$CLK_F8"

    # Guard: must be currently paused
    if [ -z "$paused_at" ]; then
        clk__die 5 "Session '$active_tag' is not paused. Use 'clk pause' first."
    fi

    # Calculate resume epoch
    local resume_epoch
    if [ -n "$at_ts" ]; then
        resume_epoch="$(clk__to_epoch "$at_ts")"
    elif [ -n "$minus_val" ]; then
        local now_epoch
        now_epoch="$(clk__now_epoch)"
        resume_epoch=$(( now_epoch - minus_val ))
    else
        resume_epoch="$(clk__now_epoch)"
    fi

    # Calculate this pause duration and new total break
    local this_pause_secs=$(( resume_epoch - paused_at ))
    if [ "$this_pause_secs" -lt 0 ]; then
        local resume_ts paused_ts
        resume_ts="$(clk__from_epoch "$resume_epoch")"
        paused_ts="$(clk__from_epoch "$paused_at")"
        clk__die 1 "Resume time $(clk__fmt_ts_display "$resume_ts") cannot be earlier than pause time $(clk__fmt_ts_display "$paused_ts")."
    fi
    local new_break_secs=$(( break_secs + this_pause_secs ))

    clk__save_undo

    # Replace record: update BREAK_SECS and clear PAUSED_AT
    local new_record="active${CLK_TAB}${start_ts}${CLK_TAB}${CLK_TAB}${active_tag}${CLK_TAB}${CLK_TAB}${new_break_secs}${CLK_TAB}${CLK_TAB}${description}"
    clk__replace_line "$active_line" "$new_record"

    local resume_ts
    resume_ts="$(clk__from_epoch "$resume_epoch")"
    local this_pause_str total_break_str
    this_pause_str="$(clk__fmt_duration "$this_pause_secs")"
    total_break_str="$(clk__fmt_duration "$new_break_secs")"

    # Calculate active work so far
    local start_epoch elapsed_secs
    start_epoch="$(clk__to_epoch "$start_ts")"
    elapsed_secs=$(( resume_epoch - start_epoch - new_break_secs ))
    if [ "$elapsed_secs" -lt 0 ]; then elapsed_secs=0; fi
    local elapsed_str
    elapsed_str="$(clk__fmt_duration "$elapsed_secs")"

    printf '\nSession in\n  %s\n  resumed at %s\n  This pause: %s\n  Total break so far: %s\n  Active work so far: %s\n\n' \
        "$active_tag" "$(clk__fmt_ts_display "$resume_ts")" "$this_pause_str" "$total_break_str" "$elapsed_str"
}

# --- clk_do_unpause ---
# clk unpause [<tag>]
#
# Clears PAUSED_AT without adding any time to BREAK_SECS.
# For the "I paused by mistake" case.
clk_do_unpause() {
    local tag="$1"

    clk__require_active_tag "$tag"
    local active_line="$CLK_ACTIVE_LINE"
    local active_tag="$CLK_ACTIVE_TAG"

    # Read the active record
    local line_content
    line_content="$(clk__get_line "$active_line")"
    clk__read_line "$line_content"

    local start_ts="$CLK_F2"
    local break_secs="${CLK_F6:-0}"
    local paused_at="$CLK_F7"
    local description="$CLK_F8"

    # Guard: must be currently paused
    if [ -z "$paused_at" ]; then
        clk__die 5 "Session '$active_tag' is not paused. Nothing to unpause."
    fi

    clk__save_undo

    # Replace record: clear PAUSED_AT, keep BREAK_SECS unchanged
    local new_record="active${CLK_TAB}${start_ts}${CLK_TAB}${CLK_TAB}${active_tag}${CLK_TAB}${CLK_TAB}${break_secs}${CLK_TAB}${CLK_TAB}${description}"
    clk__replace_line "$active_line" "$new_record"

    local paused_ts
    paused_ts="$(clk__from_epoch "$paused_at")"
    printf '\nPause cancelled for session in\n  %s\n  (was paused since %s)\n  No break time was added.\n\n' "$active_tag" "$(clk__fmt_ts_display "$paused_ts")"
}

# --- clk_do_resume_focus ---
# clk resume-focus <tag> [minus <duration> | at <timestamp>]
#
# Resume the specified tag and pause all other active (non-paused) sessions.
# A single undo snapshot covers the entire compound operation.
clk_do_resume_focus() {
    local tag="$1" minus_val="$2" at_ts="$3"

    # Tag is required
    if [ -z "$tag" ]; then
        clk__die 1 "Missing <tag>. Usage: 'clk resume-focus <tag>'."
    fi

    clk__require_active_tag "$tag"
    local focus_line="$CLK_ACTIVE_LINE"

    # Read the focus record
    local line_content
    line_content="$(clk__get_line "$focus_line")"
    clk__read_line "$line_content"

    local focus_start_ts="$CLK_F2"
    local focus_break_secs="${CLK_F6:-0}"
    local focus_paused_at="$CLK_F7"
    local focus_description="$CLK_F8"

    # Calculate the action epoch (used for both resume and pause timestamps)
    local action_epoch
    if [ -n "$at_ts" ]; then
        action_epoch="$(clk__to_epoch "$at_ts")"
    elif [ -n "$minus_val" ]; then
        local now_epoch
        now_epoch="$(clk__now_epoch)"
        action_epoch=$(( now_epoch - minus_val ))
    else
        action_epoch="$(clk__now_epoch)"
    fi

    # Find all other active sessions that are not paused
    local all_lines
    all_lines="$(clk__find_active)" || \
        clk__die 5 "No active sessions."

    local others_to_pause=""
    local lineno other_content
    while IFS= read -r lineno; do
        [ "$lineno" != "$focus_line" ] || continue
        other_content="$(clk__get_line "$lineno")"
        clk__read_line "$other_content"
        # Only pause sessions that are not already paused
        if [ -z "$CLK_F7" ]; then
            if [ -n "$others_to_pause" ]; then
                others_to_pause="${others_to_pause}
${lineno}"
            else
                others_to_pause="$lineno"
            fi
        fi
    done <<< "$all_lines"

    clk__save_undo

    # 1. Resume the focus session if it is paused
    local resumed=0
    local new_focus_break_secs="$focus_break_secs"
    if [ -n "$focus_paused_at" ]; then
        local this_pause_secs=$(( action_epoch - focus_paused_at ))
        if [ "$this_pause_secs" -lt 0 ]; then
            local resume_ts paused_ts
            resume_ts="$(clk__from_epoch "$action_epoch")"
            paused_ts="$(clk__from_epoch "$focus_paused_at")"
            clk__die 1 "Resume time $(clk__fmt_ts_display "$resume_ts") cannot be earlier than pause time $(clk__fmt_ts_display "$paused_ts")."
        fi
        new_focus_break_secs=$(( focus_break_secs + this_pause_secs ))
        local new_record="active${CLK_TAB}${focus_start_ts}${CLK_TAB}${CLK_TAB}${tag}${CLK_TAB}${CLK_TAB}${new_focus_break_secs}${CLK_TAB}${CLK_TAB}${focus_description}"
        clk__replace_line "$focus_line" "$new_record"
        resumed=1
    fi

    # 2. Pause all other non-paused active sessions
    local paused_count=0
    local paused_tags=""
    if [ -n "$others_to_pause" ]; then
        while IFS= read -r lineno; do
            other_content="$(clk__get_line "$lineno")"
            clk__read_line "$other_content"
            local other_start_ts="$CLK_F2"
            local other_tag="$CLK_F4"
            local other_break_secs="${CLK_F6:-0}"
            local other_description="$CLK_F8"
            local new_record="active${CLK_TAB}${other_start_ts}${CLK_TAB}${CLK_TAB}${other_tag}${CLK_TAB}${CLK_TAB}${other_break_secs}${CLK_TAB}${action_epoch}${CLK_TAB}${other_description}"
            clk__replace_line "$lineno" "$new_record"
            paused_count=$(( paused_count + 1 ))
            if [ -n "$paused_tags" ]; then
                paused_tags="${paused_tags}, ${other_tag}"
            else
                paused_tags="$other_tag"
            fi
        done <<< "$others_to_pause"
    fi

    # Display results
    local action_ts
    action_ts="$(clk__from_epoch "$action_epoch")"

    local start_epoch elapsed_secs elapsed_str
    start_epoch="$(clk__to_epoch "$focus_start_ts")"
    elapsed_secs=$(( action_epoch - start_epoch - new_focus_break_secs ))
    if [ "$elapsed_secs" -lt 0 ]; then elapsed_secs=0; fi
    elapsed_str="$(clk__fmt_duration "$elapsed_secs")"

    printf '\nFocused on\n  %s\n' "$tag"
    if [ "$resumed" -eq 1 ]; then
        printf '  resumed at %s\n' "$(clk__fmt_ts_display "$action_ts")"
    else
        printf '  (was not paused)\n'
    fi
    printf '  Active work so far: %s\n' "$elapsed_str"
    if [ "$paused_count" -gt 0 ]; then
        printf '  Paused %d other session(s): %s\n' "$paused_count" "$paused_tags"
    fi
    printf '\n'
}

# --- clk_do_in_focus ---
# clk in-focus <tag> [minus <duration> | at <timestamp>] [on <description>]
#
# Start a new session while pausing all other active (non-paused) sessions
# at the same timestamp. Lets users juggle multiple tags without losing
# focus: after this command, only the new session is running.
# A single undo snapshot covers the entire compound operation.
clk_do_in_focus() {
    local tag="$1" at_ts="$2" minus_val="$3" description="$4"

    clk__validate_tag "$tag"

    # Validate that no active session for this tag already exists
    if clk__find_active "$tag" >/dev/null 2>&1; then
        clk__die 5 "Tag '$tag' already has an active session. Clock out first with 'clk out $tag'."
    fi

    local start_ts
    start_ts="$(clk__resolve_time "$at_ts" "$minus_val")"
    local start_epoch
    start_epoch="$(clk__to_epoch "$start_ts")"

    # Collect all existing active sessions that are not already paused
    local others_to_pause=""
    local all_lines
    if all_lines="$(clk__find_active 2>/dev/null)"; then
        local lineno other_content
        while IFS= read -r lineno; do
            other_content="$(clk__get_line "$lineno")"
            clk__read_line "$other_content"
            if [ -z "$CLK_F7" ]; then
                if [ -n "$others_to_pause" ]; then
                    others_to_pause="${others_to_pause}
${lineno}"
                else
                    others_to_pause="$lineno"
                fi
            fi
        done <<< "$all_lines"
    fi

    clk__save_undo

    # 1. Pause each non-paused active session at start_epoch
    local paused_count=0
    local paused_tags=""
    if [ -n "$others_to_pause" ]; then
        local lineno other_content
        while IFS= read -r lineno; do
            other_content="$(clk__get_line "$lineno")"
            clk__read_line "$other_content"
            local other_start_ts="$CLK_F2"
            local other_tag="$CLK_F4"
            local other_break_secs="${CLK_F6:-0}"
            local other_description="$CLK_F8"
            local new_record="active${CLK_TAB}${other_start_ts}${CLK_TAB}${CLK_TAB}${other_tag}${CLK_TAB}${CLK_TAB}${other_break_secs}${CLK_TAB}${start_epoch}${CLK_TAB}${other_description}"
            clk__replace_line "$lineno" "$new_record"
            paused_count=$(( paused_count + 1 ))
            if [ -n "$paused_tags" ]; then
                paused_tags="${paused_tags}, ${other_tag}"
            else
                paused_tags="$other_tag"
            fi
        done <<< "$others_to_pause"
    fi

    # 2. Append the new active session
    local record="active${CLK_TAB}${start_ts}${CLK_TAB}${CLK_TAB}${tag}${CLK_TAB}${CLK_TAB}0${CLK_TAB}${CLK_TAB}${description}"
    clk__append_line "$record"

    printf '\nStarted focused session in\n  %s\n  at %s\n' "$tag" "$(clk__fmt_ts_display "$start_ts")"
    if [ -n "$description" ]; then
        printf '  on %s\n' "$description"
    fi
    if [ "$paused_count" -gt 0 ]; then
        printf '  Paused %d other session(s): %s\n' "$paused_count" "$paused_tags"
    fi
    printf '\n'
}

# --- clk_do_switch ---
# clk switch <new-tag> [from <old-tag>] [minus <duration> | at <timestamp>] [on <description>]
#
# --- RATIONALE: from keyword ---
# With multiple active sessions, the script cannot infer which session to
# close. `from <old-tag>` is explicit without changing the existing
# single-session syntax where `clk switch <tag>` just works.
clk_do_switch() {
    local new_tag="$1" from_tag="$2" at_ts="$3" minus_val="$4" description="$5"

    clk__validate_tag "$new_tag"

    # Resolve which session to close
    clk__require_active_tag "$from_tag"
    local old_tag="$CLK_ACTIVE_TAG"

    # Cannot switch to the same tag
    if [ "$new_tag" = "$old_tag" ]; then
        clk__die 1 "Cannot switch from '$old_tag' to the same tag."
    fi

    # Single undo snapshot for the combined operation
    clk__save_undo

    # Close old session (skip_undo since we already saved)
    clk_do_out "$old_tag" "$at_ts" "$minus_val" "$description" "skip_undo"

    # Start new session at the same timestamp (no description for the new session)
    clk_do_in "$new_tag" "$at_ts" "$minus_val" ""
}

# --- clk_do_add_session ---
# clk add <tag> for <duration> [minus <duration> | at <timestamp>] [on <description>]
# Creates a completed (done) record directly.
clk_do_add_session() {
    local tag="$1" for_secs="$2" at_ts="$3" minus_val="$4" description="$5"

    clk__validate_tag "$tag"

    local end_ts
    end_ts="$(clk__resolve_time "$at_ts" "$minus_val")"

    local end_epoch start_epoch length_secs start_ts
    end_epoch="$(clk__to_epoch "$end_ts")"
    length_secs="$for_secs"
    start_epoch=$(( end_epoch - length_secs ))
    start_ts="$(clk__from_epoch "$start_epoch")"

    clk__save_undo

    local done_record="done${CLK_TAB}${start_ts}${CLK_TAB}${end_ts}${CLK_TAB}${tag}${CLK_TAB}${length_secs}${CLK_TAB}0${CLK_TAB}${CLK_TAB}${description}"
    clk__insert_before_active "$done_record"

    local dur_str
    dur_str="$(clk__fmt_duration "$length_secs")"
    printf '\nAdded session in\n  %s\n  %s → %s  (%s)\n' "$tag" "$(clk__fmt_ts_display "$start_ts")" "$(clk__fmt_ts_display "$end_ts")" "$dur_str"
    if [ -n "$description" ]; then
        printf '  on %s\n' "$description"
    fi
    printf '\n'
}

# --- clk_do_add_time ---
# clk add <duration> [to <tag>]
# Adjusts the active session's START_TIME backwards by <duration>.
#
# --- RATIONALE: Adjusting start time ---
# "Add 15 minutes" means "I was actually working 15 minutes before I
# clocked in." Moving the start time backwards preserves the invariant
# LENGTH = (END - START) - BREAK without a separate "bonus time" field.
clk_do_add_time() {
    local add_secs="$1" tag="$2"

    clk__require_active_tag "$tag"
    local active_line="$CLK_ACTIVE_LINE"
    local active_tag="$CLK_ACTIVE_TAG"

    # Read the active record
    local line_content
    line_content="$(clk__get_line "$active_line")"
    clk__read_line "$line_content"

    local old_start_ts="$CLK_F2"
    local break_secs="${CLK_F6:-0}"
    local paused_at="$CLK_F7"
    local description="$CLK_F8"

    # Calculate new start time
    local old_start_epoch new_start_epoch new_start_ts
    old_start_epoch="$(clk__to_epoch "$old_start_ts")"
    new_start_epoch=$(( old_start_epoch - add_secs ))
    new_start_ts="$(clk__from_epoch "$new_start_epoch")"

    clk__save_undo

    local new_record="active${CLK_TAB}${new_start_ts}${CLK_TAB}${CLK_TAB}${active_tag}${CLK_TAB}${CLK_TAB}${break_secs}${CLK_TAB}${paused_at}${CLK_TAB}${description}"
    clk__replace_line "$active_line" "$new_record"

    local add_str
    add_str="$(clk__fmt_duration "$add_secs")"
    printf '\nAdded %s to session in\n  %s\n  %s → %s\n\n' \
        "$add_str" "$active_tag" "$(clk__fmt_ts_display "$old_start_ts")" "$(clk__fmt_ts_display "$new_start_ts")"
}

# --- clk_do_add_break ---
# clk add-break <duration> [to <tag>]
# clk ab <duration> [to <tag>]
#
# --- RATIONALE: add-break blocked while paused ---
# Adding manual break time while the session is paused would double-count:
# the pause duration AND the manual addition both become break. Requiring
# resume first keeps accounting unambiguous.
clk_do_add_break() {
    local add_secs="$1" tag="$2"

    clk__require_active_tag "$tag"
    local active_line="$CLK_ACTIVE_LINE"
    local active_tag="$CLK_ACTIVE_TAG"

    # Read the active record
    local line_content
    line_content="$(clk__get_line "$active_line")"
    clk__read_line "$line_content"

    local start_ts="$CLK_F2"
    local break_secs="${CLK_F6:-0}"
    local paused_at="$CLK_F7"
    local description="$CLK_F8"

    # Guard: must not be paused
    if [ -n "$paused_at" ]; then
        clk__die 5 "Session '$active_tag' is currently paused. Resume first with 'clk resume $active_tag'."
    fi

    local new_break_secs=$(( break_secs + add_secs ))

    clk__save_undo

    local new_record="active${CLK_TAB}${start_ts}${CLK_TAB}${CLK_TAB}${active_tag}${CLK_TAB}${CLK_TAB}${new_break_secs}${CLK_TAB}${CLK_TAB}${description}"
    clk__replace_line "$active_line" "$new_record"

    local add_str total_str
    add_str="$(clk__fmt_duration "$add_secs")"
    total_str="$(clk__fmt_duration "$new_break_secs")"
    printf '\nAdded %s break to session in\n  %s\n  Total break so far: %s\n\n' \
        "$add_str" "$active_tag" "$total_str"
}

# --- clk_do_extend ---
# clk extend [minus <duration> | at <timestamp> | by <duration>]
# Extends the last completed (done) record's end time.
clk_do_extend() {
    local tag="$1" at_ts="$2" minus_val="$3" by_val="$4"

    # Find the last done record (optionally filtered by tag)
    local last_done_lineno
    if [ -n "$tag" ]; then
        # Error if that tag has an active session
        if clk__find_active "$tag" >/dev/null 2>&1; then
            clk__die 1 "Session '$tag' is currently active. Clock out first before extending."
        fi
        last_done_lineno="$(awk -F'\t' -v t="$tag" '$1=="done" && $4==t {lineno=NR} END {print lineno}' "$CLK_LOG")"
        if [ -z "$last_done_lineno" ]; then
            clk__die 5 "No completed records for tag '$tag'."
        fi
    else
        last_done_lineno="$(awk -F'\t' '$1=="done" {lineno=NR} END {print lineno}' "$CLK_LOG")"
        if [ -z "$last_done_lineno" ]; then
            clk__die 5 "No completed records to extend."
        fi
    fi

    local line_content
    line_content="$(clk__get_line "$last_done_lineno")"
    clk__read_line "$line_content"

    local tag="$CLK_F4"
    local old_end_ts="$CLK_F3"
    local start_ts="$CLK_F2"
    local old_length_secs="$CLK_F5"
    local break_secs="${CLK_F6:-0}"
    local description="$CLK_F8"

    local old_end_epoch
    old_end_epoch="$(clk__to_epoch "$old_end_ts")"

    local new_end_ts new_end_epoch
    if [ -n "$by_val" ]; then
        new_end_epoch=$(( old_end_epoch + by_val ))
        new_end_ts="$(clk__from_epoch "$new_end_epoch")"
    else
        new_end_ts="$(clk__resolve_time "$at_ts" "$minus_val")"
        new_end_epoch="$(clk__to_epoch "$new_end_ts")"
        if [ "$new_end_epoch" -lt "$old_end_epoch" ]; then
            clk__die 1 "New end time $(clk__fmt_ts_display "$new_end_ts") is before old end time $(clk__fmt_ts_display "$old_end_ts"). Cannot shrink a session with extend."
        fi
    fi

    local extension_secs=$(( new_end_epoch - old_end_epoch ))
    local new_length_secs=$(( old_length_secs + extension_secs ))

    clk__save_undo

    local new_record="done${CLK_TAB}${start_ts}${CLK_TAB}${new_end_ts}${CLK_TAB}${tag}${CLK_TAB}${new_length_secs}${CLK_TAB}${break_secs}${CLK_TAB}${CLK_TAB}${description}"
    clk__replace_line "$last_done_lineno" "$new_record"

    local ext_str total_str
    ext_str="$(clk__fmt_duration "$extension_secs")"
    total_str="$(clk__fmt_duration "$new_length_secs")"
    printf '\nExtended session in\n  %s\n  by %s (new total: %s)\n  new end: %s\n\n' \
        "$tag" "$ext_str" "$total_str" "$(clk__fmt_ts_display "$new_end_ts")"
}

# --- clk_do_remove ---
# clk pop [-<n> | <n>]
# Without an index: removes the last record (whether active or completed).
# With -<n>: removes the nth-to-last done session.
# With <n>:  removes the nth-oldest active session (same convention as `clk <n>`).
clk_do_remove() {
    local signed_n="${1:-}"
    local lineno line_content formatted

    if [ -n "$signed_n" ]; then
        case "$signed_n" in
        -*)
            local abs_n="${signed_n#-}"
            local done_lines total_done
            done_lines="$(awk -F'\t' '$1=="done" {print NR}' "$CLK_LOG")"
            if [ -z "$done_lines" ]; then
                clk__die 5 "No completed records in log."
            fi
            total_done="$(printf '%s\n' "$done_lines" | wc -l | tr -d ' ')"
            if [ "$abs_n" -gt "$total_done" ]; then
                clk__die 1 "Index -${abs_n} out of range. Only ${total_done} completed record(s) in log."
            fi
            lineno="$(printf '%s\n' "$done_lines" | tail -n "${abs_n}" | head -n 1)"
            ;;
        *)
            local abs_n="$signed_n"
            local active_lines total_active
            active_lines="$(awk -F'\t' '$1=="active" {print NR}' "$CLK_LOG")"
            if [ -z "$active_lines" ]; then
                clk__die 5 "No active sessions."
            fi
            total_active="$(printf '%s\n' "$active_lines" | wc -l | tr -d ' ')"
            if [ "$abs_n" -gt "$total_active" ]; then
                clk__die 1 "Index ${abs_n} out of range. Only ${total_active} active session(s)."
            fi
            lineno="$(printf '%s\n' "$active_lines" | head -n "${abs_n}" | tail -n 1)"
            ;;
        esac
    else
        local total
        total="$(clk__record_count)"
        if [ "$total" -eq 0 ]; then
            clk__die 5 "No records to remove. Log is empty."
        fi
        lineno="$(awk '/^[^#]/ && NF>0 {lineno=NR} END {print lineno}' "$CLK_LOG")"
    fi

    line_content="$(clk__get_line "$lineno")"
    formatted="$(clk__fmt_record "$line_content")"

    clk__save_undo
    clk__delete_line "$lineno"

    printf '\nRemoved record:\n  %s\n\n' "$formatted"
}

# --- clk_do_reactivate ---
# clk reactivate | ra -<n>
# Converts a completed session back to active. START_TIME, TAG, BREAK_SECS,
# and DESCRIPTION are preserved; END_TIME, LENGTH_SECS, and PAUSED_AT are
# cleared. Uses the same negative-index convention as last and edit.
#
# --- RATIONALE: delete-then-append ---
# Active records must live at the end of the log (see clk__insert_before_active).
# The done record may be anywhere, so we delete it at its current line and
# append the new active record, preserving the sort invariant.
clk_do_reactivate() {
    local signed_n="$1"
    local abs_n="${signed_n#-}"

    # Resolve to log line number
    local done_lines total_done lineno
    done_lines="$(awk -F'\t' '$1=="done" {print NR}' "$CLK_LOG")"
    if [ -z "$done_lines" ]; then
        clk__die 5 "No completed records in log."
    fi
    total_done="$(printf '%s\n' "$done_lines" | wc -l | tr -d ' ')"
    if [ "$abs_n" -gt "$total_done" ]; then
        clk__die 1 "Index -${abs_n} out of range. Only ${total_done} completed record(s) in log."
    fi
    lineno="$(printf '%s\n' "$done_lines" | tail -n "${abs_n}" | head -n 1)"

    # Read done record fields
    local line_content
    line_content="$(clk__get_line "$lineno")"
    clk__read_line "$line_content"

    local start_ts="$CLK_F2"
    local tag="$CLK_F4"
    local break_secs="$CLK_F6"
    local description="$CLK_F8"

    # Prevent duplicate active session for same tag
    if clk__find_active "$tag" >/dev/null 2>&1; then
        clk__die 5 "Tag '$tag' already has an active session. Clock out first with 'clk out $tag'."
    fi

    # Build new active record (END_TIME, LENGTH_SECS, PAUSED_AT cleared)
    local new_record="active${CLK_TAB}${start_ts}${CLK_TAB}${CLK_TAB}${tag}${CLK_TAB}${CLK_TAB}${break_secs}${CLK_TAB}${CLK_TAB}${description}"

    clk__save_undo
    clk__delete_line "$lineno"
    clk__append_line "$new_record"

    printf '\nReactivated session in\n  %s\n  started at %s\n\n' "$tag" "$(clk__fmt_ts_display "$start_ts")"
}

# --- Interactive edit TUI ---
# clk edit (no args) opens an interactive record browser.
# Shows active sessions + last N done sessions (up to 10 rows).
# Arrow keys navigate, Enter selects, q quits.

# Save/restore terminal state for TUI
CLK_TUI_SAVED_STTY=""

clk__tui_cleanup() {
    # Restore terminal, show cursor
    if [ -n "$CLK_TUI_SAVED_STTY" ]; then
        stty "$CLK_TUI_SAVED_STTY" 2>/dev/null
    fi
    printf '\033[?25h' >/dev/tty
}

clk__tui_read_key() {
    local key
    IFS= read -r -s -n 1 key </dev/tty
    # Arrow keys: ESC [ A/B/C/D
    if [ "$key" = "$(printf '\033')" ]; then
        local seq
        IFS= read -r -s -n 2 -t 1 seq </dev/tty || true
        case "$seq" in
            '[A') printf 'UP' ;;
            '[B') printf 'DOWN' ;;
            *)    printf 'ESC' ;;
        esac
        return
    fi
    printf '%s' "$key"
}

# clk__tui_gather_rows() — collects rows for the interactive table.
# Sets CLK_TUI_ROWS (newline-separated: "signed_n<TAB>lineno<TAB>line_content")
# and CLK_TUI_ROW_COUNT.
CLK_TUI_ROWS=""
CLK_TUI_ROW_COUNT=0

clk__tui_gather_rows() {
    CLK_TUI_ROWS=""
    CLK_TUI_ROW_COUNT=0

    # Collect active sessions (positive index, oldest first)
    local active_lines active_count
    active_lines="$(awk -F'\t' '$1=="active" {print NR}' "$CLK_LOG")" || true
    active_count=0
    if [ -n "$active_lines" ]; then
        active_count="$(printf '%s\n' "$active_lines" | wc -l | tr -d ' ')"
    fi

    local i lineno line_content
    i=1
    while [ "$i" -le "$active_count" ]; do
        lineno="$(printf '%s\n' "$active_lines" | head -n "$i" | tail -n 1)"
        line_content="$(clk__get_line "$lineno")"
        if [ -n "$CLK_TUI_ROWS" ]; then
            CLK_TUI_ROWS="${CLK_TUI_ROWS}
${i}${CLK_TAB}${lineno}${CLK_TAB}${line_content}"
        else
            CLK_TUI_ROWS="${i}${CLK_TAB}${lineno}${CLK_TAB}${line_content}"
        fi
        CLK_TUI_ROW_COUNT=$(( CLK_TUI_ROW_COUNT + 1 ))
        i=$(( i + 1 ))
    done

    # Collect done sessions (negative index, most recent first, capped at 30)
    local done_lines done_count max_done=30
    done_lines="$(awk -F'\t' '$1=="done" {print NR}' "$CLK_LOG")" || true
    done_count=0
    if [ -n "$done_lines" ]; then
        done_count="$(printf '%s\n' "$done_lines" | wc -l | tr -d ' ')"
    fi
    if [ "$done_count" -gt "$max_done" ]; then
        done_count="$max_done"
    fi

    i=1
    while [ "$i" -le "$done_count" ]; do
        lineno="$(printf '%s\n' "$done_lines" | tail -n "$i" | head -n 1)"
        line_content="$(clk__get_line "$lineno")"
        if [ -n "$CLK_TUI_ROWS" ]; then
            CLK_TUI_ROWS="${CLK_TUI_ROWS}
-${i}${CLK_TAB}${lineno}${CLK_TAB}${line_content}"
        else
            CLK_TUI_ROWS="-${i}${CLK_TAB}${lineno}${CLK_TAB}${line_content}"
        fi
        CLK_TUI_ROW_COUNT=$(( CLK_TUI_ROW_COUNT + 1 ))
        i=$(( i + 1 ))
    done
}

# clk__tui_draw(selected_idx, scroll_offset) — draws a 3-row scrolling window.
# selected_idx is 0-based absolute index into CLK_TUI_ROWS.
# scroll_offset is the first visible row (0-based).
CLK_TUI_WINDOW=3

clk__tui_draw() {
    local sel="$1" offset="$2"
    local rev='\033[7m'
    local reset='\033[0m'
    local win_end=$(( offset + CLK_TUI_WINDOW ))

    # Move cursor to top of our drawing area and clear
    printf '\033[H\033[J' >/dev/tty

    # Build divider to match header width (76 chars content + 2 indent)
    local divider=""
    local di=0
    while [ "$di" -lt 76 ]; do
        divider="${divider}─"
        di=$(( di + 1 ))
    done

    # Scroll indicator
    local pos_str="$(( sel + 1 ))/${CLK_TUI_ROW_COUNT}"
    printf '  clk edit — ↑/↓ navigate, Enter select, q quit  [%s]\n' "$pos_str" >/dev/tty
    printf '  %s\n' "$divider" >/dev/tty

    # Header (2 extra cols for marker column: "▸ " or "  ")
    printf '    %3s  %-10s %-17s %-17s %8s %8s  %s\n' \
        "#" "TAG" "START" "END" "ACTIVE" "BREAK" "DESC" >/dev/tty
    printf '  %s\n' "$divider" >/dev/tty

    # Up-scroll indicator (always occupies a line for stable layout)
    if [ "$offset" -gt 0 ]; then
        printf '  %3s\n' "↑" >/dev/tty
    else
        printf '\n' >/dev/tty
    fi

    local row_idx=0
    local row
    printf '%s\n' "$CLK_TUI_ROWS" | while IFS= read -r row; do
        [ -z "$row" ] && { row_idx=$(( row_idx + 1 )); continue; }

        # Skip rows outside the visible window
        if [ "$row_idx" -lt "$offset" ] || [ "$row_idx" -ge "$win_end" ]; then
            row_idx=$(( row_idx + 1 ))
            continue
        fi

        local signed_n row_data
        signed_n="$(printf '%s' "$row" | cut -d"$CLK_TAB" -f1)"
        row_data="$(printf '%s' "$row" | cut -d"$CLK_TAB" -f3-)"

        clk__read_line "$row_data"
        local r_status="$CLK_F1" r_start="$CLK_F2" r_end="$CLK_F3" r_tag="$CLK_F4"
        local r_length="$CLK_F5" r_break="${CLK_F6:-0}" r_paused="$CLK_F7" r_desc="$CLK_F8"

        local disp_start disp_end active_str break_str desc_str marker
        disp_start="$(clk__fmt_ts_display "$r_start")"
        if [ "$r_status" = "done" ]; then
            disp_end="$(clk__fmt_ts_display "$r_end")"
            active_str="$(clk__fmt_duration "$r_length")"
        else
            disp_end="(active)"
            local now_epoch start_epoch elapsed_secs
            now_epoch="$(clk__now_epoch)"
            start_epoch="$(clk__to_epoch "$r_start" 2>/dev/null)" || start_epoch="$now_epoch"
            elapsed_secs=$(( now_epoch - start_epoch ))
            if [ -n "$r_break" ] && [ "$r_break" -gt 0 ] 2>/dev/null; then
                elapsed_secs=$(( elapsed_secs - r_break ))
            fi
            if [ -n "$r_paused" ]; then
                elapsed_secs=$(( elapsed_secs - (now_epoch - r_paused) ))
            fi
            if [ "$elapsed_secs" -lt 0 ]; then elapsed_secs=0; fi
            active_str="$(clk__fmt_duration "$elapsed_secs")"
        fi
        if [ -n "$r_break" ] && [ "$r_break" -gt 0 ] 2>/dev/null; then
            break_str="$(clk__fmt_duration "$r_break")"
        else
            break_str="—"
        fi
        desc_str="$r_desc"
        if [ "${#desc_str}" -gt 20 ]; then
            desc_str="$(printf '%.17s' "$desc_str")…"
        fi

        if [ "$row_idx" -eq "$sel" ]; then
            marker="▸"
        else
            marker=" "
        fi

        # Right-pad break_str to 8 display columns manually (— is 1 col but 3 bytes)
        local break_pad=""
        local break_disp_len="${#break_str}"
        if [ "$break_str" = "—" ]; then
            break_disp_len=1
        fi
        while [ "$break_disp_len" -lt 8 ]; do
            break_pad="${break_pad} "
            break_disp_len=$(( break_disp_len + 1 ))
        done

        local line_text
        line_text="$(printf '%s %3s  %-10s %-17s %-17s %8s %s%s  %s' \
            "$marker" "$signed_n" "$r_tag" "$disp_start" "$disp_end" "$active_str" "$break_pad" "$break_str" "$desc_str")"

        if [ "$row_idx" -eq "$sel" ]; then
            printf "${rev}  %s${reset}\n" "$line_text" >/dev/tty
        else
            printf '  %s\n' "$line_text" >/dev/tty
        fi

        row_idx=$(( row_idx + 1 ))
    done

    # Down-scroll indicator (always occupies a line for stable layout)
    if [ "$win_end" -lt "$CLK_TUI_ROW_COUNT" ]; then
        printf '  %3s\n' "↓" >/dev/tty
    else
        printf '\n' >/dev/tty
    fi

    printf '  %s\n' "$divider" >/dev/tty
}

# clk__tui_field_menu(signed_n, status) — prompts user for which field to edit.
# Returns field name in CLK_TUI_FIELD. Returns 1 if user cancels.
CLK_TUI_FIELD=""

clk__tui_field_menu() {
    local signed_n="$1" status="$2"

    printf '\n' >/dev/tty
    if [ "$status" = "active" ]; then
        printf '  Edit record %s: [t]ag [s]tart [a]ctive [b]reak [d]esc [p]ause [D]elete [q]back\n' "$signed_n" >/dev/tty
    else
        printf '  Edit record %s: [t]ag [s]tart [e]nd [a]ctive [b]reak [d]esc [D]elete [q]back\n' "$signed_n" >/dev/tty
    fi
    printf '  > ' >/dev/tty

    local key
    key="$(clk__tui_read_key)"

    case "$key" in
        t) CLK_TUI_FIELD="tag" ;;
        s) CLK_TUI_FIELD="start" ;;
        e) [ "$status" = "done" ] && CLK_TUI_FIELD="end" || { printf '\n  (No end time on active sessions)\n' >/dev/tty; return 1; } ;;
        a) CLK_TUI_FIELD="active" ;;
        b) CLK_TUI_FIELD="break" ;;
        d) CLK_TUI_FIELD="on" ;;
        p) [ "$status" = "active" ] && CLK_TUI_FIELD="pause" || { printf '\n  (Pause only for active sessions)\n' >/dev/tty; return 1; } ;;
        D) CLK_TUI_FIELD="delete" ;;
        q|ESC) return 1 ;;
        *) printf '\n  Unknown key.\n' >/dev/tty; return 1 ;;
    esac
    return 0
}

# clk__tui_prompt(prompt_text) — reads a line of input in cooked mode.
# Sets CLK_TUI_INPUT. Returns 1 on empty input.
CLK_TUI_INPUT=""

clk__tui_prompt() {
    local prompt="$1"
    # Temporarily restore cooked mode for line editing
    stty "$CLK_TUI_SAVED_STTY" 2>/dev/null
    printf '  %s' "$prompt" >/dev/tty
    CLK_TUI_INPUT=""
    IFS= read -r CLK_TUI_INPUT </dev/tty || true
    stty -echo -icanon 2>/dev/null
    if [ -z "$CLK_TUI_INPUT" ]; then
        return 1
    fi
    return 0
}

# clk__tui_adjust_menu(field, status) — prompts for adjust mode.
# Sets CLK_TUI_ADJUST. Returns 1 on cancel.
CLK_TUI_ADJUST=""

clk__tui_adjust_menu() {
    local field="$1" status="$2"

    case "$field" in
        end)
            printf '  Adjust: [a]ctive time or [b]reak time? ' >/dev/tty
            local key
            key="$(clk__tui_read_key)"
            printf '\n' >/dev/tty
            case "$key" in
                a) CLK_TUI_ADJUST="active" ;;
                b) CLK_TUI_ADJUST="break" ;;
                *) return 1 ;;
            esac
            ;;
        active)
            if [ "$status" = "done" ]; then
                printf '  Adjust: push [s]tart, push [e]nd, or adjust [b]reak? ' >/dev/tty
            else
                printf '  Adjust: push [s]tart or adjust [b]reak? ' >/dev/tty
            fi
            local key
            key="$(clk__tui_read_key)"
            printf '\n' >/dev/tty
            case "$key" in
                s) CLK_TUI_ADJUST="start" ;;
                e) [ "$status" = "done" ] && CLK_TUI_ADJUST="end" || return 1 ;;
                b) CLK_TUI_ADJUST="break" ;;
                *) return 1 ;;
            esac
            ;;
        break)
            if [ "$status" = "done" ]; then
                printf '  Adjust: push [s]tart, push [e]nd, or adjust [a]ctive? ' >/dev/tty
            else
                printf '  Adjust: push [s]tart or adjust [a]ctive? ' >/dev/tty
            fi
            local key
            key="$(clk__tui_read_key)"
            printf '\n' >/dev/tty
            case "$key" in
                s) CLK_TUI_ADJUST="start" ;;
                e) [ "$status" = "done" ] && CLK_TUI_ADJUST="end" || return 1 ;;
                a) CLK_TUI_ADJUST="active" ;;
                *) return 1 ;;
            esac
            ;;
    esac
    return 0
}

# clk_do_edit_interactive() — main TUI loop
clk_do_edit_interactive() {
    # Require a terminal
    if ! [ -t 0 ] || ! [ -t 1 ]; then
        clk__die 1 "Interactive edit requires a terminal. Use 'clk edit <n> <field> <value>' for non-interactive editing."
    fi

    clk__tui_gather_rows
    if [ "$CLK_TUI_ROW_COUNT" -eq 0 ]; then
        printf 'No records to edit.\n'
        return 0
    fi

    # Set up terminal
    CLK_TUI_SAVED_STTY="$(stty -g 2>/dev/null)"
    trap clk__tui_cleanup EXIT
    trap 'clk__tui_cleanup; exit 0' INT TERM
    stty -echo -icanon 2>/dev/null
    # Hide cursor
    printf '\033[?25l' >/dev/tty

    local selected=0
    local scroll_offset=0
    local running=1

    while [ "$running" = "1" ]; do
        clk__tui_draw "$selected" "$scroll_offset"

        local key
        key="$(clk__tui_read_key)"

        case "$key" in
            UP)
                if [ "$selected" -gt 0 ]; then
                    selected=$(( selected - 1 ))
                    # Scroll up if cursor moves above visible window
                    if [ "$selected" -lt "$scroll_offset" ]; then
                        scroll_offset="$selected"
                    fi
                fi
                ;;
            DOWN)
                if [ "$selected" -lt $(( CLK_TUI_ROW_COUNT - 1 )) ]; then
                    selected=$(( selected + 1 ))
                    # Scroll down if cursor moves below visible window
                    if [ "$selected" -ge $(( scroll_offset + CLK_TUI_WINDOW )) ]; then
                        scroll_offset=$(( selected - CLK_TUI_WINDOW + 1 ))
                    fi
                fi
                ;;
            q|ESC)
                running=0
                ;;
            "")
                # Enter key (read as empty in raw mode)
                # Extract the selected row's signed_n and status
                local sel_row signed_n row_lineno row_data
                sel_row="$(printf '%s\n' "$CLK_TUI_ROWS" | awk -v n=$(( selected + 1 )) 'NR==n')"
                signed_n="$(printf '%s' "$sel_row" | cut -d"$CLK_TAB" -f1)"
                row_data="$(printf '%s' "$sel_row" | cut -d"$CLK_TAB" -f3-)"
                clk__read_line "$row_data"
                local rec_status="$CLK_F1"

                # Show field menu
                if clk__tui_field_menu "$signed_n" "$rec_status"; then
                    local edit_field="$CLK_TUI_FIELD"
                    local edit_value="" edit_adjust=""

                    if [ "$edit_field" = "delete" ]; then
                        printf '\n  Confirm delete record %s? [y/n] ' "$signed_n" >/dev/tty
                        local confirm
                        confirm="$(clk__tui_read_key)"
                        printf '\n' >/dev/tty
                        if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
                            # Temporarily restore terminal for clk_do_edit output
                            stty "$CLK_TUI_SAVED_STTY" 2>/dev/null
                            clk_do_edit "$signed_n" "delete" "" ""
                            stty -echo -icanon 2>/dev/null
                            clk__tui_gather_rows
                            if [ "$CLK_TUI_ROW_COUNT" -eq 0 ]; then
                                running=0
                                printf '\n  No more records.\n' >/dev/tty
                            else
                                if [ "$selected" -ge "$CLK_TUI_ROW_COUNT" ]; then
                                    selected=$(( CLK_TUI_ROW_COUNT - 1 ))
                                fi
                                # Clamp scroll offset
                                local max_offset=$(( CLK_TUI_ROW_COUNT - CLK_TUI_WINDOW ))
                                if [ "$max_offset" -lt 0 ]; then max_offset=0; fi
                                if [ "$scroll_offset" -gt "$max_offset" ]; then
                                    scroll_offset="$max_offset"
                                fi
                                if [ "$selected" -lt "$scroll_offset" ]; then
                                    scroll_offset="$selected"
                                fi
                            fi
                        fi
                    else
                        # Prompt for value
                        local prompt_label
                        case "$edit_field" in
                            tag)   prompt_label="New tag: " ;;
                            start) prompt_label="New start (HH:MM or yyyy-mm-ddTHH:MM): " ;;
                            end)   prompt_label="New end (HH:MM or yyyy-mm-ddTHH:MM): " ;;
                            active) prompt_label="New active time (e.g. 90, 1h30m): " ;;
                            break) prompt_label="New break time (e.g. 15, 1h): " ;;
                            on)    prompt_label="New description: " ;;
                            pause) prompt_label="New pause time (HH:MM or 'clear'): " ;;
                        esac

                        if clk__tui_prompt "$prompt_label"; then
                            edit_value="$CLK_TUI_INPUT"

                            # Smart adjustment prompts for end, active, break
                            local needs_adjust=0
                            case "$edit_field" in
                                end|active|break) needs_adjust=1 ;;
                            esac

                            if [ "$needs_adjust" = "1" ]; then
                                if clk__tui_adjust_menu "$edit_field" "$rec_status"; then
                                    edit_adjust="$CLK_TUI_ADJUST"
                                else
                                    printf '  Cancelled.\n' >/dev/tty
                                    # Brief pause for user to see message
                                    IFS= read -r -s -n 1 -t 1 _ </dev/tty 2>/dev/null || true
                                    continue
                                fi
                            fi

                            # Apply edit
                            stty "$CLK_TUI_SAVED_STTY" 2>/dev/null
                            if clk_do_edit "$signed_n" "$edit_field" "$edit_value" "$edit_adjust"; then
                                clk__tui_gather_rows
                                # Clamp in case row count changed
                                if [ "$selected" -ge "$CLK_TUI_ROW_COUNT" ] && [ "$CLK_TUI_ROW_COUNT" -gt 0 ]; then
                                    selected=$(( CLK_TUI_ROW_COUNT - 1 ))
                                fi
                                local max_offset=$(( CLK_TUI_ROW_COUNT - CLK_TUI_WINDOW ))
                                if [ "$max_offset" -lt 0 ]; then max_offset=0; fi
                                if [ "$scroll_offset" -gt "$max_offset" ]; then
                                    scroll_offset="$max_offset"
                                fi
                            else
                                printf '  Edit failed.\n'
                            fi
                            stty -echo -icanon 2>/dev/null

                            # Brief pause to see before/after output
                            printf '\n  Press any key to continue...' >/dev/tty
                            IFS= read -r -s -n 1 _ </dev/tty 2>/dev/null || true
                        fi
                    fi
                fi
                ;;
        esac
    done

    # Clean up
    clk__tui_cleanup
    trap - EXIT INT TERM
    printf '\033[H\033[J' >/dev/tty
}

# --- clk_do_edit ---
# clk edit -<n> tag <new-tag>    — edit the Nth-to-last done session
# clk edit -<n> start <timestamp>
# clk edit -<n> end <timestamp> [--adjust active|break]
# clk edit -<n> active <duration> [--adjust start|end|break]
# clk edit -<n> break <duration> [--adjust active|start|end]
# clk edit -<n> pause <timestamp> | clear
# clk edit -<n> on <description>
# clk edit -<n> delete
# clk edit <n>  ...              — edit the Nth-oldest active session
#
# Negative index targets done sessions; positive index targets active sessions.
# Mirrors the convention used by clk last.
#
# 4th arg (adjust_mode): which field absorbs the change.
#   end   → "active" (default) or "break"
#   active → "start", "end", or "break"
#   break  → "active" (default), "start", or "end"
#
# --- RATIONALE: pause editing ---
# Occasionally the user pauses at the wrong time and minus on the initial
# pause command wasn't used. Rather than requiring undo + pause minus,
# direct editing of the PAUSED_AT field via edit is more surgical and
# doesn't disturb the undo stack.
clk_do_edit() {
    local signed_n="$1" field="$2" value="$3" adjust_mode="${4:-}"

    local is_negative=0 abs_n
    if printf '%s' "$signed_n" | grep -Eq '^-[0-9]+$'; then
        is_negative=1
        abs_n="${signed_n#-}"
    else
        abs_n="$signed_n"
    fi

    # Resolve signed index to a log line number
    local lineno
    if [ "$is_negative" = "1" ]; then
        local done_lines total_done
        done_lines="$(awk -F'\t' '$1=="done" {print NR}' "$CLK_LOG")"
        if [ -z "$done_lines" ]; then
            clk__die 5 "No completed records in log."
        fi
        total_done="$(printf '%s\n' "$done_lines" | wc -l | tr -d ' ')"
        if [ "$abs_n" -gt "$total_done" ]; then
            clk__die 1 "Index -${abs_n} out of range. Only ${total_done} completed record(s) in log."
        fi
        lineno="$(printf '%s\n' "$done_lines" | tail -n "${abs_n}" | head -n 1)"
    else
        local active_lines total_active
        active_lines="$(awk -F'\t' '$1=="active" {print NR}' "$CLK_LOG")"
        if [ -z "$active_lines" ]; then
            clk__die 5 "No active sessions in log."
        fi
        total_active="$(printf '%s\n' "$active_lines" | wc -l | tr -d ' ')"
        if [ "$abs_n" -gt "$total_active" ]; then
            clk__die 1 "Index ${abs_n} out of range. Only ${total_active} active session(s) in log."
        fi
        lineno="$(printf '%s\n' "$active_lines" | head -n "${abs_n}" | tail -n 1)"
    fi

    local line_content
    line_content="$(clk__get_line "$lineno")"
    clk__read_line "$line_content"

    local status="$CLK_F1"
    local start_ts="$CLK_F2"
    local end_ts="$CLK_F3"
    local tag="$CLK_F4"
    local length_secs="$CLK_F5"
    local break_secs="${CLK_F6:-0}"
    local paused_at="$CLK_F7"
    local description="$CLK_F8"

    case "$field" in
        tag)
            [ -n "$value" ] || clk__die 1 "Missing new tag for 'edit ${signed_n} tag <new-tag>'."
            clk__validate_tag "$value"
            clk__save_undo
            tag="$value"
            local new_record="${status}${CLK_TAB}${start_ts}${CLK_TAB}${end_ts}${CLK_TAB}${tag}${CLK_TAB}${length_secs}${CLK_TAB}${break_secs}${CLK_TAB}${paused_at}${CLK_TAB}${description}"
            clk__replace_line "$lineno" "$new_record"
            ;;
        start)
            [ -n "$value" ] || clk__die 1 "Missing timestamp for 'edit ${signed_n} start <timestamp>'."
            clk__validate_timestamp "$value"
            value="$CLK_VALIDATED_TS"
            local new_start_epoch
            new_start_epoch="$(clk__to_epoch "$value")"
            if [ "$status" = "done" ]; then
                local end_epoch
                end_epoch="$(clk__to_epoch "$end_ts")"
                if [ "$new_start_epoch" -gt "$end_epoch" ]; then
                    clk__die 1 "Start time ${value} is after end time ${end_ts}."
                fi
                length_secs=$(( end_epoch - new_start_epoch - break_secs ))
                if [ "$length_secs" -lt 0 ]; then
                    clk__die 1 "Active time would be negative with start ${value} and break $(clk__fmt_duration "$break_secs")."
                fi
            fi
            clk__save_undo
            start_ts="$value"
            local new_record="${status}${CLK_TAB}${start_ts}${CLK_TAB}${end_ts}${CLK_TAB}${tag}${CLK_TAB}${length_secs}${CLK_TAB}${break_secs}${CLK_TAB}${paused_at}${CLK_TAB}${description}"
            clk__replace_line "$lineno" "$new_record"
            ;;
        end)
            if [ "$status" = "active" ]; then
                clk__die 1 "Cannot set end time on an active record. Use 'clk out' instead."
            fi
            [ -n "$value" ] || clk__die 1 "Missing timestamp for 'edit ${signed_n} end <timestamp>'."
            clk__validate_timestamp "$value"
            value="$CLK_VALIDATED_TS"
            local new_end_epoch start_epoch
            new_end_epoch="$(clk__to_epoch "$value")"
            start_epoch="$(clk__to_epoch "$start_ts")"
            if [ "$new_end_epoch" -lt "$start_epoch" ]; then
                clk__die 1 "End time ${value} is before start time ${start_ts}."
            fi
            local span=$(( new_end_epoch - start_epoch ))
            : "${adjust_mode:=active}"
            case "$adjust_mode" in
                active)
                    length_secs=$(( span - break_secs ))
                    if [ "$length_secs" -lt 0 ]; then
                        clk__die 1 "Active time would be negative with end ${value} and break $(clk__fmt_duration "$break_secs")."
                    fi
                    ;;
                break)
                    break_secs=$(( span - length_secs ))
                    if [ "$break_secs" -lt 0 ]; then
                        clk__die 1 "Break time would be negative with end ${value} and active $(clk__fmt_duration "$length_secs")."
                    fi
                    ;;
                *)
                    clk__die 1 "Invalid --adjust '${adjust_mode}' for end. Expected: active, break."
                    ;;
            esac
            clk__save_undo
            end_ts="$value"
            local new_record="${status}${CLK_TAB}${start_ts}${CLK_TAB}${end_ts}${CLK_TAB}${tag}${CLK_TAB}${length_secs}${CLK_TAB}${break_secs}${CLK_TAB}${paused_at}${CLK_TAB}${description}"
            clk__replace_line "$lineno" "$new_record"
            ;;
        active)
            [ -n "$value" ] || clk__die 1 "Missing duration for 'edit ${signed_n} active <duration>'."
            clk__parse_duration "$value"
            local new_active_secs="$CLK_PARSED_DURATION_SECS"
            if [ "$new_active_secs" -le 0 ]; then
                clk__die 1 "Active time must be positive."
            fi
            if [ "$status" = "done" ]; then
                local start_epoch end_epoch
                start_epoch="$(clk__to_epoch "$start_ts")"
                end_epoch="$(clk__to_epoch "$end_ts")"
                [ -n "$adjust_mode" ] || clk__die 1 "Editing active time requires --adjust (start, end, or break)."
                case "$adjust_mode" in
                    start)
                        local new_start_epoch=$(( end_epoch - new_active_secs - break_secs ))
                        start_ts="$(clk__from_epoch "$new_start_epoch")"
                        ;;
                    end)
                        local new_end_epoch=$(( start_epoch + new_active_secs + break_secs ))
                        end_ts="$(clk__from_epoch "$new_end_epoch")"
                        ;;
                    break)
                        local span=$(( end_epoch - start_epoch ))
                        break_secs=$(( span - new_active_secs ))
                        if [ "$break_secs" -lt 0 ]; then
                            clk__die 1 "Active $(clk__fmt_duration "$new_active_secs") exceeds session span $(clk__fmt_duration "$span")."
                        fi
                        ;;
                    *)
                        clk__die 1 "Invalid --adjust '${adjust_mode}' for active. Expected: start, end, break."
                        ;;
                esac
            else
                # Active session: no end timestamp
                [ -n "$adjust_mode" ] || clk__die 1 "Editing active time requires --adjust (start or break)."
                case "$adjust_mode" in
                    start)
                        local now_epoch
                        now_epoch="$(clk__now_epoch)"
                        local pause_secs=0
                        if [ -n "$paused_at" ]; then
                            pause_secs=$(( now_epoch - paused_at ))
                        fi
                        local new_start_epoch=$(( now_epoch - new_active_secs - break_secs - pause_secs ))
                        start_ts="$(clk__from_epoch "$new_start_epoch")"
                        ;;
                    break)
                        local now_epoch
                        now_epoch="$(clk__now_epoch)"
                        local pause_secs=0
                        if [ -n "$paused_at" ]; then
                            pause_secs=$(( now_epoch - paused_at ))
                        fi
                        local elapsed=$(( now_epoch - $(clk__to_epoch "$start_ts") - pause_secs ))
                        break_secs=$(( elapsed - new_active_secs ))
                        if [ "$break_secs" -lt 0 ]; then
                            clk__die 1 "Active $(clk__fmt_duration "$new_active_secs") exceeds elapsed time $(clk__fmt_duration "$elapsed")."
                        fi
                        ;;
                    end)
                        clk__die 1 "Cannot use --adjust end on an active session (no end timestamp)."
                        ;;
                    *)
                        clk__die 1 "Invalid --adjust '${adjust_mode}' for active. Expected: start, end, break."
                        ;;
                esac
            fi
            clk__save_undo
            length_secs="$new_active_secs"
            local new_record="${status}${CLK_TAB}${start_ts}${CLK_TAB}${end_ts}${CLK_TAB}${tag}${CLK_TAB}${length_secs}${CLK_TAB}${break_secs}${CLK_TAB}${paused_at}${CLK_TAB}${description}"
            clk__replace_line "$lineno" "$new_record"
            ;;
        break)
            [ -n "$value" ] || clk__die 1 "Missing duration for 'edit ${signed_n} break <duration>'."
            clk__parse_duration "$value"
            local new_break_secs="$CLK_PARSED_DURATION_SECS"
            : "${adjust_mode:=active}"
            if [ "$status" = "done" ]; then
                local start_epoch end_epoch
                start_epoch="$(clk__to_epoch "$start_ts")"
                end_epoch="$(clk__to_epoch "$end_ts")"
                case "$adjust_mode" in
                    active)
                        local span=$(( end_epoch - start_epoch ))
                        if [ "$new_break_secs" -gt "$span" ]; then
                            clk__die 1 "Break $(clk__fmt_duration "$new_break_secs") exceeds session span $(clk__fmt_duration "$span")."
                        fi
                        length_secs=$(( span - new_break_secs ))
                        ;;
                    start)
                        local new_start_epoch=$(( end_epoch - length_secs - new_break_secs ))
                        start_ts="$(clk__from_epoch "$new_start_epoch")"
                        ;;
                    end)
                        local new_end_epoch=$(( start_epoch + length_secs + new_break_secs ))
                        end_ts="$(clk__from_epoch "$new_end_epoch")"
                        ;;
                    *)
                        clk__die 1 "Invalid --adjust '${adjust_mode}' for break. Expected: active, start, end."
                        ;;
                esac
            else
                # Active session: adjust_mode "end" is invalid (no end timestamp)
                case "$adjust_mode" in
                    active|start)
                        # For active sessions, break edit doesn't recalculate length_secs
                        # (there is no length_secs yet). Only "start" needs special handling.
                        if [ "$adjust_mode" = "start" ]; then
                            local now_epoch
                            now_epoch="$(clk__now_epoch)"
                            local pause_secs=0
                            if [ -n "$paused_at" ]; then
                                pause_secs=$(( now_epoch - paused_at ))
                            fi
                            local elapsed=$(( now_epoch - $(clk__to_epoch "$start_ts") - break_secs - pause_secs ))
                            local new_start_epoch=$(( now_epoch - elapsed - new_break_secs - pause_secs ))
                            start_ts="$(clk__from_epoch "$new_start_epoch")"
                        fi
                        ;;
                    end)
                        clk__die 1 "Cannot use --adjust end on an active session (no end timestamp)."
                        ;;
                    *)
                        clk__die 1 "Invalid --adjust '${adjust_mode}' for break. Expected: active, start, end."
                        ;;
                esac
            fi
            clk__save_undo
            break_secs="$new_break_secs"
            local new_record="${status}${CLK_TAB}${start_ts}${CLK_TAB}${end_ts}${CLK_TAB}${tag}${CLK_TAB}${length_secs}${CLK_TAB}${break_secs}${CLK_TAB}${paused_at}${CLK_TAB}${description}"
            clk__replace_line "$lineno" "$new_record"
            ;;
        pause)
            if [ "$status" != "active" ]; then
                clk__die 1 "Cannot set pause on a completed record. 'pause' only applies to active records."
            fi
            [ -n "$value" ] || clk__die 1 "Missing value for 'edit ${signed_n} pause <timestamp|clear>'."
            if [ "$value" = "clear" ]; then
                paused_at=""
            else
                clk__validate_timestamp "$value"
                value="$CLK_VALIDATED_TS"
                paused_at="$(clk__to_epoch "$value")"
            fi
            clk__save_undo
            local new_record="${status}${CLK_TAB}${start_ts}${CLK_TAB}${end_ts}${CLK_TAB}${tag}${CLK_TAB}${length_secs}${CLK_TAB}${break_secs}${CLK_TAB}${paused_at}${CLK_TAB}${description}"
            clk__replace_line "$lineno" "$new_record"
            ;;
        on)
            [ -n "$value" ] || clk__die 1 "Missing description for 'edit ${signed_n} on <description>'."
            clk__save_undo
            description="$value"
            local new_record="${status}${CLK_TAB}${start_ts}${CLK_TAB}${end_ts}${CLK_TAB}${tag}${CLK_TAB}${length_secs}${CLK_TAB}${break_secs}${CLK_TAB}${paused_at}${CLK_TAB}${description}"
            clk__replace_line "$lineno" "$new_record"
            ;;
        delete)
            clk__save_undo
            clk__delete_line "$lineno"
            local formatted
            formatted="$(clk__fmt_record "$line_content")"
            printf '\nDeleted record:\n  %s\n\n' "$formatted"
            return 0
            ;;
        *)
            clk__die 1 "Unknown field '${field}'. Expected: tag, start, end, active, break, pause, on, delete."
            ;;
    esac

    # Print before/after comparison (all non-delete paths)
    local updated_line
    updated_line="$(clk__get_line "$lineno")"
    CLK_FMT_RAW=1
    local fmt_before fmt_after
    fmt_before="$(clk__fmt_record "$line_content")"
    fmt_after="$(clk__fmt_record "$updated_line")"
    CLK_FMT_RAW=0
    printf '\nUpdated record %s:\n  before: %s\n   after: %s\n\n' "$signed_n" "$fmt_before" "$fmt_after"
}

# --- clk_do_log ---
# clk log — opens the log file in an editor.
#
# --- RATIONALE: $VISUAL before $EDITOR ---
# POSIX convention. $VISUAL is for full-screen editors; $EDITOR is for
# line editors. Falling back to vi ensures the command always works.
clk_do_log() {
    "${VISUAL:-${EDITOR:-vi}}" "$CLK_LOG"
}

# --- clk_do_alias ---
# clk alias — adds `alias c='clk'` to the user's shell rc file.
clk_do_alias() {
    local rc_file
    case "${SHELL:-/bin/bash}" in
        */zsh)  rc_file="$HOME/.zshrc" ;;
        */bash) rc_file="$HOME/.bashrc" ;;
        *)      rc_file="$HOME/.profile" ;;
    esac

    local alias_line="alias c='clk'"
    if grep -qF "$alias_line" "$rc_file" 2>/dev/null; then
        printf 'Alias already exists in %s\n' "$rc_file"
        return 0
    fi

    printf '\n%s\n' "$alias_line" >> "$rc_file" || clk__die 2 "Failed to write to '$rc_file'."
    printf 'Added "%s" to %s\n' "$alias_line" "$rc_file"
    printf 'Reload your shell or run: source %s\n' "$rc_file"
}

# --- clk__show_log_diff ---
# Shows a human-readable diff between two log files.
# Lines in $1 but not $2 are prefixed with "−" (removed).
# Lines in $2 but not $1 are prefixed with "+" (restored/added).
# Skips comment lines. Each changed record is formatted via clk__fmt_record.
clk__show_log_diff() {
    local before_file="$1" after_file="$2"

    # Extract data lines (skip comments) from each file
    local before_lines after_lines
    before_lines="$(grep -v '^#' "$before_file" | grep -v '^[[:space:]]*$' || true)"
    after_lines="$(grep -v '^#' "$after_file" | grep -v '^[[:space:]]*$' || true)"

    # Lines removed (in before but not after)
    local removed
    removed="$(comm -23 <(printf '%s\n' "$before_lines" | sort) <(printf '%s\n' "$after_lines" | sort) || true)"
    # Lines added (in after but not before)
    local added
    added="$(comm -13 <(printf '%s\n' "$before_lines" | sort) <(printf '%s\n' "$after_lines" | sort) || true)"

    local line
    if [ -n "$removed" ]; then
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            local formatted
            formatted="$(clk__fmt_record "$line")"
            printf '  − %s\n' "$formatted"
        done <<< "$removed"
    fi
    if [ -n "$added" ]; then
        while IFS= read -r line; do
            [ -z "$line" ] && continue
            local formatted
            formatted="$(clk__fmt_record "$line")"
            printf '  + %s\n' "$formatted"
        done <<< "$added"
    fi
}

# --- clk_do_undo ---
# clk undo
#
# --- RATIONALE: Showing diff ---
# A bare "Undone" message forces the user to run clk last or clk status
# to verify what happened. Showing the diff inline gives immediate
# confidence that the right thing was reversed.
clk_do_undo() {
    local undo_file="${CLK_LOG}.undo"
    if [ ! -f "$undo_file" ]; then
        printf 'Nothing to undo.\n'
        return 0
    fi

    # Save current to .redo, then restore .undo
    cp "$CLK_LOG" "${CLK_LOG}.redo" || clk__die 2 "Failed to save redo snapshot."
    local before_file="${CLK_LOG}.redo"

    cp "$undo_file" "$CLK_LOG" || clk__die 2 "Failed to restore undo snapshot."

    printf 'Undone.\n'
    clk__show_log_diff "$before_file" "$CLK_LOG"
    printf "Use 'clk redo' to reverse.\n"
}

# --- clk_do_redo ---
# clk redo
clk_do_redo() {
    local redo_file="${CLK_LOG}.redo"
    if [ ! -f "$redo_file" ]; then
        printf 'Nothing to redo.\n'
        return 0
    fi

    # Save current to .undo, then restore .redo
    cp "$CLK_LOG" "${CLK_LOG}.undo" || clk__die 2 "Failed to save undo snapshot."
    local before_file="${CLK_LOG}.undo"

    cp "$redo_file" "$CLK_LOG" || clk__die 2 "Failed to restore redo snapshot."

    printf 'Redone.\n'
    clk__show_log_diff "$before_file" "$CLK_LOG"
    printf "Use 'clk undo' to reverse.\n"
}

# --- clk_do_view ---
# clk view today | yesterday
# clk view past [<n>] <hour(s)|day(s)|week(s)|month(s)> [before <timestamp> | before minus <duration>]
# clk view from <timestamp> until|to <timestamp>
# Optional suffixes: [for <tag>] [by <day|week>]
#
# --- RATIONALE: view not blocked by active sessions ---
# v1 required all sessions closed before viewing summaries. v2 excludes
# active sessions from totals (their duration isn't finalized) and shows a
# note. Users can check active sessions via 'status'.
clk_do_view() {
    local start_epoch="$1" end_epoch="$2" range_desc="$3"
    local filter_tag="${4:-}" group_by="${5:-}"

    local start_ts end_ts
    start_ts="$(clk__from_epoch "$start_epoch")"
    end_ts="$(clk__from_epoch "$end_epoch")"

    # Count active sessions whose start falls within the range
    local active_in_range=0
    local active_lines
    active_lines="$(clk__find_active)" || true
    if [ -n "$active_lines" ]; then
        local aline
        while IFS= read -r aline; do
            local acontent
            acontent="$(clk__get_line "$aline")"
            clk__read_line "$acontent"
            local a_start_epoch
            a_start_epoch="$(clk__to_epoch "$CLK_F2")"
            if [ "$a_start_epoch" -ge "$start_epoch" ] && [ "$a_start_epoch" -lt "$end_epoch" ]; then
                # When filtering by tag, only count active sessions matching the filter
                if [ -z "$filter_tag" ] || clk__tag_matches "$CLK_F4" "$filter_tag"; then
                    active_in_range=$(( active_in_range + 1 ))
                fi
            fi
        done <<< "$active_lines"
    fi

    # (awk_tag_cond removed — multi-tag matching handled inside awk)

    printf '\n'

    if [ -n "$group_by" ]; then
        # --- Grouped bar chart mode ---
        # Bucket sessions by day or week and display as a bar chart
        clk__view_grouped "$start_ts" "$end_ts" "$start_epoch" "$end_epoch" \
            "$range_desc" "$filter_tag" "$group_by" "$active_in_range"
        printf '\n'
        return
    fi

    # Collect per-tag totals using awk with timestamp string comparisons
    local start_ts_str end_ts_str
    start_ts_str="$start_ts"
    end_ts_str="$end_ts"

    local awk_result
    awk_result="$(awk -F'\t' -v s="$start_ts_str" -v e="$end_ts_str" -v ftag="$filter_tag" '
    function tag_matches(t,    i, stem) {
        if (t in ftagset) return 1
        for (i = 1; i <= nprefixes; i++) {
            stem = prefixes[i]
            if (t == stem || substr(t, 1, length(stem) + 1) == stem ".") return 1
        }
        return 0
    }
    BEGIN {
        # Build tag filter lookup from comma-separated list
        nftags = 0; nprefixes = 0
        if (ftag != "") {
            n = split(ftag, ftarr, ",")
            for (i = 1; i <= n; i++) {
                f = ftarr[i]
                if (substr(f, length(f)) == ".") {
                    prefixes[++nprefixes] = substr(f, 1, length(f) - 1)
                } else {
                    ftagset[f] = 1
                }
            }
            nftags = n
        }
    }
    $1 == "done" && $3 >= s && $3 <= e {
        if (nftags > 0 && !tag_matches($4)) next
        tag = $4
        secs = $5 + 0
        total += secs
        if (!(tag in tagsecs)) {
            tags[++ntags] = tag
        }
        tagsecs[tag] += secs
    }
    END {
        # Print total first, then each tag sorted by seconds descending
        printf "%d\n", total

        # Simple insertion sort for descending order
        for (i = 1; i <= ntags; i++) {
            for (j = i + 1; j <= ntags; j++) {
                if (tagsecs[tags[j]] > tagsecs[tags[i]]) {
                    tmp = tags[i]
                    tags[i] = tags[j]
                    tags[j] = tmp
                }
            }
        }

        for (i = 1; i <= ntags; i++) {
            printf "%s\t%d\n", tags[i], tagsecs[tags[i]]
        }
    }
    ' "$CLK_LOG" 2>/dev/null)"

    # Parse awk output
    local total_secs=0
    local line_num=0
    local tag_names=()
    local tag_secs=()

    while IFS= read -r line; do
        if [ "$line_num" -eq 0 ]; then
            total_secs="$line"
        else
            local t s
            t="$(printf '%s' "$line" | cut -d"$CLK_TAB" -f1)"
            s="$(printf '%s' "$line" | cut -d"$CLK_TAB" -f2)"
            tag_names+=("$t")
            tag_secs+=("$s")
        fi
        line_num=$(( line_num + 1 ))
    done <<< "$awk_result"

    # Print output
    printf '%s\n' "$range_desc"
    printf '%s – %s\n' "$(clk__fmt_ts_full "$start_ts")" "$(clk__fmt_ts_full "$end_ts")"
    if [ -n "$filter_tag" ]; then
        printf 'Filtered by tag: %s\n' "$(printf '%s' "$filter_tag" | sed 's/,/, /g')"
    fi
    printf '\n'

    if [ "$total_secs" -eq 0 ] && [ "${#tag_names[@]}" -eq 0 ]; then
        printf 'No completed sessions in this range.\n'
    else
        local total_minutes total_hours_str
        total_minutes=$(( total_secs / 60 ))
        total_hours_str="$(awk "BEGIN { printf \"%.2f\", $total_secs / 3600 }")"

        # Header
        printf '%-18s %8s %10s %7s\n' "TAG" "MINUTES" "HOURS" "%"
        printf '%-18s %8d %9sh\n' "TOTAL" "$total_minutes" "$total_hours_str"

        local i
        for (( i = 0; i < ${#tag_names[@]}; i++ )); do
            local t_name="${tag_names[$i]}"
            local t_secs="${tag_secs[$i]}"
            local t_minutes=$(( t_secs / 60 ))
            local t_hours_str pct_str
            t_hours_str="$(awk "BEGIN { printf \"%.2f\", $t_secs / 3600 }")"
            if [ "$total_secs" -gt 0 ]; then
                pct_str="$(awk "BEGIN { printf \"%.2f\", ($t_secs / $total_secs) * 100 }")"
                printf '%-18s %8d %9sh %6s%%\n' "$t_name" "$t_minutes" "$t_hours_str" "$pct_str"
            else
                printf '%-18s %8d %9sh\n' "$t_name" "$t_minutes" "$t_hours_str"
            fi
        done
    fi

    if [ "$active_in_range" -gt 0 ]; then
        printf '\nNote: %d active session(s) not included in totals.\n' "$active_in_range"
    fi

    printf '\n'
}

# --- clk__view_grouped ---
# Renders a bar chart of minutes per day, week, month, or session.
# Called by clk_do_view when 'by day|week|month|session' is specified.
clk__view_grouped() {
    local start_ts="$1" end_ts="$2" start_epoch="$3" end_epoch="$4"
    local range_desc="$5" filter_tag="$6" group_by="$7" active_in_range="$8"

    local bar_width=40

    # Use awk to extract matching sessions.
    # For session grouping, emit start-timestamp and seconds.
    # For day/week/month, emit end-date (YYYY-MM-DD) and seconds.
    local raw_data
    raw_data="$(awk -F'\t' -v s="$start_ts" -v e="$end_ts" -v ftag="$filter_tag" -v gby="$group_by" '
    function tag_matches(t,    i, stem) {
        if (t in ftagset) return 1
        for (i = 1; i <= nprefixes; i++) {
            stem = prefixes[i]
            if (t == stem || substr(t, 1, length(stem) + 1) == stem ".") return 1
        }
        return 0
    }
    BEGIN {
        nftags = 0; nprefixes = 0
        if (ftag != "") {
            n = split(ftag, ftarr, ",")
            for (i = 1; i <= n; i++) {
                f = ftarr[i]
                if (substr(f, length(f)) == ".") {
                    prefixes[++nprefixes] = substr(f, 1, length(f) - 1)
                } else {
                    ftagset[f] = 1
                }
            }
            nftags = n
        }
    }
    $1 == "done" && $3 >= s && $3 <= e {
        if (nftags > 0 && !tag_matches($4)) next
        secs = $5 + 0
        if (gby == "session") {
            # Emit full session details for table rendering
            brk = $6 + 0
            desc = $8
            printf "%s\t%s\t%s\t%d\t%d\t%s\n", $2, $3, $4, secs, brk, desc
        } else {
            # Extract date from end timestamp
            date_part = substr($3, 1, 10)
            printf "%s\t%d\n", date_part, secs
        }
    }
    ' "$CLK_LOG" 2>/dev/null)"

    # Aggregate by day using awk, then optionally by week
    local day_data
    day_data="$(printf '%s' "$raw_data" | awk -F'\t' '
    NF >= 2 {
        day = $1
        secs = $2 + 0
        if (!(day in days)) {
            order[++n] = day
        }
        days[day] += secs
    }
    END {
        # Sort by date (insertion sort)
        for (i = 1; i <= n; i++) {
            for (j = i + 1; j <= n; j++) {
                if (order[j] < order[i]) {
                    tmp = order[i]
                    order[i] = order[j]
                    order[j] = tmp
                }
            }
        }
        for (i = 1; i <= n; i++) {
            printf "%s\t%d\n", order[i], days[order[i]]
        }
    }
    ')"

    # Print header
    printf '%s\n' "$range_desc"
    printf '%s – %s\n' "$(clk__fmt_ts_full "$start_ts")" "$(clk__fmt_ts_full "$end_ts")"
    if [ -n "$filter_tag" ]; then
        printf 'Tag: %s  (by %s)\n\n' "$(printf '%s' "$filter_tag" | sed 's/,/, /g')" "$group_by"
    else
        printf 'All tags  (by %s)\n\n' "$group_by"
    fi

    # For session grouping, use raw_data directly (one row per session)
    if [ "$group_by" = "session" ]; then
        if [ -z "$raw_data" ]; then
            printf 'No completed sessions in this range.\n'
            if [ "$active_in_range" -gt 0 ]; then
                printf '\nNote: %d active session(s) not included in totals.\n' "$active_in_range"
            fi
            return
        fi
        # Sort by start timestamp (already in order from log, but be safe)
        local session_data
        session_data="$(printf '%s' "$raw_data" | sort -t"$(printf '\t')" -k1,1)"
        # Show tag column if no filter (all tags), multiple tags in filter,
        # or any tag filter uses prefix matching (trailing dot)
        local show_tag=0
        if [ -z "$filter_tag" ]; then
            show_tag=1
        elif printf '%s' "$filter_tag" | grep -q ','; then
            show_tag=1
        elif printf '%s' "$filter_tag" | grep -qE '\.$'; then
            show_tag=1
        fi
        clk__view_render_session_table "$session_data" "$show_tag"
        if [ "$active_in_range" -gt 0 ]; then
            printf '\nNote: %d active session(s) not included in totals.\n' "$active_in_range"
        fi
        return
    fi

    if [ -z "$day_data" ]; then
        printf 'No completed sessions in this range.\n'
        if [ "$active_in_range" -gt 0 ]; then
            printf '\nNote: %d active session(s) not included in totals.\n' "$active_in_range"
        fi
        return
    fi

    if [ "$group_by" = "month" ]; then
        # Aggregate day_data into months (YYYY-MM)
        local month_data
        month_data="$(printf '%s' "$day_data" | awk -F'\t' '
        NF >= 2 {
            month_label = substr($1, 1, 7)
            secs = $2 + 0
            if (!(month_label in months)) {
                morder[++nm] = month_label
            }
            months[month_label] += secs
        }
        END {
            for (i = 1; i <= nm; i++) {
                for (j = i + 1; j <= nm; j++) {
                    if (morder[j] < morder[i]) {
                        tmp = morder[i]
                        morder[i] = morder[j]
                        morder[j] = tmp
                    }
                }
            }
            for (i = 1; i <= nm; i++) {
                printf "%s\t%d\n", morder[i], months[morder[i]]
            }
        }
        ')"

        clk__view_render_bars "$month_data" "$bar_width"
    elif [ "$group_by" = "week" ]; then
        # Aggregate day_data into weeks (Monday-based)
        # Pass to awk which uses date math to find week start
        local week_data
        week_data="$(printf '%s' "$day_data" | awk -F'\t' '
        function date_to_epoch(datestr,    cmd, ep) {
            y = substr(datestr,1,4) + 0
            m = substr(datestr,6,2) + 0
            d = substr(datestr,9,2) + 0
            a = int((14 - m) / 12)
            y2 = y + 4800 - a
            m2 = m + 12 * a - 3
            jdn = d + int((153 * m2 + 2) / 5) + 365 * y2 + int(y2/4) - int(y2/100) + int(y2/400) - 32045
            return (jdn - 2440588) * 86400
        }
        function epoch_to_date(ep,    days, y, m, d, jdn) {
            days = int(ep / 86400)
            jdn = days + 2440588
            a = jdn + 32044
            b = int((4*a + 3) / 146097)
            c = a - int(146097*b/4)
            dd = int((4*c + 3) / 1461)
            ee = c - int(1461*dd/4)
            mm = int((5*ee + 2) / 153)
            d = ee - int((153*mm + 2)/5) + 1
            m = mm + 3 - 12 * int(mm/10)
            y = 100*b + dd - 4800 + int(mm/10)
            return sprintf("%04d-%02d-%02d", y, m, d)
        }
        {
            date_str = $1
            secs = $2 + 0
            ep = date_to_epoch(date_str)
            days_since = int(ep / 86400)
            dow = (days_since + 3) % 7
            week_start_ep = ep - dow * 86400
            week_label = epoch_to_date(week_start_ep)

            if (!(week_label in weeks)) {
                worder[++nw] = week_label
            }
            weeks[week_label] += secs
        }
        END {
            for (i = 1; i <= nw; i++) {
                for (j = i + 1; j <= nw; j++) {
                    if (worder[j] < worder[i]) {
                        tmp = worder[i]
                        worder[i] = worder[j]
                        worder[j] = tmp
                    }
                }
            }
            for (i = 1; i <= nw; i++) {
                printf "%s\t%d\n", worder[i], weeks[worder[i]]
            }
        }
        ')"

        clk__view_render_bars "$week_data" "$bar_width"
    else
        # group_by == "day"
        clk__view_render_bars "$day_data" "$bar_width"
    fi

    if [ "$active_in_range" -gt 0 ]; then
        printf '\nNote: %d active session(s) not included in totals.\n' "$active_in_range"
    fi
}

# --- clk__view_render_session_table ---
# Renders a table of sessions from "start\tend\ttag\tsecs\tbreak_secs\tdesc" lines,
# followed by summary statistics.
# $1 = data, $2 = show_tag (1 or 0)
clk__view_render_session_table() {
    local data="$1" show_tag="$2"
    local term_cols
    term_cols="$(stty size </dev/tty 2>/dev/null | awk '{print $2}')"
    if [ -z "$term_cols" ] || [ "$term_cols" -le 0 ] 2>/dev/null; then
        term_cols=80
    fi

    printf '%s' "$data" | awk -F'\t' -v show_tag="$show_tag" -v term_w="$term_cols" '
    function trunc(s,    byte_len, i, col, c3, cut_byte) {
        if (term_w <= 0) return s
        byte_len = length(s)
        if (byte_len <= term_w) return s  # if bytes fit, display cols definitely fit
        # Walk the string tracking display columns vs byte positions.
        # Recognize the 3-byte UTF-8 characters used in our output (─ █ …)
        # so we never split a multi-byte sequence.
        col = 0; i = 1; cut_byte = 0
        while (i <= byte_len) {
            if (col == term_w - 1) cut_byte = i - 1
            c3 = substr(s, i, 3)
            if (c3 == "─" || c3 == "█" || c3 == "…") i += 3; else i++
            col++
        }
        if (col <= term_w) return s
        return substr(s, 1, cut_byte) "…"
    }
    function fmt_hm(secs,    h, m) {
        h = int(secs / 3600)
        m = int((secs % 3600) / 60)
        if (h > 0) return sprintf("%dh %02dm", h, m)
        return sprintf("%dm", m)
    }
    function fmt_ts(ts) {
        # YYYY-MM-DDTHH:MM:SS -> YYYY-MM-DD HH:MM
        return substr(ts, 1, 10) " " substr(ts, 12, 5)
    }
    function date_to_jdn(ts,    y, m, d, a) {
        # Convert YYYY-MM-DD... to Julian Day Number for day arithmetic
        y = substr(ts, 1, 4) + 0
        m = substr(ts, 6, 2) + 0
        d = substr(ts, 9, 2) + 0
        a = int((14 - m) / 12)
        y = y + 4800 - a
        m = m + 12 * a - 3
        return d + int((153 * m + 2) / 5) + 365 * y + int(y/4) - int(y/100) + int(y/400) - 32045
    }
    {
        n++
        start[n]   = $1
        endts[n]   = $2
        tag[n]     = $3
        secs[n]    = $4 + 0
        brk[n]     = $5 + 0
        desc[n]    = $6

        # Compute day offset for end timestamp
        end_diff[n] = date_to_jdn($2) - date_to_jdn($1)
        if (end_diff[n] > 0) {
            plen = length(sprintf("+%d", end_diff[n]))
            if (plen > max_prefix_w) max_prefix_w = plen
        }

        # Stats
        mins = secs[n] / 60
        vals[n] = mins
        total_secs += secs[n]
        total_brk  += brk[n]
    }
    END {
        if (n == 0) exit

        # Build end display strings with aligned HH:MM
        # If any cross-day sessions exist, all entries get a prefix area
        # so that HH:MM aligns vertically. +N is right-aligned in the prefix.
        # prefix_w includes the "+N" part; add 1 for the space before HH:MM
        if (max_prefix_w > 0) {
            end_col_w = max_prefix_w + 1 + 5  # "+N HH:MM"
        } else {
            end_col_w = 5  # just "HH:MM"
        }
        for (i = 1; i <= n; i++) {
            tm = substr(endts[i], 12, 5)
            if (max_prefix_w > 0) {
                if (end_diff[i] > 0) {
                    end_disp[i] = sprintf("%" max_prefix_w "s %s", sprintf("+%d", end_diff[i]), tm)
                } else {
                    end_disp[i] = sprintf("%" max_prefix_w "s %s", "", tm)
                }
            } else {
                end_disp[i] = tm
            }
        }

        # Check if any session has a description
        has_desc = 0
        for (i = 1; i <= n; i++) {
            if (desc[i] != "") { has_desc = 1; break }
        }

        # Compute max tag width
        max_tag_w = 3  # minimum for "Tag" header
        if (show_tag) {
            for (i = 1; i <= n; i++) {
                if (length(tag[i]) > max_tag_w) max_tag_w = length(tag[i])
            }
        }

        # Find max secs for bar normalization
        bar_max_w = 12
        max_secs = 0
        for (i = 1; i <= n; i++) {
            if (secs[i] > max_secs) max_secs = secs[i]
        }

        # Build header and separator
        hdr = sprintf("%*s  %-16s  %-*s  %-8s  %-6s", bar_max_w, "", "Start", end_col_w, "End", "Duration", "Break")
        sep = ""
        for (i = 1; i <= bar_max_w; i++) sep = sep " "
        sep = sep "  "
        for (i = 1; i <= 16; i++) sep = sep "─"
        sep = sep "  "
        for (i = 1; i <= end_col_w; i++) sep = sep "─"
        sep = sep "  "
        for (i = 1; i <= 8; i++) sep = sep "─"
        sep = sep "  "
        for (i = 1; i <= 6; i++) sep = sep "─"
        if (show_tag) {
            hdr = hdr sprintf("  %-*s", max_tag_w, "Tag")
            sep = sep "  "
            for (i = 1; i <= max_tag_w; i++) sep = sep "─"
        }
        if (has_desc) {
            hdr = hdr "  Description"
            sep = sep "  "
            for (i = 1; i <= 12; i++) sep = sep "─"
        }

        printf "%s\n%s\n", trunc(hdr), trunc(sep)

        # Compute max description width from terminal width
        # Fixed cols: bar(12) + 2 + Start(16) + 2 + End(end_col_w) + 2 + Duration(8) + 2 + Break(6)
        used_w = bar_max_w + 2 + 16 + 2 + end_col_w + 2 + 8 + 2 + 6
        if (show_tag) used_w += 2 + max_tag_w
        if (has_desc) used_w += 2  # gap before description
        max_desc_w = term_w - used_w
        if (max_desc_w < 10) max_desc_w = 10

        for (i = 1; i <= n; i++) {
            # Build right-aligned leftward-growing bar
            bar_len = (max_secs > 0) ? int((secs[i] / max_secs) * bar_max_w + 0.5) : 0
            if (bar_len < 1 && secs[i] > 0) bar_len = 1
            bar = ""
            pad = ""
            for (b = 0; b < bar_max_w - bar_len; b++) pad = pad " "
            for (b = 0; b < bar_len; b++) bar = bar "█"
            bar_field = pad bar

            line = bar_field sprintf("  %-16s  %-*s  %-8s  %-6s", fmt_ts(start[i]), end_col_w, end_disp[i], fmt_hm(secs[i]), fmt_hm(brk[i]))
            if (show_tag) line = line sprintf("  %-*s", max_tag_w, tag[i])
            if (has_desc && desc[i] != "") {
                d = desc[i]
                if (length(d) > max_desc_w) d = substr(d, 1, max_desc_w - 1) "…"
                line = line "  " d
            }
            printf "%s\n", trunc(line)
        }

        # Summary statistics
        sum = 0
        for (i = 1; i <= n; i++) sum += vals[i]
        mean = sum / n

        # Sort for median (insertion sort)
        for (i = 2; i <= n; i++) {
            v = vals[i]
            j = i - 1
            while (j >= 1 && vals[j] > v) {
                vals[j+1] = vals[j]
                j--
            }
            vals[j+1] = v
        }
        if (n % 2 == 1) {
            median = vals[int(n/2) + 1]
        } else {
            median = (vals[n/2] + vals[n/2 + 1]) / 2
        }

        sum2 = 0; sum3 = 0
        for (i = 1; i <= n; i++) {
            d = vals[i] - mean
            sum2 += d * d
            sum3 += d * d * d
        }
        if (n > 1) {
            variance = sum2 / (n - 1)
            stddev = sqrt(variance)
        } else {
            stddev = 0
        }
        if (n >= 3 && stddev > 0) {
            skew = (n / ((n-1.0) * (n-2.0))) * (sum3 / (stddev * stddev * stddev))
        } else {
            skew = 0
        }

        printf "\n"
        printf "  sessions  %5d\n", n
        printf "  mean    %7.1fm\n", mean
        printf "  median  %7.1fm\n", median
        printf "  stddev  %7.1fm\n", stddev
        printf "  skew    %7.2f\n", skew

        total_m = int(sum)
        if (total_m >= 60) {
            th = int(total_m / 60)
            tm = total_m - th * 60
            printf "  total   %7dm  (%dh %dm)\n", total_m, th, tm
        } else {
            printf "  total   %7dm\n", total_m
        }
        if (total_brk > 0) {
            printf "  breaks  %7dm\n", int(total_brk / 60)
        }
    }
    '
}

# --- clk__view_render_bars ---
# Renders a horizontal bar chart from "label\tsecs" lines,
# followed by summary statistics (mean, median, stddev, skewness).
clk__view_render_bars() {
    local data="$1" max_bar_width="$2"

    # Find max seconds for scaling
    local max_secs
    max_secs="$(printf '%s' "$data" | awk -F'\t' '
    { if ($2+0 > max) max = $2+0 }
    END { printf "%d", max }
    ')"

    if [ "$max_secs" -le 0 ]; then
        printf 'No completed sessions in this range.\n'
        return
    fi

    # Render bars and compute statistics in a single awk pass
    printf '%s' "$data" | awk -F'\t' -v max="$max_secs" -v bw="$max_bar_width" '
    {
        label = $1
        secs = $2 + 0
        mins = secs / 60
        bar_len = (max > 0) ? int((secs / max) * bw + 0.5) : 0
        if (bar_len < 1 && secs > 0) bar_len = 1
        bar = ""
        for (b = 0; b < bar_len; b++) bar = bar "█"
        printf "%s  %s %dm\n", label, bar, int(mins)

        vals[++n] = mins
        sum += mins
    }
    END {
        if (n == 0) exit

        # Mean
        mean = sum / n

        # Sort vals for median (insertion sort)
        for (i = 2; i <= n; i++) {
            v = vals[i]
            j = i - 1
            while (j >= 1 && vals[j] > v) {
                vals[j+1] = vals[j]
                j--
            }
            vals[j+1] = v
        }

        # Median
        if (n % 2 == 1) {
            median = vals[int(n/2) + 1]
        } else {
            median = (vals[n/2] + vals[n/2 + 1]) / 2
        }

        # Stddev and skewness (sample)
        sum2 = 0; sum3 = 0
        for (i = 1; i <= n; i++) {
            d = vals[i] - mean
            sum2 += d * d
            sum3 += d * d * d
        }

        if (n > 1) {
            variance = sum2 / (n - 1)
            stddev = sqrt(variance)
        } else {
            stddev = 0
        }

        # Adjusted Fisher-Pearson skewness (requires n >= 3)
        if (n >= 3 && stddev > 0) {
            skew = (n / ((n-1.0) * (n-2.0))) * (sum3 / (stddev * stddev * stddev))
        } else {
            skew = 0
        }

        printf "\n"
        printf "  mean    %7.1fm\n", mean
        printf "  median  %7.1fm\n", median
        printf "  stddev  %7.1fm\n", stddev
        printf "  skew    %7.2f\n", skew

        total_m = int(sum)
        if (total_m >= 60) {
            th = int(total_m / 60)
            tm = total_m - th * 60
            printf "  total   %7dm  (%dh %dm)\n", total_m, th, tm
        } else {
            printf "  total   %7dm\n", total_m
        }
    }
    '
}

#####################################################################
# View dispatch — shared parser for both `clk view ...` and the
# bare-keyword forms (`clk today`, `clk -1 month`, `clk from ... to ...`).
#####################################################################

# clk__run_view <args...>
# Parses a view range expression from its positional args and invokes
# clk_do_view. Accepts the same grammar as the former `clk view <range>`
# subcommand, minus the `view` keyword itself. Called both from the
# `view|v)` dispatch branch and from bare top-level range keywords.
clk__run_view() {
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing arguments. Usage: 'clk today', 'clk past <n> <unit>', or 'clk from <ts> to <ts>'."
    fi

    local view_start_epoch=""
    local view_end_epoch=""
    local view_range_desc=""
    local view_n view_unit view_unit_display view_anchor_epoch before_minus_val now_ep duration_secs
    local view_offset view_offset_unit view_thru_offset view_thru_unit view_thru_label
    local view_filter_tag view_group_by from_ts until_ts

    case "$1" in
        all)
            shift
            view_start_epoch=0
            view_end_epoch="$(clk__now_epoch)"
            view_range_desc="All time"
            ;;
        past)
            shift
            view_n=1
            view_unit=""

            if [ $# -eq 0 ]; then
                clk__die 1 "Missing time unit after 'past'. Usage: 'clk past [<n>] <hour(s)|day(s)|week(s)|month(s)|year(s)>'."
            fi

            if printf '%s' "$1" | grep -Eq '^[0-9]+$'; then
                view_n="$1"; shift
            fi

            if [ $# -eq 0 ]; then
                clk__die 1 "Missing time unit. Expected 'hour(s)', 'day(s)', 'week(s)', 'month(s)', or 'year(s)'."
            fi

            case "$1" in
                hour|hours)   view_unit="hours"; shift ;;
                day|days)     view_unit="days"; shift ;;
                week|weeks)   view_unit="weeks"; shift ;;
                month|months) view_unit="months"; shift ;;
                year|years)   view_unit="years"; shift ;;
                *) clk__die 1 "Unknown time unit '$1'. Expected 'hour(s)', 'day(s)', 'week(s)', 'month(s)', or 'year(s)'." ;;
            esac

            view_anchor_epoch="$(clk__now_epoch)"

            if [ $# -gt 0 ]; then
                if [ "$1" = "before" ]; then
                    shift
                    if [ $# -eq 0 ]; then
                        clk__die 1 "Missing value after 'before'. Expected a timestamp or 'minus <duration>'."
                    fi
                    if [ "$1" = "minus" ]; then
                        shift
                        [ $# -ge 1 ] || clk__die 1 "Missing <duration> after 'before minus'."
                        clk__parse_duration "$1"
                        before_minus_val="$CLK_PARSED_DURATION_SECS"; shift
                        now_ep="$(clk__now_epoch)"
                        view_anchor_epoch=$(( now_ep - before_minus_val ))
                    else
                        clk__consume_timestamp "$1" "${2:-}"
                        view_anchor_epoch="$(clk__to_epoch "$CLK_VALIDATED_TS")"
                        shift $CLK_TIMESTAMP_ARGC
                    fi
                elif [ "$1" != "for" ] && [ "$1" != "by" ]; then
                    clk__die 1 "Unexpected argument '$1'. Expected 'before', 'for', 'by', or end of command."
                fi
            fi

            duration_secs=0
            case "$view_unit" in
                hours)  duration_secs=$(( view_n * 3600 )) ;;
                days)   duration_secs=$(( view_n * 86400 )) ;;
                weeks)  duration_secs=$(( view_n * 604800 )) ;;
                months) duration_secs=$(( view_n * 2592000 )) ;;
                years)  duration_secs=$(( view_n * 31536000 )) ;;
            esac

            view_end_epoch="$view_anchor_epoch"
            view_start_epoch=$(( view_anchor_epoch - duration_secs ))
            view_unit_display="$view_unit"
            if [ "$view_n" -eq 1 ]; then
                view_unit_display="${view_unit%s}"
            fi
            view_range_desc="Past ${view_n} ${view_unit_display}"
            ;;
        from)
            shift
            [ $# -ge 1 ] || clk__die 1 "Missing <timestamp> after 'from'."
            clk__consume_timestamp "$1" "${2:-}"
            view_start_epoch="$(clk__to_epoch "$CLK_VALIDATED_TS")"
            shift $CLK_TIMESTAMP_ARGC

            if [ $# -eq 0 ] || [ "$1" != "to" ]; then
                clk__die 1 "Expected 'to <timestamp>' after 'from <timestamp>'."
            fi
            shift  # consume 'to'
            [ $# -ge 1 ] || clk__die 1 "Missing <timestamp> after 'to'."
            clk__consume_timestamp "$1" "${2:-}"
            view_end_epoch="$(clk__to_epoch "$CLK_VALIDATED_TS")"
            shift $CLK_TIMESTAMP_ARGC

            from_ts="$(clk__from_epoch "$view_start_epoch")"
            until_ts="$(clk__from_epoch "$view_end_epoch")"
            view_range_desc="$(clk__fmt_ts_full "$from_ts") → $(clk__fmt_ts_full "$until_ts")"
            ;;
        -[0-9]*|this|today|yesterday)
            view_offset_unit=""
            case "$1" in
                today)     view_offset=0; view_offset_unit="day" ;;
                yesterday) view_offset=1; view_offset_unit="day" ;;
                this)      view_offset=0 ;;
                *)
                    view_offset="${1#-}"
                    if ! printf '%s' "$view_offset" | grep -Eq '^[0-9]+$'; then
                        clk__die 1 "Invalid offset '$1'. Expected '-<n>' (e.g., '-0', '-3')."
                    fi
                    ;;
            esac
            shift

            if [ -z "$view_offset_unit" ]; then
                [ $# -ge 1 ] || clk__die 1 "Missing time unit after offset. Expected 'hour(s)', 'day(s)', 'week(s)', 'month(s)', or 'year(s)'."
                view_offset_unit="$1"; shift
            fi

            case "$view_offset_unit" in
                hour|hours)
                    view_start_epoch="$(clk__hour_start_epoch "-$view_offset")"
                    if [ "$view_offset" -eq 0 ]; then
                        view_end_epoch="$(clk__now_epoch)"
                        view_range_desc="This hour"
                    else
                        view_end_epoch="$(clk__hour_start_epoch "-$(( view_offset - 1 ))")"
                        if [ "$view_offset" -eq 1 ]; then
                            view_range_desc="Last hour"
                        else
                            view_range_desc="${view_offset} hours ago"
                        fi
                    fi
                    ;;
                day|days)
                    view_start_epoch="$(clk__midnight_epoch "-$view_offset")"
                    if [ "$view_offset" -eq 0 ]; then
                        view_end_epoch="$(clk__now_epoch)"
                        view_range_desc="Today"
                    else
                        view_end_epoch="$(clk__midnight_epoch "-$(( view_offset - 1 ))")"
                        if [ "$view_offset" -eq 1 ]; then
                            view_range_desc="Yesterday"
                        else
                            view_range_desc="${view_offset} days ago"
                        fi
                    fi
                    ;;
                week|weeks)
                    view_start_epoch="$(clk__week_start_epoch "-$view_offset")"
                    if [ "$view_offset" -eq 0 ]; then
                        view_end_epoch="$(clk__now_epoch)"
                        view_range_desc="This week"
                    else
                        view_end_epoch="$(clk__week_start_epoch "-$(( view_offset - 1 ))")"
                        if [ "$view_offset" -eq 1 ]; then
                            view_range_desc="Last week"
                        else
                            view_range_desc="${view_offset} weeks ago"
                        fi
                    fi
                    ;;
                month|months)
                    view_start_epoch="$(clk__month_start_epoch "-$view_offset")"
                    if [ "$view_offset" -eq 0 ]; then
                        view_end_epoch="$(clk__now_epoch)"
                        view_range_desc="This month"
                    else
                        view_end_epoch="$(clk__month_start_epoch "-$(( view_offset - 1 ))")"
                        if [ "$view_offset" -eq 1 ]; then
                            view_range_desc="Last month"
                        else
                            view_range_desc="${view_offset} months ago"
                        fi
                    fi
                    ;;
                year|years)
                    view_start_epoch="$(clk__year_start_epoch "-$view_offset")"
                    if [ "$view_offset" -eq 0 ]; then
                        view_end_epoch="$(clk__now_epoch)"
                        view_range_desc="This year"
                    else
                        view_end_epoch="$(clk__year_start_epoch "-$(( view_offset - 1 ))")"
                        if [ "$view_offset" -eq 1 ]; then
                            view_range_desc="Last year"
                        else
                            view_range_desc="${view_offset} years ago"
                        fi
                    fi
                    ;;
                *) clk__die 1 "Unknown time unit '$view_offset_unit'. Expected 'hour(s)', 'day(s)', 'week(s)', 'month(s)', or 'year(s)'." ;;
            esac

            # Optional: through {-<m> | this | today | yesterday} [<unit>]
            if [ $# -gt 0 ] && [ "$1" = "through" ]; then
                shift
                [ $# -ge 1 ] || clk__die 1 "Missing offset after 'through'. Expected '-<n>', 'this', 'today', or 'yesterday'."
                view_thru_unit=""
                case "$1" in
                    today)     view_thru_offset=0; view_thru_unit="day" ;;
                    yesterday) view_thru_offset=1; view_thru_unit="day" ;;
                    this)      view_thru_offset=0 ;;
                    *)
                        view_thru_offset="${1#-}"
                        if ! printf '%s' "$view_thru_offset" | grep -Eq '^[0-9]+$'; then
                            clk__die 1 "Invalid offset '$1' after 'through'. Expected '-<n>', 'this', 'today', or 'yesterday'."
                        fi
                        ;;
                esac
                shift

                if [ -z "$view_thru_unit" ]; then
                    [ $# -ge 1 ] || clk__die 1 "Missing time unit after 'through' offset. Expected 'hour(s)', 'day(s)', 'week(s)', 'month(s)', or 'year(s)'."
                    view_thru_unit="$1"; shift
                fi

                view_thru_label=""
                case "$view_thru_unit" in
                    hour|hours)
                        if [ "$view_thru_offset" -eq 0 ]; then
                            view_end_epoch="$(clk__now_epoch)"
                            view_thru_label="this hour"
                        else
                            view_end_epoch="$(clk__hour_start_epoch "-$(( view_thru_offset - 1 ))")"
                            if [ "$view_thru_offset" -eq 1 ]; then
                                view_thru_label="last hour"
                            else
                                view_thru_label="${view_thru_offset} hours ago"
                            fi
                        fi
                        ;;
                    day|days)
                        if [ "$view_thru_offset" -eq 0 ]; then
                            view_end_epoch="$(clk__now_epoch)"
                            view_thru_label="today"
                        else
                            view_end_epoch="$(clk__midnight_epoch "-$(( view_thru_offset - 1 ))")"
                            if [ "$view_thru_offset" -eq 1 ]; then
                                view_thru_label="yesterday"
                            else
                                view_thru_label="${view_thru_offset} days ago"
                            fi
                        fi
                        ;;
                    week|weeks)
                        if [ "$view_thru_offset" -eq 0 ]; then
                            view_end_epoch="$(clk__now_epoch)"
                            view_thru_label="this week"
                        else
                            view_end_epoch="$(clk__week_start_epoch "-$(( view_thru_offset - 1 ))")"
                            if [ "$view_thru_offset" -eq 1 ]; then
                                view_thru_label="last week"
                            else
                                view_thru_label="${view_thru_offset} weeks ago"
                            fi
                        fi
                        ;;
                    month|months)
                        if [ "$view_thru_offset" -eq 0 ]; then
                            view_end_epoch="$(clk__now_epoch)"
                            view_thru_label="this month"
                        else
                            view_end_epoch="$(clk__month_start_epoch "-$(( view_thru_offset - 1 ))")"
                            if [ "$view_thru_offset" -eq 1 ]; then
                                view_thru_label="last month"
                            else
                                view_thru_label="${view_thru_offset} months ago"
                            fi
                        fi
                        ;;
                    year|years)
                        if [ "$view_thru_offset" -eq 0 ]; then
                            view_end_epoch="$(clk__now_epoch)"
                            view_thru_label="this year"
                        else
                            view_end_epoch="$(clk__year_start_epoch "-$(( view_thru_offset - 1 ))")"
                            if [ "$view_thru_offset" -eq 1 ]; then
                                view_thru_label="last year"
                            else
                                view_thru_label="${view_thru_offset} years ago"
                            fi
                        fi
                        ;;
                    *) clk__die 1 "Unknown time unit '$view_thru_unit' after 'through'. Expected 'hour(s)', 'day(s)', 'week(s)', 'month(s)', or 'year(s)'." ;;
                esac

                if [ "$view_end_epoch" -le "$view_start_epoch" ]; then
                    clk__die 1 "'through' end must be after start. The 'through' period must be more recent than the starting period."
                fi

                view_range_desc="${view_range_desc} through ${view_thru_label}"
            fi
            ;;
        *)
            clk__die 1 "Unknown view range '$1'. Expected 'all', 'today', 'yesterday', 'past', 'from', '-<n>', or 'this'."
            ;;
    esac

    # Optional: for <tag> — filter by tag
    view_filter_tag=""
    if [ $# -gt 0 ] && [ "$1" = "for" ]; then
        shift
        [ $# -ge 1 ] || clk__die 1 "Missing <tag> after 'for'."
        view_filter_tag="$1"; shift
    fi

    # Optional: by <day|week|month|session> — group by time bucket
    view_group_by=""
    if [ $# -gt 0 ] && [ "$1" = "by" ]; then
        shift
        [ $# -ge 1 ] || clk__die 1 "Missing <day|week|month|session> after 'by'."
        case "$1" in
            day)     view_group_by="day"; shift ;;
            week)    view_group_by="week"; shift ;;
            month)   view_group_by="month"; shift ;;
            session) view_group_by="session"; shift ;;
            *) clk__die 1 "Unknown grouping '$1'. Expected 'day', 'week', 'month', or 'session'." ;;
        esac
    fi

    [ $# -eq 0 ] || clk__die 1 "Unexpected argument '$1' after range."

    clk_subcmd="view"
    clk_do_view "$view_start_epoch" "$view_end_epoch" "$view_range_desc" "$view_filter_tag" "$view_group_by"
}

#####################################################################
# Main — guarded so the script can be sourced for testing
#####################################################################

# When sourced with CLK_SOURCED=1, skip main execution so tests can
# call helpers directly.
if [ "${CLK_SOURCED:-0}" = "1" ]; then
    return 0 2>/dev/null || true
fi

# No-args: show synopsis
if [ "$#" -eq 0 ]; then
    printf '\n%s\n\nRun "clk help" and see the EXAMPLES section to get started.\n\n' "$CLK_SYNOPSIS"
    exit 0
fi

# Version
if [ "$1" = 'version' ] || [ "$1" = 'V' ]; then
    printf 'clk %s\n' "$CLK_VERSION"
    exit 0
fi

# Help
if [ "$1" = 'help' ]; then
    man clk 2>/dev/null || {
        clk_self_dir="$(cd "$(dirname "$0")" && pwd)"
        if [ -f "$clk_self_dir/clk.1" ]; then
            man "$clk_self_dir/clk.1"
        else
            printf "Man page not found. Install via 'brew install poiurewq/tap/clk' for full documentation.\n" >&2
            printf '\n%s\n\n' "$CLK_SYNOPSIS"
        fi
    }
    exit 0
fi

# Initialize log
clk__ensure_log
clk__upgrade_check

#####################################################################
# Argument parsing and subcommand dispatch
#####################################################################

# Shared option-parsing helpers used by subcommand parsers.
# These consume arguments from the caller's positional params via
# variable names rather than shift (since we parse in a while loop).

clk_subcmd=""
clk_tag=""
clk_at_timestamp=""
clk_minus_secs=""
clk_description=""
clk_for_secs=""
clk_from_tag=""
clk_last_n=""

case "$1" in

in)
    clk_subcmd="in"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing <tag> in 'clk in <tag>'. Run 'clk' for usage."
    fi
    clk_tag="$1"; shift

    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <duration> after 'minus'."
                clk__parse_duration "$2"
                clk_minus_secs="$CLK_PARSED_DURATION_SECS"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__consume_timestamp "$2" "${3:-}"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift $(( 1 + CLK_TIMESTAMP_ARGC ))
                ;;
            on)
                [ $# -ge 2 ] || clk__die 1 "Missing <description> after 'on'."
                shift  # consume 'on'
                clk_description="$*"
                break  # 'on' consumes all remaining args
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk in ${clk_tag}'."
                ;;
        esac
    done

    clk_do_in "$clk_tag" "$clk_at_timestamp" "$clk_minus_secs" "$clk_description"
    ;;

in-focus|I)
    clk_subcmd="in-focus"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing <tag>. Usage: 'clk in-focus <tag>'."
    fi
    clk_tag="$1"; shift

    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <duration> after 'minus'."
                clk__parse_duration "$2"
                clk_minus_secs="$CLK_PARSED_DURATION_SECS"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__consume_timestamp "$2" "${3:-}"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift $(( 1 + CLK_TIMESTAMP_ARGC ))
                ;;
            on)
                [ $# -ge 2 ] || clk__die 1 "Missing <description> after 'on'."
                shift
                clk_description="$*"
                break
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk in-focus ${clk_tag}'."
                ;;
        esac
    done

    clk_do_in_focus "$clk_tag" "$clk_at_timestamp" "$clk_minus_secs" "$clk_description"
    ;;

out)
    clk_subcmd="out"
    shift

    # Tag is optional — peek at first arg to see if it's a tag or an option
    if [ $# -gt 0 ] && [ "$1" != "minus" ] && [ "$1" != "at" ] && [ "$1" != "on" ]; then
        clk_tag="$1"; shift
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <duration> after 'minus'."
                clk__parse_duration "$2"
                clk_minus_secs="$CLK_PARSED_DURATION_SECS"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__consume_timestamp "$2" "${3:-}"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift $(( 1 + CLK_TIMESTAMP_ARGC ))
                ;;
            on)
                [ $# -ge 2 ] || clk__die 1 "Missing <description> after 'on'."
                shift
                clk_description="$*"
                break
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk out'."
                ;;
        esac
    done

    clk_do_out "$clk_tag" "$clk_at_timestamp" "$clk_minus_secs" "$clk_description"
    ;;

status|s)
    clk_subcmd="status"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk status'"
    clk_do_status
    ;;

last|l)
    clk_subcmd="last"
    shift
    if [ $# -gt 0 ]; then
        if printf '%s' "$1" | grep -Eq '^[1-9][0-9]*$'; then
            clk_last_n="$1"; shift
        else
            clk__die 1 "Expected a positive integer (e.g., 3) for 'clk last', got '$1'."
        fi
    fi
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk last [<n>]'"
    clk_do_last "${clk_last_n:-1}"
    ;;

pause|p)
    clk_subcmd="pause"
    shift

    # Tag is optional — peek at first arg
    if [ $# -gt 0 ] && [ "$1" != "minus" ] && [ "$1" != "at" ]; then
        clk_tag="$1"; shift
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <duration> after 'minus'."
                clk__parse_duration "$2"
                clk_minus_secs="$CLK_PARSED_DURATION_SECS"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__consume_timestamp "$2" "${3:-}"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift $(( 1 + CLK_TIMESTAMP_ARGC ))
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk pause'."
                ;;
        esac
    done

    clk_do_pause "$clk_tag" "$clk_minus_secs" "$clk_at_timestamp"
    ;;

resume|r)
    clk_subcmd="resume"
    shift

    # Tag is optional — peek at first arg
    if [ $# -gt 0 ] && [ "$1" != "minus" ] && [ "$1" != "at" ]; then
        clk_tag="$1"; shift
    fi

    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <duration> after 'minus'."
                clk__parse_duration "$2"
                clk_minus_secs="$CLK_PARSED_DURATION_SECS"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__consume_timestamp "$2" "${3:-}"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift $(( 1 + CLK_TIMESTAMP_ARGC ))
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk resume'."
                ;;
        esac
    done

    clk_do_resume "$clk_tag" "$clk_minus_secs" "$clk_at_timestamp"
    ;;

resume-focus|R)
    clk_subcmd="resume-focus"
    shift

    # Tag is required
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing <tag>. Usage: 'clk resume-focus <tag>'."
    fi
    clk_tag="$1"; shift

    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <duration> after 'minus'."
                clk__parse_duration "$2"
                clk_minus_secs="$CLK_PARSED_DURATION_SECS"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__consume_timestamp "$2" "${3:-}"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift $(( 1 + CLK_TIMESTAMP_ARGC ))
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk resume-focus'."
                ;;
        esac
    done

    clk_do_resume_focus "$clk_tag" "$clk_minus_secs" "$clk_at_timestamp"
    ;;

unpause|up)
    clk_subcmd="unpause"
    shift

    # Tag is optional
    if [ $# -gt 0 ]; then
        clk_tag="$1"; shift
    fi
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk unpause [<tag>]'"

    clk_do_unpause "$clk_tag"
    ;;

switch)
    clk_subcmd="switch"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing <new-tag> in 'clk switch <new-tag>'. Run 'clk' for usage."
    fi
    clk_tag="$1"; shift

    while [ $# -gt 0 ]; do
        case "$1" in
            from)
                [ $# -ge 2 ] || clk__die 1 "Missing <old-tag> after 'from'."
                clk_from_tag="$2"; shift 2
                ;;
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <duration> after 'minus'."
                clk__parse_duration "$2"
                clk_minus_secs="$CLK_PARSED_DURATION_SECS"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__consume_timestamp "$2" "${3:-}"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift $(( 1 + CLK_TIMESTAMP_ARGC ))
                ;;
            on)
                [ $# -ge 2 ] || clk__die 1 "Missing <description> after 'on'."
                shift
                clk_description="$*"
                break
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk switch ${clk_tag}'."
                ;;
        esac
    done

    clk_do_switch "$clk_tag" "$clk_from_tag" "$clk_at_timestamp" "$clk_minus_secs" "$clk_description"
    ;;

add|a)
    clk_subcmd="add"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing arguments. Usage: 'clk add <tag> for <duration>' or 'clk add <duration> [to <tag>]'."
    fi

    # Disambiguate: if $1 looks like a duration (plain int or X/Y/XhYm form),
    # it's "add <duration> [to <tag>]". Otherwise it's "add <tag> for <duration>".
    if printf '%s' "$1" | grep -Eq '^[0-9]+([hH]([0-9]+[mM])?|[mM])?$'; then
        # Form: add <duration> [to <tag>]
        clk__parse_duration "$1"
        clk_for_secs="$CLK_PARSED_DURATION_SECS"; shift
        if [ $# -gt 0 ] && [ "$1" = "to" ]; then
            [ $# -ge 2 ] || clk__die 1 "Missing <tag> after 'to'."
            clk_tag="$2"; shift 2
        fi
        [ $# -eq 0 ] || clk__die 1 "Unexpected argument '$1' after 'clk add'."
        clk_do_add_time "$clk_for_secs" "$clk_tag"
    else
        # Form: add <tag> for <duration> [minus <duration> | at <timestamp>] [on <description>]
        clk_tag="$1"; shift
        if [ $# -eq 0 ] || [ "$1" != "for" ]; then
            clk__die 1 "Expected 'for <duration>' after 'clk add ${clk_tag}'. Run 'clk' for usage."
        fi
        shift  # consume 'for'
        [ $# -ge 1 ] || clk__die 1 "Missing <duration> after 'for'."
        clk__parse_duration "$1"
        clk_for_secs="$CLK_PARSED_DURATION_SECS"; shift

        while [ $# -gt 0 ]; do
            case "$1" in
                minus)
                    [ $# -ge 2 ] || clk__die 1 "Missing <duration> after 'minus'."
                    clk__parse_duration "$2"
                    clk_minus_secs="$CLK_PARSED_DURATION_SECS"; shift 2
                    ;;
                at)
                    [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                    clk__validate_timestamp "$2"
                    clk_at_timestamp="$CLK_VALIDATED_TS"; shift 2
                    ;;
                on)
                    [ $# -ge 2 ] || clk__die 1 "Missing <description> after 'on'."
                    shift
                    clk_description="$*"
                    break
                    ;;
                *)
                    clk__die 1 "Unknown option '$1' after 'clk add ${clk_tag} for <duration>'."
                    ;;
            esac
        done

        clk_do_add_session "$clk_tag" "$clk_for_secs" "$clk_at_timestamp" "$clk_minus_secs" "$clk_description"
    fi
    ;;

add-break|ab)
    clk_subcmd="add-break"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing <duration> in 'clk add-break <duration>'. Run 'clk' for usage."
    fi
    clk__parse_duration "$1"
    clk_for_secs="$CLK_PARSED_DURATION_SECS"; shift

    if [ $# -gt 0 ] && [ "$1" = "to" ]; then
        [ $# -ge 2 ] || clk__die 1 "Missing <tag> after 'to'."
        clk_tag="$2"; shift 2
    fi
    [ $# -eq 0 ] || clk__die 1 "Unexpected argument '$1'. Usage: 'clk add-break <duration> [to <tag>]'."

    clk_do_add_break "$clk_for_secs" "$clk_tag"
    ;;

extend)
    clk_subcmd="extend"
    shift

    # Tag is optional — peek at first arg
    if [ $# -gt 0 ] && [ "$1" != "minus" ] && [ "$1" != "at" ] && [ "$1" != "by" ]; then
        clk_tag="$1"; shift
    fi

    clk_by_secs=""
    while [ $# -gt 0 ]; do
        case "$1" in
            minus)
                [ $# -ge 2 ] || clk__die 1 "Missing <duration> after 'minus'."
                clk__parse_duration "$2"
                clk_minus_secs="$CLK_PARSED_DURATION_SECS"; shift 2
                ;;
            at)
                [ $# -ge 2 ] || clk__die 1 "Missing <timestamp> after 'at'."
                clk__consume_timestamp "$2" "${3:-}"
                clk_at_timestamp="$CLK_VALIDATED_TS"; shift $(( 1 + CLK_TIMESTAMP_ARGC ))
                ;;
            by)
                [ $# -ge 2 ] || clk__die 1 "Missing <duration> after 'by'."
                clk__parse_duration "$2"
                clk_by_secs="$CLK_PARSED_DURATION_SECS"; shift 2
                ;;
            *)
                clk__die 1 "Unknown option '$1' after 'clk extend'."
                ;;
        esac
    done

    clk_do_extend "$clk_tag" "$clk_at_timestamp" "$clk_minus_secs" "$clk_by_secs"
    ;;

pop)
    clk_subcmd="pop"
    shift
    clk_remove_n=""
    if [ $# -gt 0 ]; then
        if ! printf '%s' "$1" | grep -Eq '^-?[1-9][0-9]*$'; then
            clk__die 1 "Expected -<n> (done) or <n> (active) index, or no argument. Usage: 'clk pop [-<n> | <n>]'"
        fi
        clk_remove_n="$1"; shift
    fi
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk pop [-<n> | <n>]'"
    clk_do_remove "$clk_remove_n"
    ;;

reactivate|ra)
    clk_subcmd="reactivate"
    shift
    if [ $# -eq 0 ]; then
        clk__die 1 "Missing index. Usage: 'clk reactivate -<n>'"
    fi
    if ! printf '%s' "$1" | grep -Eq '^-[1-9][0-9]*$'; then
        clk__die 1 "Expected -<n> index (done session), got '$1'. Usage: 'clk reactivate -<n>'"
    fi
    clk_ra_n="$1"; shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk reactivate -<n>'"
    clk_do_reactivate "$clk_ra_n"
    ;;

undo)
    clk_subcmd="undo"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk undo'"
    clk_do_undo
    ;;

redo)
    clk_subcmd="redo"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk redo'"
    clk_do_redo
    ;;

view|v)
    shift
    clk__run_view "$@"
    ;;


edit|e)
    clk_subcmd="edit"
    shift

    # No args → interactive mode
    if [ $# -eq 0 ]; then
        clk_do_edit_interactive
        exit 0
    fi

    # Parse signed index: -<n> targets done sessions, <n> targets active sessions
    clk_edit_n=""
    if printf '%s' "$1" | grep -Eq '^-[1-9][0-9]*$'; then
        clk_edit_n="$1"; shift
    elif printf '%s' "$1" | grep -Eq '^[1-9][0-9]*$'; then
        clk_edit_n="$1"; shift
    else
        clk__die 1 "Expected -<n> (done) or <n> (active) index, got '$1'. Usage: 'clk edit (-<n> | <n>) <field> <value>'."
    fi

    if [ $# -eq 0 ]; then
        clk__die 1 "Missing field. Usage: 'clk edit ${clk_edit_n} <field> <value>'."
    fi

    clk_edit_field="$1"; shift

    # For 'on', collect all remaining args as the description
    # For 'delete', no value needed
    # For others, take next arg as value
    clk_edit_value=""
    clk_edit_adjust=""
    case "$clk_edit_field" in
        on)
            [ $# -ge 1 ] || clk__die 1 "Missing <description> after 'on'."
            clk_edit_value="$*"
            ;;
        delete)
            [ $# -eq 0 ] || clk__die 1 "Unexpected argument '$1' after 'delete'."
            ;;
        tag|start|end|active|break|pause)
            [ $# -ge 1 ] || clk__die 1 "Missing value for 'edit ${clk_edit_n} ${clk_edit_field}'."
            case "$clk_edit_field" in
                start|end)
                    if printf '%s' "$1" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}$' && \
                       [ $# -ge 2 ] && printf '%s' "$2" | grep -Eq '^[0-9]{2}:[0-9]{2}(:[0-9]{2})?$'; then
                        clk_edit_value="$1 $2"; shift 2
                    else
                        clk_edit_value="$1"; shift
                    fi
                    ;;
                pause)
                    if [ "$1" != "clear" ] && \
                       printf '%s' "$1" | grep -Eq '^[0-9]{4}-[0-9]{2}-[0-9]{2}$' && \
                       [ $# -ge 2 ] && printf '%s' "$2" | grep -Eq '^[0-9]{2}:[0-9]{2}(:[0-9]{2})?$'; then
                        clk_edit_value="$1 $2"; shift 2
                    else
                        clk_edit_value="$1"; shift
                    fi
                    ;;
                *)
                    clk_edit_value="$1"; shift
                    ;;
            esac
            # Parse optional --adjust flag for end, active, break
            if [ $# -ge 1 ] && [ "$1" = "--adjust" ]; then
                shift
                [ $# -ge 1 ] || clk__die 1 "Missing value after --adjust."
                clk_edit_adjust="$1"; shift
            fi
            [ $# -eq 0 ] || clk__die 1 "Unexpected argument '$1' after 'clk edit ${clk_edit_n} ${clk_edit_field} ${clk_edit_value}'."
            ;;
        *)
            clk__die 1 "Unknown field '${clk_edit_field}'. Expected: tag, start, end, active, break, pause, on, delete."
            ;;
    esac

    clk_do_edit "$clk_edit_n" "$clk_edit_field" "$clk_edit_value" "$clk_edit_adjust"
    ;;

log)
    clk_subcmd="log"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk log'"
    clk_do_log
    ;;

alias)
    clk_subcmd="alias"
    shift
    [ $# -eq 0 ] || clk__die 1 "Too many arguments. Usage: 'clk alias'"
    clk_do_alias
    ;;

-[0-9]*)
    # Ambiguous: `clk -<n>` shows a single done record, but `clk -<n> <unit> ...`
    # is a view range. Peek at the next token to disambiguate.
    if [ $# -ge 2 ]; then
        case "$2" in
            hour|hours|day|days|week|weeks|month|months|year|years)
                clk__run_view "$@"
                exit $?
                ;;
        esac
    fi
    # Show a single done session: clk -<n> prints only the Nth-to-last done.
    clk_subcmd="last"
    clk_last_n="$1"
    clk__validate_positive_int "${clk_last_n#-}" "<n> in 'clk -<n>'"
    [ $# -eq 1 ] || clk__die 1 "Too many arguments. Usage: 'clk -<n>'"
    clk__show_done_at "${clk_last_n#-}"
    ;;

[1-9]*)
    # Show a single active session: clk <n> prints only the Nth-oldest active.
    # (Tags must not be purely numeric, per 'clk in', so this is unambiguous.)
    if ! printf '%s' "$1" | grep -Eq '^[1-9][0-9]*$'; then
        clk__die 1 "Unknown command '$1'. Run 'clk' with no arguments for usage."
    fi
    clk_subcmd="last"
    clk_pos_n="$1"
    [ $# -eq 1 ] || clk__die 1 "Too many arguments. Usage: 'clk <n>'"
    clk__show_active_at "$clk_pos_n"
    ;;

all|past|from|this|today|yesterday)
    # Syntactic sugar: bare range keywords dispatch to view.
    clk__run_view "$@"
    ;;

*)
    clk__die 1 "Unknown command '$1'. Run 'clk' with no arguments for usage."
    ;;

esac
