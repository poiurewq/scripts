#!/usr/bin/env zsh
set -e

#######################################################################
# Display formatting
#######################################################################

bf=$(tput bold 2>/dev/null) || bf=''
nf=$(tput sgr0 2>/dev/null) || nf=''
uf=$(tput smul 2>/dev/null) || uf=''

#######################################################################
# Constants
#######################################################################

nt_template_name='nt_template'

# Editor resolution order: NT_EDITOR > VISUAL > EDITOR > vim  (§3.4)
nt_editor="${NT_EDITOR:-${VISUAL:-${EDITOR:-vim}}}"

# Syntax references used in error messages
nt_syn_r="${bf}rename${nf} ${uf}num${nf} ${uf}title${nf}"
nt_syn_rn="${bf}renumber${nf} ${uf}n${nf} ${uf}m${nf}"

# Reserved tokens for non-greedy title parsing (§3.1 / Appendix B)
# Any argument matching one of these stops consume_title.
_nt_reserved_tokens=(
	n new l last r rename rl rn renumber
	a activity ar activity-recursive
	h help R t
	i index c copy
)

#######################################################################
# Cross-platform abstraction (§2.5)
#######################################################################

NT_PLATFORM='other'

nt_platform_detect() {
	case "$OSTYPE" in
		darwin*)  NT_PLATFORM='darwin' ;;
		linux*)   NT_PLATFORM='linux'  ;;
		*)        NT_PLATFORM='other'  ;;
	esac
}

nt_open_app() {
	local app_name="$1"; shift
	case "$NT_PLATFORM" in
		darwin) open -a "$app_name" "$@" ;;
		*)      "$app_name" "$@" ;;
	esac
}

nt_copy_to_clipboard() {
	local string="$1"
	case "$NT_PLATFORM" in
		darwin)
			printf '%s' "$string" | pbcopy
			;;
		linux)
			printf '%s' "$string" | xsel --clipboard --input 2>/dev/null \
				|| printf '%s' "$string" | xclip -selection clipboard 2>/dev/null \
				|| return 1
			;;
		*)
			return 1
			;;
	esac
}

nt_stat_mtime_ym() {
	case "$NT_PLATFORM" in
		darwin) stat -f "%Sm" -t "%Y-%m" "$@" ;;
		*)      stat -c "%y" "$@" | cut -d'-' -f1,2 ;;
	esac
}

#######################################################################
# Error helper (§2.6)
#######################################################################

nt_err() {
	printf '%s\n' "$1" >&2
}

#######################################################################
# Utility functions
#######################################################################

nt_open() {
	local app_or_cmd="$1"; shift
	local -a file_list=("$@")

	if command -v "${app_or_cmd}" >/dev/null 2>&1; then
		case "$app_or_cmd" in
			vi|vim) vim -p "${file_list[@]}" ;;
			*) "${app_or_cmd}" "${file_list[@]}" ;;
		esac
	else
		nt_open_app "${app_or_cmd}" "${file_list[@]}"
	fi
}

# Returns the numeric index (as integer string) of the last indexed
# document, or 0 if none exist. Uses zsh globs instead of ls|sort|awk.
last_num_getter() {
	local -a docs
	docs=( [0-9]##*(N.on) )
	if [[ ${#docs[@]} -eq 0 ]]; then
		printf '0'
		return 0
	fi
	local last="${docs[-1]}"
	local num="${last%%[^0-9]*}"
	# Force base-10 to strip leading zeros for arithmetic
	printf '%d' "$(( 10#${num} ))"
}

# Returns the filename of the last indexed document (highest numeric
# index). Uses zsh glob qualifiers for numeric sorting. Returns 1 if
# no indexed documents exist.
last_indexed_doc() {
	local -a docs
	docs=( [0-9]##*(N.on) )
	if [[ ${#docs[@]} -eq 0 ]]; then
		return 1
	fi
	printf '%s' "${docs[-1]}"
}

# Returns the delimiter string between the numeric index and title.
# e.g. "001__foo.md" -> "__", "001-foo.md" -> "-", "001.md" -> ""
get_delimiter() {
	local name="$1"
	if [[ "$name" =~ ^[0-9]+(_+) ]]; then
		printf '%s' "${match[1]}"
	elif [[ "$name" =~ ^[0-9]+(-+) ]]; then
		printf '%s' "${match[1]}"
	fi
}

# Returns the file extension (everything after the last dot, if
# non-numeric). Returns 1 if no valid extension found.
get_extension() {
	local filename="$1"
	local ext="${filename##*.}"
	if [[ "$ext" == "$filename" ]] || [[ "$ext" =~ ^[0-9]+$ ]]; then
		return 1
	fi
	printf '%s' "$ext"
}

# Returns the matching filename for a given numeric index. Prints an
# error to stderr and returns 1 if not found.
find_doc_by_index() {
	local padded
	padded="$( printf '%03d' "$1" )"
	local -a docs
	docs=( ${padded}*(N.) )
	if [[ ${#docs[@]} -eq 0 ]]; then
		nt_err "File with index ${padded} not found."
		return 1
	fi
	printf '%s' "${docs[1]}"
}

# Validates a simple numeric index (must be integer, 1–999).
# Prints an error to stderr and returns 1 if invalid.
validate_index() {
	local idx="$1"
	if ! [[ "$idx" =~ ^[0-9]+$ ]]; then
		nt_err "Invalid index: ${idx}"
		return 1
	fi
	if [[ "$idx" -lt 1 ]] || [[ "$idx" -gt 999 ]]; then
		nt_err "Index out of range (1-999): ${idx}"
		return 1
	fi
}

# Consumes arguments as a title, stopping at any reserved token or
# numeric index. Sets globals:
#   _consume_title_raw    — space-separated title
#   _consume_title_result — hyphen-joined title
#   _nt_consumed          — number of arguments consumed
consume_title() {
	_consume_title_raw=""
	_consume_title_result=""
	_nt_consumed=0
	local arg t matched
	for arg in "$@"; do
		# Stop at numeric tokens (simple index or range)
		if [[ "$arg" =~ ^[0-9]+$ ]] || [[ "$arg" =~ ^[0-9]+-[0-9]+$ ]]; then
			break
		fi
		# Stop at reserved tokens
		matched=0
		for t in "${_nt_reserved_tokens[@]}"; do
			if [[ "$arg" == "$t" ]]; then
				matched=1
				break
			fi
		done
		if [[ $matched -eq 1 ]]; then
			break
		fi
		if [[ $_nt_consumed -eq 0 ]]; then
			_consume_title_raw="$arg"
		else
			_consume_title_raw+=" $arg"
		fi
		(( _nt_consumed++ )) || true
	done
	_consume_title_result="${_consume_title_raw// /-}"
}

# Composes a filename: build_filename <index> <delimiter> <title> <extension>
# Delimiter defaults to "-" when title is non-empty and delimiter is empty.
build_filename() {
	local index="$1" delimiter="$2" title="$3" extension="$4"
	local result="$index"
	if [[ -n "$title" ]]; then
		if [[ -z "$delimiter" ]]; then
			delimiter="-"
		fi
		result+="${delimiter}${title}"
	fi
	if [[ -n "$extension" ]]; then
		result+=".${extension}"
	fi
	printf '%s' "$result"
}

#######################################################################
# Subcommand functions
#######################################################################

cmd_help() {
	printf 'usage: nt <command> [args]\n\n'
	printf '  nt                           print usage\n'
	printf '  nt help                      print this help (alias: h)\n'
	printf '  nt new [i INDEX] [TITLE]     create new indexed document (alias: n)\n'
	printf '  nt last [N]                  open last (or Nth-to-last) document (alias: l)\n'
	printf '  nt last n                    print last index number (alias: l n)\n'
	printf '  nt NUM [NUM ...]             open document(s) by numeric index\n'
	printf '  nt rename NUM TITLE          rename document by index (alias: r)\n'
	printf '  nt rl TITLE                  rename last document\n'
	printf '  nt renumber N M              renumber consecutive run (alias: rn)\n'
	printf '  nt activity                  activity summary, current dir (alias: a)\n'
	printf '  nt activity-recursive        activity summary, recursive (alias: ar)\n'
	printf '  nt R                         open README.md\n'
	printf '  nt t                         open template file\n'
}

cmd_new() {
	local new_num_raw new_num
	new_num_raw="$(last_num_getter)"
	new_num_raw="$(( new_num_raw + 1 ))"
	new_num="$( printf '%03d' "${new_num_raw}" )"

	# Fetch last doc once for delimiter and extension inheritance
	local last_doc
	last_doc="$(last_indexed_doc 2>/dev/null)" || last_doc=""

	local new_doc new_title_raw new_title
	if [[ "$#" -gt 0 ]]; then
		consume_title "$@"
		new_title_raw="$_consume_title_raw"
		new_title="$_consume_title_result"
		local last_delim
		last_delim="$(get_delimiter "$last_doc")"
		if [[ -z "$last_delim" ]]; then
			new_doc="${new_num}-${new_title}"
		else
			new_doc="${new_num}${last_delim}${new_title}"
		fi
	else
		_nt_consumed=0
		new_doc="${new_num}"
		new_title_raw=""
	fi

	local -a templates
	templates=( ${nt_template_name}.*(N.) )
	local template_count=${#templates[@]}
	if [[ $template_count -eq 1 ]]; then
		local template_file="${templates[1]}"
		new_doc+=".${template_file##*.}"
		sed -e "s|%DATE|$(date '+%Y-%m-%d')|g" \
			-e "s|%TITLE|${new_title_raw}|g" \
			"$template_file" >> "$new_doc"
	elif [[ $template_count -gt 1 ]]; then
		printf "Too many nt template files in this folder.\n"
		exit 5
	else
		local last_ext
		if [ "${new_num_raw}" -eq 1 ]; then
			last_ext="md"
		else
			last_ext="$(get_extension "$last_doc" 2>/dev/null)" || last_ext="md"
		fi
		new_doc+=".${last_ext}"
		local new_time
		new_time="$(date '+%Y.%m.%d-%H:%M')"
		printf "created=${new_time}\n" >> "${new_doc}"
		printf '\n\n\n' >> "${new_doc}"
	fi
	files_to_open+=( "${new_doc}" )
}

cmd_last() {
	local last_num
	last_num="$(last_num_getter)"
	if [ "${last_num}" -eq 0 ]; then
		nt_err "No indexed document found."
		exit 2
	fi

	if [ "$#" -eq 0 ]; then
		# No argument: open the last doc
		_nt_consumed=0
		files_to_open+=( "$(last_indexed_doc)" )
	elif [ "$1" = 'n' ]; then
		# Special token 'n': print numeric index and exit
		printf '%d\n' "${last_num}"
		exit 0
	elif [[ "$1" =~ ^[0-9]+$ ]]; then
		# Positive integer: open nth-to-last
		_nt_consumed=1
		local nth="$1"
		local -a docs
		docs=( [0-9]##*(N.on) )
		local total=${#docs[@]}
		if (( nth < 1 )) || (( nth > total )); then
			nt_err "Only ${total} indexed document(s) found."
			exit 2
		fi
		local idx=$(( total - nth + 1 ))
		files_to_open+=( "${docs[$idx]}" )
	else
		nt_err "Invalid argument for last: $1"
		exit 2
	fi
}

cmd_open() {
	validate_index "$1" || exit 2
	local doc
	doc="$(find_doc_by_index "$1")" || exit 2
	files_to_open+=( "$doc" )
}

cmd_rename() {
	if [ "$#" -lt 2 ]; then
		printf 'usage: %s\n' "${nt_syn_r}"
		exit 1
	fi
	validate_index "$1" || exit 2
	local try_doc try_num
	try_doc="$(find_doc_by_index "$1")" || exit 2
	try_num="$( printf '%03d' "$1" )"
	shift
	consume_title "$@"
	if [ -z "$_consume_title_result" ]; then
		printf 'usage: %s\n' "${nt_syn_r}"
		exit 1
	fi
	local new_title="$_consume_title_result"
	local try_doc_ext try_delim new_doc
	try_doc_ext="$(get_extension "$try_doc" 2>/dev/null)" || try_doc_ext="${try_doc##*.}"
	try_delim="$(get_delimiter "$try_doc")"
	if [ -z "$try_delim" ]; then
		new_doc="${try_num}-${new_title}.${try_doc_ext}"
	else
		new_doc="${try_num}${try_delim}${new_title}.${try_doc_ext}"
	fi
	\mv "${try_doc}" "${new_doc}" \
		&& printf '%s renamed to %s\n' "${try_doc}" "${new_doc}"
}

# Rename the last indexed document to the given title.
cmd_rename_last() {
	if [ "$#" -eq 0 ]; then
		nt_err "usage: nt rl <title>"
		exit 1
	fi
	local last_num
	last_num="$(last_num_getter)"
	if [ "${last_num}" -eq 0 ]; then
		nt_err "No indexed document found."
		exit 2
	fi
	local last_doc
	last_doc="$(last_indexed_doc)"
	consume_title "$@"
	if [ -z "$_consume_title_result" ]; then
		nt_err "usage: nt rl <title>"
		exit 1
	fi
	local new_title="$_consume_title_result"
	local last_num_padded last_delim last_ext new_doc
	last_num_padded="$( printf '%03d' "${last_num}" )"
	last_delim="$(get_delimiter "$last_doc")"
	last_ext="$(get_extension "$last_doc" 2>/dev/null)" || last_ext="${last_doc##*.}"
	if [ -z "$last_delim" ]; then
		new_doc="${last_num_padded}-${new_title}.${last_ext}"
	else
		new_doc="${last_num_padded}${last_delim}${new_title}.${last_ext}"
	fi
	\mv "${last_doc}" "${new_doc}" \
		&& printf '%s renamed to %s\n' "${last_doc}" "${new_doc}"
}

cmd_renumber() {
	if [ "$#" -lt 2 ]; then
		printf 'usage: %s\n' "${nt_syn_rn}"
		exit 1
	fi
	local rn_start="$1" rn_target="$2"
	validate_index "$rn_start" || exit 2
	validate_index "$rn_target" || exit 2
	if [ "$rn_start" -eq "$rn_target" ]; then
		printf 'Nothing to renumber.\n'
		exit 0
	fi
	# verify starting file exists
	local rn_start_doc
	rn_start_doc="$(find_doc_by_index "$rn_start")" || exit 2
	# find end of consecutive run starting from rn_start
	local rn_end=$rn_start
	local rn_next rn_next_padded
	local -a rn_next_docs
	while true; do
		rn_next=$(( rn_end + 1 ))
		rn_next_padded="$( printf '%03d' "$rn_next" )"
		rn_next_docs=( ${rn_next_padded}*(N.) )
		if [[ ${#rn_next_docs[@]} -gt 0 ]]; then
			rn_end=$rn_next
		else
			break
		fi
	done
	local rn_count=$(( rn_end - rn_start ))
	# check for collisions in target range
	local rn_i rn_ti rn_ti_padded
	local -a rn_ti_docs
	for rn_i in $(seq 0 $rn_count); do
		rn_ti=$(( rn_target + rn_i ))
		# skip if target is within source range (will be moved)
		if [ "$rn_ti" -ge "$rn_start" ] && [ "$rn_ti" -le "$rn_end" ]; then
			continue
		fi
		rn_ti_padded="$( printf '%03d' "$rn_ti" )"
		rn_ti_docs=( ${rn_ti_padded}*(N.) )
		if [[ ${#rn_ti_docs[@]} -gt 0 ]]; then
			nt_err "Target index ${rn_ti_padded} already occupied by ${rn_ti_docs[1]}."
			exit 2
		fi
	done
	# rename in correct order to avoid collisions
	local rn_seq
	if [ "$rn_target" -gt "$rn_start" ]; then
		rn_seq="$(seq $rn_count -1 0)"
	else
		rn_seq="$(seq 0 $rn_count)"
	fi
	local rn_si rn_ti_inner rn_si_padded rn_ti_padded_inner rn_si_doc rn_ti_doc_inner
	for rn_i in ${=rn_seq}; do
		rn_si=$(( rn_start + rn_i ))
		rn_ti_inner=$(( rn_target + rn_i ))
		rn_si_padded="$( printf '%03d' "$rn_si" )"
		rn_ti_padded_inner="$( printf '%03d' "$rn_ti_inner" )"
		rn_si_doc="$(find_doc_by_index "$rn_si")" || exit 2
		rn_ti_doc_inner="${rn_ti_padded_inner}${rn_si_doc#${rn_si_padded}}"
		\mv "${rn_si_doc}" "${rn_ti_doc_inner}" \
			&& printf '%s -> %s\n' "${rn_si_doc}" "${rn_ti_doc_inner}"
	done
}

cmd_activity() {
	local -a nt_files
	if [ "$1" = "ar" ]; then
		nt_files=( **/[0-9][0-9][0-9]([_-]*|.?*)(N.) )
	else
		nt_files=( [0-9][0-9][0-9]([_-]*|.?*)(N.) )
	fi
	if [ "${#nt_files[@]}" -eq 0 ]; then
		printf 'No indexed documents found.\n'
		exit 0
	fi
	printf '\nActivity Summary\n================\n\n'
	nt_stat_mtime_ym "${nt_files[@]}" \
		| sort | uniq -c | sort -k2 \
		| while read count month; do
			bar=$(printf '%*s' "$count" '' | tr ' ' '#')
			printf "  %s  %3d  %s\n" "$month" "$count" "$bar"
		done
	printf '\n  Total: %d documents\n\n' "${#nt_files[@]}"
}

cmd_readme() {
	local -a readmes
	readmes=( (#i)readme.md(N.) )
	if [[ ${#readmes[@]} -eq 0 ]]; then
		nt_err "No README.md found in current working directory."
		exit 4
	fi
	files_to_open+=( "${readmes[1]}" )
}

cmd_template() {
	local -a templates
	templates=( ${nt_template_name}.*(N.) )
	local template_count=${#templates[@]}
	if [[ $template_count -eq 1 ]]; then
		files_to_open+=( "${templates[1]}" )
	elif [[ $template_count -gt 1 ]]; then
		printf "Too many nt template files in this folder.\n"
		exit 5
	else
		printf "No nt template found in this folder.\n"
		exit 0
	fi
}

#######################################################################
# Main entry point
#######################################################################

if [ "$#" -eq 0 ]; then
	printf 'usage: nt <command> [args] — run "nt help" for full reference\n'
	exit 0
fi

nt_platform_detect
typeset -aU files_to_open=()
_nt_consumed=0
setopt extended_glob 2>/dev/null

while [ "$#" -gt 0 ]; do
	case "$1" in

		n|new)
			shift
			cmd_new "$@"
			_nc=$_nt_consumed
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		l|last)
			shift
			cmd_last "$@"
			_nc=$_nt_consumed
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		r|rename)
			shift
			cmd_rename "$@"
			# 1 for the index arg + title consumed
			_nc=$(( 1 + _nt_consumed ))
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		rl)
			shift
			cmd_rename_last "$@"
			_nc=$_nt_consumed
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		rn|renumber)    shift; cmd_renumber "$@"; break ;;
		a|activity)     cmd_activity "a";         break ;;
		ar|activity-recursive)
		                cmd_activity "ar";         break ;;
		h|help)         cmd_help;                  break ;;
		R)              cmd_readme;                shift ;;
		t)              cmd_template;              shift ;;

		[0-9]|[0-9][0-9]|[0-9][0-9][0-9])
		                cmd_open "$1"; shift ;;

		*)              nt_err "Unknown option '$1'"; exit 2 ;;
	esac
done

unsetopt extended_glob 2>/dev/null

if [ "${#files_to_open[@]}" -gt 0 ]; then
	nt_open "${nt_editor}" "${files_to_open[@]}"
fi
