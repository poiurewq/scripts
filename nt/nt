#!/usr/bin/env zsh
set -e

#######################################################################
# Display formatting
#######################################################################

bf=$(tput bold 2>/dev/null) || bf=''
nf=$(tput sgr0 2>/dev/null) || nf=''
uf=$(tput smul 2>/dev/null) || uf=''

#######################################################################
# Constants
#######################################################################

nt_template_name='nt_template'
NT_VERSION="0.1.9"

# Regex patterns (stored in variables to prevent zsh backslash removal in =~)
_nt_idx_pat='^([0-9]+(\.[0-9]+)*)([-_]|\.[^0-9]|$)'  # extract: index + boundary
_nt_idx_strict='^[0-9]+(\.[0-9]+)*$'        # validate/consume: full-string match
_nt_range_pat='^[0-9]+-[0-9]+$'             # consume_title: range token
_nt_digits='^[0-9]+$'                        # bare digits

# Editor resolution order: NT_EDITOR > VISUAL > EDITOR > vim  (§3.4)
nt_editor="${NT_EDITOR:-${VISUAL:-${EDITOR:-vim}}}"

# Syntax references used in error messages
nt_syn_r="${bf}rename${nf} ${uf}num${nf} ${uf}title${nf}"
nt_syn_rn="${bf}renumber${nf} ${uf}n${nf} ${uf}m${nf}"

#######################################################################
# Cross-platform abstraction (§2.5)
#######################################################################

NT_PLATFORM='other'

nt_platform_detect() {
	case "$OSTYPE" in
		darwin*)  NT_PLATFORM='darwin' ;;
		linux*)   NT_PLATFORM='linux'  ;;
		*)        NT_PLATFORM='other'  ;;
	esac
}

nt_open_app() {
	local app_name="$1"; shift
	case "$NT_PLATFORM" in
		darwin) open -a "$app_name" "$@" ;;
		*)      "$app_name" "$@" ;;
	esac
}

nt_copy_to_clipboard() {
	local string="$1"
	case "$NT_PLATFORM" in
		darwin)
			printf '%s' "$string" | pbcopy
			;;
		linux)
			printf '%s' "$string" | xsel --clipboard --input 2>/dev/null \
				|| printf '%s' "$string" | xclip -selection clipboard 2>/dev/null \
				|| return 1
			;;
		*)
			return 1
			;;
	esac
}

nt_stat_mtime_ym() {
	case "$NT_PLATFORM" in
		darwin) stat -f "%Sm" -t "%Y-%m" "$@" ;;
		*)      stat -c "%y" "$@" | cut -d'-' -f1,2 ;;
	esac
}

#######################################################################
# Error helper (§2.6)
#######################################################################

nt_err() {
	printf '%s\n' "$1" >&2
}

#######################################################################
# Utility functions
#######################################################################

nt_open() {
	local app_or_cmd="$1"; shift
	local -a file_list=("$@")

	if command -v "${app_or_cmd}" >/dev/null 2>&1; then
		case "$app_or_cmd" in
			vi|vim) vim -p "${file_list[@]}" ;;
			*) "${app_or_cmd}" "${file_list[@]}" ;;
		esac
	else
		nt_open_app "${app_or_cmd}" "${file_list[@]}"
	fi
}

# Extracts the hierarchical index prefix from a filename.
# e.g. "004.7-title.md" -> "004.7", "003-note.md" -> "003", "007.md" -> "007"
extract_index() {
	local f="$1"
	if [[ "$f" =~ $_nt_idx_pat ]]; then
		printf '%s' "${match[1]}"
	fi
}

# Compares two hierarchical indices component-by-component.
# Prints: -1 (a < b), 0 (a == b), 1 (a > b)
compare_indices() {
	local a="$1" b="$2"
	local -a ap bp
	ap=( "${(@s:.:)a}" )
	bp=( "${(@s:.:)b}" )
	local i max_len av bv
	max_len=$(( ${#ap[@]} > ${#bp[@]} ? ${#ap[@]} : ${#bp[@]} ))
	for (( i = 1; i <= max_len; i++ )); do
		av=$(( 10#${ap[$i]:-0} ))
		bv=$(( 10#${bp[$i]:-0} ))
		if (( av < bv )); then printf -- '-1'; return 0; fi
		if (( av > bv )); then printf '1';  return 0; fi
	done
	printf '0'
}

# Increments the last component of a hierarchical index.
# Zero-pads only the first component to 3 digits.
# e.g. "004.7" -> "004.8", "003" -> "004", "004.7.9" -> "004.7.10"
increment_index() {
	local idx="$1"
	if [[ -z "$idx" ]]; then
		nt_err "increment_index: empty index"
		return 1
	fi
	local -a parts
	parts=( "${(@s:.:)idx}" )
	parts[-1]=$(( 10#${parts[-1]} + 1 ))
	parts[1]="$(printf '%03d' "$(( 10#${parts[1]} ))")"
	printf '%s' "${(j:.:)parts}"
}

# Sorts filenames by hierarchical index using a schwartzian transform.
# Reads filenames as arguments; prints sorted filenames one per line.
sort_docs_hierarchically() {
	[[ "$#" -eq 0 ]] && return 0
	local -a pairs parts
	local f idx key p
	for f in "$@"; do
		idx="$(extract_index "$f")"
		[[ -z "$idx" ]] && continue
		# Build a sortable key: each component zero-padded to 5 digits, joined by '.'
		parts=( "${(@s:.:)idx}" )
		key=""
		for p in "${parts[@]}"; do
			key+="$(printf '%05d' "$(( 10#$p ))")."
		done
		pairs+=( "${key}|${f}" )
	done
	local -a sorted
	sorted=( "${(@o)pairs}" )   # lexicographic sort; pads make it numeric-equivalent
	local pair
	for pair in "${sorted[@]}"; do
		printf '%s\n' "${pair#*|}"
	done
}

# Returns the filename of the last indexed document (hierarchically).
# Returns 1 if no indexed documents exist.
last_indexed_doc() {
	local -a docs
	docs=( [[:digit:]]##*(N.) )
	if [[ ${#docs[@]} -eq 0 ]]; then
		return 1
	fi
	local sorted_last
	sorted_last="$(sort_docs_hierarchically "${docs[@]}" | tail -n1)"
	printf '%s' "$sorted_last"
}

# Returns the full hierarchical index string of the last indexed document.
# Returns 1 if no indexed documents exist.
last_index() {
	local doc
	doc="$(last_indexed_doc 2>/dev/null)" || return 1
	extract_index "$doc"
}

# Returns the delimiter between the index and title portions of a filename.
get_delimiter() {
	local name="$1"
	local idx
	idx="$(extract_index "$name")"
	[[ -z "$idx" ]] && return
	local rest="${name#${idx}}"
	if [[ "$rest" == _* ]]; then
		[[ "$rest" =~ ^(_+) ]] && printf '%s' "${match[1]}"
	elif [[ "$rest" == -* ]]; then
		[[ "$rest" =~ ^(-+) ]] && printf '%s' "${match[1]}"
	fi
}

# Returns the file extension (after last dot, if non-numeric). Returns 1 if none.
get_extension() {
	local filename="$1"
	local ext="${filename##*.}"
	if [[ "$ext" == "$filename" ]] || [[ "$ext" =~ $_nt_digits ]]; then
		return 1
	fi
	printf '%s' "$ext"
}

# Returns the matching filename for a given index (simple or hierarchical).
# Normalizes the first component to 3 digits.
find_doc_by_index() {
	local idx="$1"
	local -a parts
	parts=( "${(@s:.:)idx}" )
	parts[1]="$(printf '%03d' "$(( 10#${parts[1]} ))")"
	local normalized="${(j:.:)parts}"

	local -a candidates
	candidates=( ${normalized}*(N.) )

	local -a docs
	local f file_idx
	for f in "${candidates[@]}"; do
		file_idx="$(extract_index "$f")"
		if [[ "$file_idx" == "$normalized" ]]; then
			docs+=( "$f" )
		fi
	done

	if [[ ${#docs[@]} -eq 0 ]]; then
		nt_err "File with index ${normalized} not found."
		return 1
	fi
	if [[ ${#docs[@]} -gt 1 ]]; then
		if [[ -t 2 ]]; then
			printf 'Multiple files with index %s:\n' "$normalized" >&2
			local i
			for (( i = 1; i <= ${#docs[@]}; i++ )); do
				printf '  %d) %s\n' "$i" "${docs[$i]}" >&2
			done
			local choice
			printf 'Select [1-%d]: ' "${#docs[@]}" >&2
			read -r choice </dev/tty
			if ! [[ "$choice" =~ $_nt_digits ]] \
				|| (( choice < 1 || choice > ${#docs[@]} )); then
				nt_err "Invalid selection."
				return 1
			fi
			printf '%s' "${docs[$choice]}"
		else
			nt_err "Multiple files with index ${normalized}: ${docs[*]}"
			return 1
		fi
		return 0
	fi
	printf '%s' "${docs[1]}"
}

# Validates an index (simple integer or hierarchical dot-separated).
validate_index() {
	local idx="$1"
	if ! [[ "$idx" =~ $_nt_idx_strict ]]; then
		nt_err "Invalid index: ${idx}"
		return 1
	fi
	local -a parts
	parts=( "${(@s:.:)idx}" )
	if [[ $(( 10#${parts[1]} )) -lt 1 ]]; then
		nt_err "Index must start with a positive integer: ${idx}"
		return 1
	fi
	local p
	for p in "${parts[@]}"; do
		if [[ $(( 10#$p )) -gt 999 ]]; then
			nt_err "Index component out of range (0-999): ${p}"
			return 1
		fi
	done
}

# Consumes arguments as a title. Behaviour depends on $_nt_greedy:
#
#   Greedy mode   ($_nt_greedy=1, set when command has no leading hyphen):
#     Consume ALL arguments — no stopping at reserved words or numbers.
#     Allows titles like "my new note 5" without quoting.
#
#   Non-greedy mode ($_nt_greedy=0, set when command has a leading hyphen):
#     Stop at the first bare number, range token (N-M), or any arg that
#     starts with '-'.  Those tokens belong to the next chained option.
#
# Sets globals:
#   _consume_title_raw    — space-separated title
#   _consume_title_result — hyphen-joined title
#   _nt_consumed          — number of arguments consumed
consume_title() {
	_consume_title_raw=""
	_consume_title_result=""
	_nt_consumed=0
	local arg
	for arg in "$@"; do
		if [[ $_nt_greedy -eq 0 ]]; then
			# Non-greedy stop condition: only hyphen-prefixed args
			if [[ "$arg" == -* ]]; then
				break
			fi
		fi
		if [[ $_nt_consumed -eq 0 ]]; then
			_consume_title_raw="$arg"
		else
			_consume_title_raw+=" $arg"
		fi
		(( _nt_consumed++ )) || true
	done
	_consume_title_result="${_consume_title_raw// /-}"
}

# Composes a filename: build_filename <index> <delimiter> <title> <extension>
build_filename() {
	local index="$1" delimiter="$2" title="$3" extension="$4"
	local result="$index"
	if [[ -n "$title" ]]; then
		if [[ -z "$delimiter" ]]; then
			delimiter="-"
		fi
		result+="${delimiter}${title}"
	fi
	if [[ -n "$extension" ]]; then
		result+=".${extension}"
	fi
	printf '%s' "$result"
}

#######################################################################
# Subcommand functions
#######################################################################

cmd_help() {
	printf '\n'
	printf 'nt — simple notes maintainer\n\n'
	printf 'usage: nt <command> [args]\n\n'
	printf '  nt h                print this help (alias: help)\n'
	printf '  nt n [TITLE]        create new indexed document (alias: new)\n'
	printf '  nt l [N]            open last (or Nth-to-last) document (alias: last)\n'
	printf '  nt li               print last index number (alias: last-index)\n'
	printf '  nt NUM [NUM ...]    open document(s) by index (supports N.M hierarchical)\n'
	printf '  nt r NUM TITLE      rename document by index (alias: rename)\n'
	printf '  nt rl TITLE         rename last document\n'
	printf '  nt rn N M           renumber consecutive run (alias: renumber)\n'
	printf '  nt a                activity summary, current dir (alias: activity)\n'
	printf '  nt ar               activity summary, recursive (alias: activity-recursive)\n'
	printf '  nt R                open README.md\n'
	printf '  nt t                open template file\n'
	printf '  nt v                print version (alias: version)\n'
	printf '\nBare commands (no hyphen) consume all remaining words as the title.\n'
	printf 'Hyphen-prefixed commands stop at numbers/flags, enabling chaining;\n'
	printf 'chained commands are processed in the sequence they are passed:\n'
	printf '  nt -n new note one -n new note two\n'
	printf '  creates two new notes and opens both of them\n\n'
	printf 'To get started, type: man nt  (see the EXAMPLES section)\n\n'
}

cmd_version() {
	printf 'nt %s\n' "$NT_VERSION"
}

cmd_new() {
	local last_idx new_idx
	last_idx="$(last_index 2>/dev/null)" || last_idx=""

	if [[ -z "$last_idx" ]]; then
		new_idx="001"
	else
		new_idx="$(increment_index "$last_idx")"
	fi

	local last_doc
	last_doc="$(last_indexed_doc 2>/dev/null)" || last_doc=""

	local new_doc new_title_raw new_title
	if [[ "$#" -gt 0 ]]; then
		consume_title "$@"
		new_title_raw="$_consume_title_raw"
		new_title="$_consume_title_result"
		local last_delim
		last_delim="$(get_delimiter "$last_doc")"
		if [[ -z "$last_delim" ]]; then
			new_doc="${new_idx}-${new_title}"
		else
			new_doc="${new_idx}${last_delim}${new_title}"
		fi
	else
		_nt_consumed=0
		new_doc="${new_idx}"
		new_title_raw=""
	fi

	local -a templates
	templates=( ${nt_template_name}.*(N.) )
	local template_count=${#templates[@]}
	if [[ $template_count -eq 1 ]]; then
		local template_file="${templates[1]}"
		new_doc+=".${template_file##*.}"
		sed -e "s|%DATE|$(date '+%Y-%m-%d')|g" \
			-e "s|%TITLE|${new_title_raw}|g" \
			"$template_file" >> "$new_doc"
	elif [[ $template_count -gt 1 ]]; then
		printf "Too many nt template files in this folder.\n"
		exit 5
	else
		local last_ext
		if [[ -z "$last_doc" ]]; then
			last_ext="md"
		else
			last_ext="$(get_extension "$last_doc" 2>/dev/null)" || last_ext="md"
		fi
		new_doc+=".${last_ext}"
		local new_time
		new_time="$(date '+%Y.%m.%d-%H:%M')"
		printf "created=${new_time}\n" >> "${new_doc}"
		printf '\n\n\n' >> "${new_doc}"
	fi
	files_to_open+=( "${new_doc}" )
}

cmd_last() {
	local last_doc
	last_doc="$(last_indexed_doc 2>/dev/null)" || {
		nt_err "No indexed document found."
		exit 2
	}

	# In non-greedy mode, a leading-hyphen arg belongs to the next command.
	if [[ "$#" -gt 0 ]] && [[ "$1" == -* ]] && [[ $_nt_greedy -eq 0 ]]; then
		_nt_consumed=0
		files_to_open+=( "$last_doc" )
		return 0
	fi

	if [ "$#" -eq 0 ]; then
		# No argument: open the last doc
		_nt_consumed=0
		files_to_open+=( "$last_doc" )
	elif [[ "$1" =~ $_nt_digits ]]; then
		# Positive integer N: open Nth-to-last
		_nt_consumed=1
		local nth="$1"
		local -a all_docs
		all_docs=( [[:digit:]]##*(N.) )
		local sorted_output
		sorted_output="$(sort_docs_hierarchically "${all_docs[@]}")"
		local -a sorted_docs
		sorted_docs=( "${(f)sorted_output}" )
		local total=${#sorted_docs[@]}
		if (( nth < 1 )) || (( nth > total )); then
			nt_err "Only ${total} indexed document(s) found."
			exit 2
		fi
		local idx=$(( total - nth + 1 ))
		files_to_open+=( "${sorted_docs[$idx]}" )
	else
		nt_err "Invalid argument for last: $1"
		exit 2
	fi
}

cmd_last_index() {
	local idx
	idx="$(last_index 2>/dev/null)" || {
		nt_err "No indexed document found."
		exit 2
	}
	# Strip leading zeros from each component for display
	local -a parts
	parts=( "${(@s:.:)idx}" )
	local -a stripped
	local p
	for p in "${parts[@]}"; do
		stripped+=( "$(( 10#$p ))" )
	done
	printf '%s\n' "${(j:.:)stripped}"
}

cmd_open() {
	validate_index "$1" || exit 2
	local doc
	doc="$(find_doc_by_index "$1")" || exit 2
	files_to_open+=( "$doc" )
}

cmd_rename() {
	if [ "$#" -lt 2 ]; then
		printf 'usage: %s\n' "${nt_syn_r}"
		exit 1
	fi
	validate_index "$1" || exit 2
	local try_doc
	try_doc="$(find_doc_by_index "$1")" || exit 2
	local try_idx
	try_idx="$(extract_index "$try_doc")"
	shift
	consume_title "$@"
	if [ -z "$_consume_title_result" ]; then
		printf 'usage: %s\n' "${nt_syn_r}"
		exit 1
	fi
	local new_title="$_consume_title_result"
	local try_doc_ext try_delim new_doc
	try_doc_ext="$(get_extension "$try_doc" 2>/dev/null)" || try_doc_ext="${try_doc##*.}"
	try_delim="$(get_delimiter "$try_doc")"
	if [ -z "$try_delim" ]; then
		new_doc="${try_idx}-${new_title}.${try_doc_ext}"
	else
		new_doc="${try_idx}${try_delim}${new_title}.${try_doc_ext}"
	fi
	\mv "${try_doc}" "${new_doc}" \
		&& printf '%s renamed to %s\n' "${try_doc}" "${new_doc}"
}

# Rename the last indexed document to the given title.
cmd_rename_last() {
	if [ "$#" -eq 0 ]; then
		nt_err "usage: nt rl <title>"
		exit 1
	fi
	local last_doc
	last_doc="$(last_indexed_doc 2>/dev/null)" || {
		nt_err "No indexed document found."
		exit 2
	}
	local last_idx
	last_idx="$(extract_index "$last_doc")"
	consume_title "$@"
	if [ -z "$_consume_title_result" ]; then
		nt_err "usage: nt rl <title>"
		exit 1
	fi
	local new_title="$_consume_title_result"
	local last_delim last_ext new_doc
	last_delim="$(get_delimiter "$last_doc")"
	last_ext="$(get_extension "$last_doc" 2>/dev/null)" || last_ext="${last_doc##*.}"
	if [ -z "$last_delim" ]; then
		new_doc="${last_idx}-${new_title}.${last_ext}"
	else
		new_doc="${last_idx}${last_delim}${new_title}.${last_ext}"
	fi
	\mv "${last_doc}" "${new_doc}" \
		&& printf '%s renamed to %s\n' "${last_doc}" "${new_doc}"
}

cmd_renumber() {
	if [ "$#" -lt 2 ]; then
		printf 'usage: %s\n' "${nt_syn_rn}"
		exit 1
	fi
	local rn_start="$1" rn_target="$2"
	validate_index "$rn_start" || exit 2
	validate_index "$rn_target" || exit 2

	# Normalize first components to 3 digits
	local -a start_parts target_parts
	start_parts=( "${(@s:.:)rn_start}" )
	target_parts=( "${(@s:.:)rn_target}" )
	start_parts[1]="$(printf '%03d' "$(( 10#${start_parts[1]} ))")"
	target_parts[1]="$(printf '%03d' "$(( 10#${target_parts[1]} ))")"
	local norm_start="${(j:.:)start_parts}"
	local norm_target="${(j:.:)target_parts}"

	# Both indices must have the same depth
	if [[ ${#start_parts[@]} -ne ${#target_parts[@]} ]]; then
		nt_err "Start and target must have the same number of index components."
		exit 2
	fi
	local depth=${#start_parts[@]}

	if [[ "$norm_start" == "$norm_target" ]]; then
		printf 'Nothing to renumber.\n'
		exit 0
	fi

	# Verify start document exists
	find_doc_by_index "$norm_start" >/dev/null || exit 2

	# Find consecutive run (increment last component, same parent prefix)
	local -a rn_end_parts=( "${start_parts[@]}" )
	local next_last next_idx
	local -a next_parts
	while true; do
		next_last=$(( 10#${rn_end_parts[-1]} + 1 ))
		next_parts=( "${rn_end_parts[@]}" )
		next_parts[-1]="$next_last"
		next_idx="${(j:.:)next_parts}"
		if find_doc_by_index "$next_idx" >/dev/null 2>&1; then
			rn_end_parts=( "${next_parts[@]}" )
		else
			break
		fi
	done

	local start_last=$(( 10#${start_parts[-1]} ))
	local end_last=$(( 10#${rn_end_parts[-1]} ))
	local target_last=$(( 10#${target_parts[-1]} ))
	local rn_count=$(( end_last - start_last ))

	# Parent prefix of the start range (for overlap detection)
	local start_prefix="" target_prefix=""
	if [[ $depth -gt 1 ]]; then
		start_prefix="${(j:.:)start_parts[1,-2]}"
		target_prefix="${(j:.:)target_parts[1,-2]}"
	fi

	# Collision check: target slots must be free (unless within source range)
	local rn_i ti_last chk_idx chk_doc
	local -a chk_arr
	for rn_i in $(seq 0 $rn_count); do
		ti_last=$(( target_last + rn_i ))
		# Skip slots that will be vacated (same prefix, overlapping range)
		if [[ "$start_prefix" == "$target_prefix" ]] \
			&& (( ti_last >= start_last && ti_last <= end_last )); then
			continue
		fi
		chk_arr=( "${target_parts[@]}" )
		chk_arr[-1]="$ti_last"
		chk_arr[1]="$(printf '%03d' "$(( 10#${chk_arr[1]} ))")"
		chk_idx="${(j:.:)chk_arr}"
		chk_doc=
		if chk_doc="$(find_doc_by_index "$chk_idx" 2>/dev/null)"; then
			nt_err "Target index ${chk_idx} already occupied by ${chk_doc}."
			exit 2
		fi
	done

	# Determine move order to avoid overwriting
	local rn_seq
	if [[ "$(compare_indices "$norm_target" "$norm_start")" == "1" ]]; then
		rn_seq="$(seq $rn_count -1 0)"
	else
		rn_seq="$(seq 0 $rn_count)"
	fi

	local si_last si_idx_norm ti_idx_norm si_doc ti_doc si_file_idx
	local -a si_arr ti_arr
	for rn_i in ${=rn_seq}; do
		si_last=$(( start_last + rn_i ))
		ti_last=$(( target_last + rn_i ))

		# Build zero-padded source index
		si_arr=( "${start_parts[@]}" )
		si_arr[-1]="$si_last"
		si_arr[1]="$(printf '%03d' "$(( 10#${si_arr[1]} ))")"
		si_idx_norm="${(j:.:)si_arr}"

		# Build zero-padded target index
		ti_arr=( "${target_parts[@]}" )
		ti_arr[-1]="$ti_last"
		ti_arr[1]="$(printf '%03d' "$(( 10#${ti_arr[1]} ))")"
		ti_idx_norm="${(j:.:)ti_arr}"

		si_doc="$(find_doc_by_index "$si_idx_norm")" || exit 2
		# Get the exact index prefix as it appears in the filename
		si_file_idx="$(extract_index "$si_doc")"
		# Replace the index prefix in the filename
		ti_doc="${ti_idx_norm}${si_doc#${si_file_idx}}"
		\mv "${si_doc}" "${ti_doc}" \
			&& printf '%s -> %s\n' "${si_doc}" "${ti_doc}"
	done
}

cmd_activity() {
	local -a nt_files
	if [ "$1" = "ar" ]; then
		nt_files=( **/[[:digit:]]##*(N.) )
	else
		nt_files=( [[:digit:]]##*(N.) )
	fi
	if [ "${#nt_files[@]}" -eq 0 ]; then
		printf 'No indexed documents found.\n'
		exit 0
	fi
	printf '\nActivity Summary\n================\n\n'
	nt_stat_mtime_ym "${nt_files[@]}" \
		| sort | uniq -c | sort -k2 \
		| while read count month; do
			bar=$(printf '%*s' "$count" '' | tr ' ' '#')
			printf "  %s  %3d  %s\n" "$month" "$count" "$bar"
		done
	printf '\n  Total: %d documents\n\n' "${#nt_files[@]}"
}

cmd_readme() {
	local -a readmes
	readmes=( (#i)readme.md(N.) )
	if [[ ${#readmes[@]} -eq 0 ]]; then
		touch README.md
		readmes=( README.md )
	fi
	files_to_open+=( "${readmes[1]}" )
}

cmd_template() {
	local -a templates
	templates=( ${nt_template_name}.*(N.) )
	local template_count=${#templates[@]}
	if [[ $template_count -eq 1 ]]; then
		files_to_open+=( "${templates[1]}" )
	elif [[ $template_count -gt 1 ]]; then
		printf "Too many nt template files in this folder.\n"
		exit 5
	else
		touch "${nt_template_name}.md"
		files_to_open+=( "${nt_template_name}.md" )
	fi
}

#######################################################################
# Main entry point
#######################################################################

if [ "$#" -eq 0 ]; then
	cmd_help
	exit 0
fi

nt_platform_detect
typeset -aU files_to_open=()
_nt_consumed=0
_nt_greedy=0
setopt extended_glob 2>/dev/null

# Helper: shift past _nt_consumed args in the main arg list.
# Used after title-consuming commands so the dispatcher loop can continue.
_nt_shift_consumed() {
	_nc=$_nt_consumed
	while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
}

while [ "$#" -gt 0 ]; do
	case "$1" in

		# ── Bare (greedy) forms ──────────────────────────────────────
		# Consume ALL remaining args as the title.  No stopping at
		# reserved words or numbers.  Chaining is not supported in
		# bare mode; use the hyphen forms for that.

		n|new)
			shift; _nt_greedy=1; cmd_new "$@"
			_nc=$_nt_consumed
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		l|last)
			shift; _nt_greedy=1; cmd_last "$@"
			_nc=$_nt_consumed
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		li|last-index|-li|--last-index)
			cmd_last_index; break ;;

		r|rename)
			shift; _nt_greedy=1; cmd_rename "$@"
			_nc=$(( 1 + _nt_consumed ))
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		rl)
			shift; _nt_greedy=1; cmd_rename_last "$@"
			_nc=$_nt_consumed
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		# ── Hyphen-prefixed (non-greedy) forms ───────────────────────
		# Stop title consumption at the first bare number, range, or
		# any -flag arg.  Those tokens are left in $@ for the next
		# iteration, enabling option chaining.

		-n|--new)
			shift; _nt_greedy=0; cmd_new "$@"
			_nc=$_nt_consumed
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		-l|--last)
			shift; _nt_greedy=0; cmd_last "$@"
			_nc=$_nt_consumed
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		-r|--rename)
			shift; _nt_greedy=0; cmd_rename "$@"
			_nc=$(( 1 + _nt_consumed ))
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		-rl|--rl)
			shift; _nt_greedy=0; cmd_rename_last "$@"
			_nc=$_nt_consumed
			while [ "$_nc" -gt 0 ] && [ "$#" -gt 0 ]; do shift; _nc=$(( _nc - 1 )); done
			;;

		# ── Stateless commands (greedy/non-greedy irrelevant) ────────

		rn|renumber|-rn|--renumber)
			shift; cmd_renumber "$@"; break ;;

		a|activity|-a|--activity)
			cmd_activity "a"; break ;;

		ar|activity-recursive|-ar|--activity-recursive)
			cmd_activity "ar"; break ;;

		h|help|-h|--help)
			cmd_help; break ;;

		v|version|-v|--version)
			cmd_version; break ;;

		R|-R)     cmd_readme;   shift ;;
		t|-t)     cmd_template; shift ;;

		# ── Numeric index (simple or hierarchical) ───────────────────
		# Bare form:    3, 007, 1.1, 004.7.10, etc.
		# Hyphen form: -3, -007, -1.1, etc. (for use in chained commands)
		[0123456789]*)
			if [[ "$1" =~ $_nt_idx_strict ]]; then
				cmd_open "$1"; shift
			else
				nt_err "Unknown option '$1'"; exit 2
			fi
			;;

		-[0123456789]*)
			if [[ "${1#-}" =~ $_nt_idx_strict ]]; then
				cmd_open "${1#-}"; shift
			else
				nt_err "Unknown option '$1'"; exit 2
			fi
			;;

		*)        nt_err "Unknown option '$1'"; exit 2 ;;
	esac
done

unsetopt extended_glob 2>/dev/null

if [ "${#files_to_open[@]}" -gt 0 ]; then
	nt_open "${nt_editor}" "${files_to_open[@]}"
fi
